---
// R3 — ⌘K command palette (REDESIGN.md §4.6). Site-wide, mounted in Base.astro.
// Solid paper panel (NOT glass — that's the AI-slop tell), hairline-ruled rows,
// ember <mark> highlights. Engine: Pagefind JS API with heading-level sub-results
// + topic facets; the existing /search-index.json keyword scorer is the dev
// fallback (Pagefind only exists after `astro build`).
import { getCollection } from "astro:content";
import { UI, type Lang } from "../lib/i18n";
import { prettyTopic } from "../lib/format";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = UI[lang];
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const homeHref = lang === "th" ? `${base}/th/` : `${base}/`;

// Top topics for the empty state — latest report per topic in this lang, by salience.
const all = await getCollection("reports");
const byTopic = new Map<string, (typeof all)[number]>();
for (const e of all) {
  if (e.data.lang !== lang) continue;
  const cur = byTopic.get(e.data.topic);
  if (!cur || e.data.date > cur.data.date) byTopic.set(e.data.topic, e);
}
const topicChips = [...byTopic.values()]
  .sort((a, b) => (b.data.salience ?? 0) - (a.data.salience ?? 0))
  .slice(0, 8)
  .map((e) => ({
    label: prettyTopic(e.data.topic),
    url: `${base}/report/${e.data.date}/${e.data.topic}/${lang}`,
  }));

const strings = {
  search: t.search,
  placeholder: t.searchPlaceholder,
  empty: t.searchEmpty,
  hint: t.searchHint,
  recent: t.searchRecent,
  browse: t.searchBrowse,
  matchesIn: t.searchMatchesIn,
  clear: t.filterClear,
  filterTopic: t.filterTopic,
  results: { one: t.searchResultsCount(1).replace(/^\d+\s*/, ""), many: t.searchResultsCount(2).replace(/^\d+\s*/, "") },
};
---

<div class="search-scrim" data-search-scrim hidden data-pagefind-ignore>
  <div class="search-palette" role="dialog" aria-modal="true" aria-label={t.search}>
    <div class="search-input-row">
      <svg class="search-glyph" width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
        <circle cx="11" cy="11" r="6.2" fill="none" stroke="currentColor" stroke-width="1.7" />
        <line x1="15.6" y1="15.6" x2="20" y2="20" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
      </svg>
      <input
        type="text"
        class="search-field"
        data-search-input
        placeholder={t.searchPlaceholder}
        aria-label={t.searchPlaceholder}
        autocomplete="off"
        autocapitalize="off"
        spellcheck="false"
        enterkeyhint="search"
      />
      <kbd class="search-esc">esc</kbd>
    </div>

    <div class="search-facets" data-search-facets hidden></div>

    <div class="search-results" data-search-results role="listbox" aria-label={t.search}></div>

    <div class="search-blank" data-search-blank>
      <div class="search-blank-group" data-search-recent-group hidden>
        <p class="search-blank-lbl eyebrow">{t.searchRecent}</p>
        <div class="search-chips" data-search-recent></div>
      </div>
      <div class="search-blank-group">
        <p class="search-blank-lbl eyebrow">{t.searchBrowse}</p>
        <div class="search-chips">
          {topicChips.map((c) => (
            <a class="search-chip" href={c.url} data-search-chip>{c.label}</a>
          ))}
          <a class="search-chip search-chip--archive" href={homeHref}>{t.archive} →</a>
        </div>
      </div>
    </div>

    <div class="search-foot">
      <span class="search-count num" data-search-count></span>
      <span class="search-foot-hint">{t.searchHint}</span>
    </div>
  </div>
</div>

<style>
  /* Solid paper panel — NO backdrop blur / glassmorphism (REDESIGN §1 hard NO). */
  .search-scrim {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: clamp(3.5rem, 12vh, 8rem) 1rem 2rem;
    background: color-mix(in oklch, var(--ink), transparent 52%);
  }
  .search-scrim[hidden] { display: none; }
  @media (prefers-reduced-motion: no-preference) {
    .search-scrim:not([hidden]) { animation: scrim-in 140ms ease both; }
    .search-scrim:not([hidden]) .search-palette { animation: palette-in 180ms cubic-bezier(0.16, 1, 0.3, 1) both; }
  }
  @keyframes scrim-in { from { opacity: 0; } to { opacity: 1; } }
  @keyframes palette-in { from { opacity: 0; transform: translateY(-8px); } to { opacity: 1; transform: translateY(0); } }

  .search-palette {
    width: min(42rem, 100%);
    max-height: min(70vh, 40rem);
    display: flex;
    flex-direction: column;
    background: var(--paper);
    border: var(--rule-section);
    box-shadow: 0 24px 60px -28px color-mix(in oklch, var(--ink), transparent 35%);
  }

  .search-input-row {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.85rem 1.05rem;
    border-bottom: var(--rule-section);
    flex-shrink: 0;
  }
  .search-glyph { color: var(--soft-ink); flex-shrink: 0; }
  .search-field {
    flex: 1;
    min-width: 0;
    font-family: var(--font-ui);
    font-size: var(--step-1);
    background: none;
    border: none;
    color: var(--ink);
    outline: none;
    line-height: 1.3;
  }
  .search-field::placeholder { color: var(--faint-ink); }
  .search-esc {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--faint-ink);
    border: var(--rule-faint);
    padding: 0.1rem 0.4rem;
    flex-shrink: 0;
  }

  /* Topic facet chips (shown when a query has results) */
  .search-facets {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding: 0.6rem 1.05rem;
    border-bottom: var(--rule-faint);
    flex-shrink: 0;
  }
  .search-facets[hidden] { display: none; }
  .facet-chip {
    appearance: none;
    cursor: pointer;
    font-family: var(--font-ui);
    font-size: 0.72rem;
    letter-spacing: 0.02em;
    padding: 0.2rem 0.55rem;
    min-height: 30px;
    background: none;
    border: var(--rule-faint);
    color: var(--soft-ink);
    transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
  }
  .facet-chip:hover { color: var(--accent-ink); border-color: var(--accent); }
  .facet-chip[aria-pressed="true"] {
    color: var(--accent-ink);
    border-color: color-mix(in oklch, var(--accent), transparent 45%);
    background: color-mix(in oklch, var(--accent), transparent 90%);
    font-weight: 600;
  }

  .search-results {
    overflow-y: auto;
    flex: 1 1 auto;
  }
  .search-results:empty { display: none; }

  .search-row {
    display: block;
    padding: 0.75rem 1.05rem;
    border-top: var(--rule-faint);
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }
  .search-row:first-child { border-top: 0; }
  .search-row:hover,
  .search-row.is-active {
    background: color-mix(in oklch, var(--accent), transparent 90%);
  }
  .search-row-head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.35rem 0.7rem;
    font-family: var(--font-ui);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.72rem;
    color: var(--soft-ink);
  }
  .search-row-date {
    font-family: var(--font-mono);
    letter-spacing: 0;
    text-transform: none;
    color: var(--faint-ink);
  }
  .search-row-excerpt {
    margin: 0.3rem 0 0;
    font-family: var(--font-body);
    font-size: var(--step--1);
    line-height: 1.5;
    color: var(--soft-ink);
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
  }
  .search-row-excerpt :global(mark) {
    background: color-mix(in oklch, var(--accent), transparent 78%);
    color: var(--ink);
    padding: 0 0.1em;
    border-radius: 1px;
  }
  .search-row-sub {
    margin: 0.3rem 0 0;
    font-family: var(--font-ui);
    font-size: 0.7rem;
    color: var(--faint-ink);
    letter-spacing: 0.01em;
  }
  .search-row-sub .arrow { color: var(--accent-ink); }

  /* Empty / blank state */
  .search-blank {
    padding: 0.9rem 1.05rem 1.05rem;
    overflow-y: auto;
  }
  .search-blank[hidden] { display: none; }
  .search-blank-group + .search-blank-group { margin-top: 1rem; }
  .search-blank-lbl { margin: 0 0 0.55rem; }
  .search-chips { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .search-chip {
    font-family: var(--font-ui);
    font-size: 0.78rem;
    letter-spacing: 0.01em;
    padding: 0.3rem 0.65rem;
    min-height: 36px;
    display: inline-flex;
    align-items: center;
    border: var(--rule-faint);
    color: var(--soft-ink);
    text-decoration: none;
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .search-chip:hover { color: var(--accent-ink); border-color: var(--accent); }
  .search-chip--archive { color: var(--accent-ink); border-color: color-mix(in oklch, var(--accent), transparent 55%); }

  .search-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem 1rem;
    flex-wrap: wrap;
    padding: 0.6rem 1.05rem;
    border-top: var(--rule-section);
    font-family: var(--font-ui);
    font-size: 0.72rem;
    color: var(--faint-ink);
    flex-shrink: 0;
  }
  .search-count { color: var(--soft-ink); }
  .search-count:empty { display: none; }

  @media (max-width: 560px) {
    .search-scrim { padding-top: 2rem; }
    .search-palette { max-height: 82vh; }
    .search-field { font-size: var(--step-0); }
    .search-foot-hint { display: none; }
  }
</style>

<script is:inline define:vars={{ strings, lang, base }}>
  (() => {
    const scrim = document.querySelector("[data-search-scrim]");
    if (!scrim) return;
    const palette = scrim.querySelector(".search-palette");
    const input = scrim.querySelector("[data-search-input]");
    const resultsEl = scrim.querySelector("[data-search-results]");
    const blankEl = scrim.querySelector("[data-search-blank]");
    const recentGroup = scrim.querySelector("[data-search-recent-group]");
    const recentEl = scrim.querySelector("[data-search-recent]");
    const facetsEl = scrim.querySelector("[data-search-facets]");
    const countEl = scrim.querySelector("[data-search-count]");

    const RECENT_KEY = "sdr:recent-search";
    let pagefind = null;     // resolved Pagefind module (build/preview)
    let pfSearch = null;     // bound search fn
    let fallbackDocs = null; // JSON keyword path (dev)
    let loadPromise = null;
    let topicFilter = null;  // selected facet value
    let lastResults = [];    // rendered row data (for keyboard nav)
    let activeIdx = -1;
    let lastReturnFocus = null;

    // ---- recent searches (localStorage, last 5) ----
    function readRecent() {
      try { return JSON.parse(localStorage.getItem(RECENT_KEY) || "[]"); } catch { return []; }
    }
    function pushRecent(q) {
      q = (q || "").trim();
      if (q.length < 2) return;
      let list = readRecent().filter((x) => x.toLowerCase() !== q.toLowerCase());
      list.unshift(q);
      list = list.slice(0, 5);
      try { localStorage.setItem(RECENT_KEY, JSON.stringify(list)); } catch {}
    }
    function paintRecent() {
      const list = readRecent();
      if (!list.length) { recentGroup.hidden = true; return; }
      recentGroup.hidden = false;
      recentEl.innerHTML = "";
      for (const q of list) {
        const b = document.createElement("button");
        b.type = "button";
        b.className = "search-chip";
        b.textContent = q;
        b.addEventListener("click", () => { input.value = q; runQuery(q); input.focus(); });
        recentEl.appendChild(b);
      }
    }

    // ---- open / close ----
    function open() {
      if (!scrim.hidden) return;
      lastReturnFocus = document.activeElement;
      scrim.hidden = false;
      document.documentElement.style.overflow = "hidden";
      paintRecent();
      showBlank(true);
      loadSearch();
      requestAnimationFrame(() => input.focus());
    }
    function close() {
      if (scrim.hidden) return;
      scrim.hidden = true;
      document.documentElement.style.overflow = "";
      input.value = "";
      resultsEl.innerHTML = "";
      facetsEl.hidden = true;
      countEl.textContent = "";
      activeIdx = -1;
      lastResults = [];
      topicFilter = null;
      if (lastReturnFocus && lastReturnFocus.focus) lastReturnFocus.focus();
    }
    function showBlank(on) {
      blankEl.hidden = !on;
      if (on) { resultsEl.innerHTML = ""; facetsEl.hidden = true; countEl.textContent = ""; }
    }

    // ---- engine load (Pagefind, else JSON fallback) ----
    async function loadSearch() {
      if (loadPromise) return loadPromise;
      loadPromise = (async () => {
        try {
          const pf = await import(/* @vite-ignore */ `${base}/pagefind/pagefind.js`);
          await pf.options({ language: document.documentElement.lang || lang || "en" });
          pagefind = pf;
          pfSearch = async (q, filters) => {
            const r = await pf.search(q && q.length ? q : null, filters ? { filters } : {});
            return { total: r.results.length, items: await Promise.all(r.results.slice(0, 8).map((x) => x.data())) };
          };
        } catch {
          try {
            const res = await fetch(`${base}/search-index.json`);
            fallbackDocs = res.ok ? (await res.json()).docs || [] : [];
          } catch { fallbackDocs = []; }
        }
      })();
      return loadPromise;
    }

    function tokenize(s) {
      return (s || "").toLowerCase().replace(/[`*_#>\[\]\(\)]/g, " ")
        .split(/[^a-z0-9ก-๙\-]+/u).filter((x) => x && x.length > 1);
    }
    function scoreDoc(doc, tokens) {
      const hay = [doc.title, doc.topic, (doc.tags || []).join(" "),
        (doc.tldr || []).join(" "), (doc.signals || []).join(" ")].join(" ").toLowerCase();
      let s = 0;
      for (const tk of tokens) {
        const re = new RegExp(tk.replace(/[.*+?^${}()|[\]\\]/g, "\\$&"), "g");
        const m = hay.match(re); if (m) s += m.length;
      }
      return s;
    }
    function esc(s) {
      return (s || "").replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
    }
    function prettyDate(iso) { return iso || ""; }

    // ---- facets (topic) ----
    async function paintFacets() {
      if (!pagefind || !pagefind.filters) { facetsEl.hidden = true; return; }
      let filters;
      try { filters = await pagefind.filters(); } catch { facetsEl.hidden = true; return; }
      const topics = filters && filters.topic ? Object.keys(filters.topic) : [];
      if (!topics.length) { facetsEl.hidden = true; return; }
      facetsEl.hidden = false;
      facetsEl.innerHTML = "";
      for (const tp of topics.sort()) {
        const b = document.createElement("button");
        b.type = "button";
        b.className = "facet-chip";
        b.textContent = tp;
        b.setAttribute("aria-pressed", topicFilter === tp ? "true" : "false");
        b.addEventListener("click", () => {
          topicFilter = topicFilter === tp ? null : tp;
          runQuery(input.value.trim());
        });
        facetsEl.appendChild(b);
      }
    }

    // ---- render ----
    function rowHtml(h) {
      const sub = (h.subs && h.subs.length)
        ? `<p class="search-row-sub"><span class="arrow">›</span> ${esc(strings.matchesIn)}: ${h.subs.slice(0, 3).map(esc).join(" · ")}</p>`
        : "";
      const ex = h.excerpt ? `<p class="search-row-excerpt">${h.excerpt}</p>` : "";
      return `<div class="search-row-head"><span>${esc(h.title)}</span>` +
        `<span class="search-row-date num">· ${esc(prettyDate(h.date))}</span></div>${ex}${sub}`;
    }
    function render(hits, total) {
      lastResults = hits;
      activeIdx = -1;
      resultsEl.innerHTML = "";
      if (!hits.length) {
        showBlank(false);
        resultsEl.innerHTML = `<p class="search-row" style="cursor:default;color:var(--faint-ink)">${esc(strings.empty)}</p>`;
        countEl.textContent = "";
        return;
      }
      showBlank(false);
      const frag = document.createDocumentFragment();
      hits.forEach((h, i) => {
        const a = document.createElement("a");
        a.className = "search-row";
        a.href = h.url;
        a.setAttribute("role", "option");
        a.dataset.idx = String(i);
        a.innerHTML = rowHtml(h);
        a.addEventListener("mouseenter", () => setActive(i));
        frag.appendChild(a);
      });
      resultsEl.appendChild(frag);
      const n = total ?? hits.length;
      const unit = n === 1 ? strings.results.one : strings.results.many;
      countEl.textContent = `${n} ${unit}`.trim();
    }
    function setActive(i) {
      const rows = resultsEl.querySelectorAll(".search-row[href]");
      if (!rows.length) return;
      activeIdx = (i + rows.length) % rows.length;
      rows.forEach((r, j) => r.classList.toggle("is-active", j === activeIdx));
      rows[activeIdx].scrollIntoView({ block: "nearest" });
    }

    // ---- query ----
    async function runQuery(q) {
      await loadSearch();
      const hasQ = q && tokenize(q).length;
      if (!hasQ && !topicFilter) { showBlank(true); return; }

      if (pfSearch) {
        try {
          const filters = topicFilter ? { topic: topicFilter } : null;
          const { total, items } = await pfSearch(q, filters);
          const hits = items.map((d) => ({
            url: d.url,
            title: (d.meta && d.meta.title) || d.url,
            date: (d.meta && d.meta.date) || "",
            excerpt: d.excerpt,
            subs: (d.sub_results || []).map((s) => s.title).filter(Boolean),
          }));
          render(hits, total);
          await paintFacets();
        } catch { render([]); }
      } else {
        const tokens = tokenize(q);
        const scored = (fallbackDocs || [])
          .map((d) => [scoreDoc(d, tokens), d])
          .filter(([s]) => s > 0)
          .sort((a, b) => b[0] - a[0] || (b[1].date || "").localeCompare(a[1].date || ""))
          .slice(0, 8)
          .map(([, d]) => ({
            url: base + (d.url || ""),
            title: prettyTopicLocal(d.topic) || d.title,
            date: d.date,
            excerpt: esc((d.tldr && d.tldr[0]) || ""),
            subs: (d.signals || []).slice(0, 2),
          }));
        render(scored, scored.length);
        facetsEl.hidden = true;
      }
    }
    function prettyTopicLocal(slug) {
      return (slug || "").split("-").map((w) => w.charAt(0).toUpperCase() + w.slice(1)).join(" ");
    }

    // ---- input wiring ----
    let debId = 0;
    input.addEventListener("input", () => {
      clearTimeout(debId);
      const q = input.value.trim();
      debId = setTimeout(() => runQuery(q), 200);
    });

    // ---- keyboard ----
    document.addEventListener("keydown", (e) => {
      const tag = (e.target && e.target.tagName) || "";
      const typing = /^(INPUT|TEXTAREA|SELECT)$/.test(tag) || (e.target && e.target.isContentEditable);
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "k") { e.preventDefault(); scrim.hidden ? open() : close(); return; }
      if (e.key === "/" && !typing && scrim.hidden) { e.preventDefault(); open(); return; }
      if (scrim.hidden) return;
      if (e.key === "Escape") { e.preventDefault(); close(); }
      else if (e.key === "ArrowDown") { e.preventDefault(); setActive(activeIdx + 1); }
      else if (e.key === "ArrowUp") { e.preventDefault(); setActive(activeIdx - 1); }
      else if (e.key === "Enter") {
        const rows = resultsEl.querySelectorAll(".search-row[href]");
        if (activeIdx >= 0 && rows[activeIdx]) { pushRecent(input.value); window.location.href = rows[activeIdx].getAttribute("href"); }
        else if (rows[0]) { pushRecent(input.value); window.location.href = rows[0].getAttribute("href"); }
      }
    });

    // record recent on result click + close on backdrop / chip nav
    resultsEl.addEventListener("click", (e) => {
      if (e.target.closest(".search-row[href]")) pushRecent(input.value);
    });
    scrim.addEventListener("click", (e) => { if (e.target === scrim) close(); });

    // open triggers (masthead button + anything with [data-search-open])
    for (const btn of document.querySelectorAll("[data-search-open]")) {
      btn.addEventListener("click", (e) => { e.preventDefault(); open(); });
    }
  })();
</script>
