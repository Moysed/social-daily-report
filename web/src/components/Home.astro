---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import { prettyDate, prettyTopic, sentimentEmoji } from "../lib/format";
import { homePath, UI, type Lang } from "../lib/i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = UI[lang];
const other: Lang = lang === "en" ? "th" : "en";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const local = (path: string) => `${base}${path}`;

const all = await getCollection("reports");

type Entry = (typeof all)[number];
type Pair = { en?: Entry; th?: Entry };

const byDate = new Map<string, Map<string, Pair>>();
for (const entry of all) {
  const day = byDate.get(entry.data.date) ?? new Map<string, Pair>();
  const pair = day.get(entry.data.topic) ?? {};
  pair[entry.data.lang] = entry;
  day.set(entry.data.topic, pair);
  byDate.set(entry.data.date, day);
}

const href = (entry: Entry) => local(`/report/${entry.data.date}/${entry.data.topic}/${entry.data.lang}`);
const pct = (value?: number | null) => (value == null ? null : Math.round(value * 100));
const entryFor = (pair: Pair) => pair[lang] ?? pair[other];

// Pull the first TL;DR bullet (or first paragraph) from a report body. Strips
// inline `[refs]`, link/code syntax so the deck reads as prose.
function leadDeck(body: string | undefined): string | null {
  if (!body) return null;
  const lines = body.split(/\r?\n/);
  let inTldr = false;
  for (const raw of lines) {
    const line = raw.trim();
    if (/^##\s+(TL;DR|TL;?DR|สรุป)/i.test(line)) { inTldr = true; continue; }
    if (inTldr && /^##\s/.test(line)) break;
    if (inTldr && /^[-*]\s+/.test(line)) {
      return cleanInline(line.replace(/^[-*]\s+/, ""));
    }
  }
  for (const raw of lines) {
    const line = raw.trim();
    if (!line || line.startsWith("#") || line.startsWith("|") || /^[-*]\s/.test(line)) continue;
    return cleanInline(line);
  }
  return null;
}

function cleanInline(s: string): string {
  return s
    .replace(/\[(\d+(?:,\s*\d+)*)\]/g, "")
    .replace(/!?\[([^\]]+)\]\([^)]+\)/g, "$1")
    .replace(/`([^`]+)`/g, "$1")
    .replace(/\s{2,}/g, " ")
    .trim();
}

const dates = [...byDate.keys()].sort().reverse();
const latest = dates[0];
const rowsForDate = (date: string) =>
  [...byDate.get(date)!.entries()]
      .map(([topic, pair]) => ({ topic, pair, entry: entryFor(pair)! }))
      .sort((a, b) => (b.entry.data.salience ?? 0) - (a.entry.data.salience ?? 0));
const latestPairs = latest ? rowsForDate(latest) : [];
const lead = latestPairs[0];
const others = latestPairs.slice(1);
const archiveDates = dates.slice(1);
const archiveGroups = archiveDates.map((date) => ({ date, rows: rowsForDate(date) }));

// ---- Calendar archive ----
// Group every date that has a report by its YYYY-MM month so we can render a
// per-month grid. We include `latest` so the calendar reads as one continuous
// timeline; clicking the latest cell just scrolls to the brief at the top.
type MonthCell = { date: string | null; count: number; isLatest: boolean; isFuture: boolean };
type Month = { key: string; label: string; weeks: MonthCell[][] };

const datesWithReports = new Set(dates);
const countsByDate = new Map<string, number>(dates.map((d) => [d, byDate.get(d)!.size]));

const monthSet = new Set<string>(dates.map((d) => d.slice(0, 7)));
const monthKeys = [...monthSet].sort().reverse();

const monthFormatter = new Intl.DateTimeFormat(lang === "th" ? "th-TH" : "en-US", {
  year: "numeric",
  month: "long",
});
const weekdayLabels: string[] =
  lang === "th"
    ? ["อา", "จ", "อ", "พ", "พฤ", "ศ", "ส"]
    : ["S", "M", "T", "W", "T", "F", "S"];

const today = new Date();
const todayStr = `${today.getUTCFullYear()}-${String(today.getUTCMonth() + 1).padStart(2, "0")}-${String(today.getUTCDate()).padStart(2, "0")}`;

const months: Month[] = monthKeys.map((key) => {
  const [y, m] = key.split("-").map(Number);
  const first = new Date(Date.UTC(y, m - 1, 1));
  const daysInMonth = new Date(Date.UTC(y, m, 0)).getUTCDate();
  const startDay = first.getUTCDay();
  const cells: MonthCell[] = [];
  for (let i = 0; i < startDay; i++) cells.push({ date: null, count: 0, isLatest: false, isFuture: false });
  for (let d = 1; d <= daysInMonth; d++) {
    const dStr = `${y}-${String(m).padStart(2, "0")}-${String(d).padStart(2, "0")}`;
    cells.push({
      date: dStr,
      count: countsByDate.get(dStr) ?? 0,
      isLatest: dStr === latest,
      isFuture: dStr > todayStr,
    });
  }
  while (cells.length % 7 !== 0) cells.push({ date: null, count: 0, isLatest: false, isFuture: false });
  const weeks: MonthCell[][] = [];
  for (let i = 0; i < cells.length; i += 7) weeks.push(cells.slice(i, i + 7));
  return {
    key,
    label: monthFormatter.format(first),
    weeks,
  };
});

// Maximum daily report count across the archive — used to scale heatmap shades.
const maxDayCount = Math.max(1, ...countsByDate.values());

// Day-detail panels: one for every archive date. Default hidden; JS unhides
// whichever the user picked in the calendar.
const archivePanels = archiveDates.map((date) => ({ date, rows: rowsForDate(date) }));

const allTopics: string[] = [];
{
  const seen = new Set<string>();
  for (const date of dates) {
    for (const topic of byDate.get(date)!.keys()) {
      if (!seen.has(topic)) { seen.add(topic); allTopics.push(topic); }
    }
  }
}

function haystackFor(topic: string, entry: Entry): string {
  const d = entry.data;
  return [
    prettyTopic(topic),
    topic,
    ...(d.platforms ?? []),
    ...(d.tags ?? []),
    leadDeck(entry.body) ?? "",
  ].join(" ").toLowerCase();
}

// Activity bucket from salience (0..1). Friendly labels replace "salience %".
type Activity = "high" | "medium" | "low";
function activityOf(salience: number | null | undefined): Activity {
  if (salience == null) return "low";
  if (salience >= 0.65) return "high";
  if (salience >= 0.40) return "medium";
  return "low";
}
function activityLabel(a: Activity): string {
  return a === "high" ? t.activityHigh : a === "medium" ? t.activityMedium : t.activityLow;
}

// Trend vs the previous run of the same topic (older date). Returns the
// direction + a short label. If no prior run exists, returns "new".
type Trend = "rising" | "easing" | "steady" | "new";
function trendOf(topic: string, currentSalience: number | null | undefined): Trend {
  for (const date of dates) {
    if (date === latest) continue;
    const pair = byDate.get(date)?.get(topic);
    const prev = pair && entryFor(pair);
    if (!prev) continue;
    const ps = prev.data.salience;
    if (ps == null || currentSalience == null) return "steady";
    const delta = currentSalience - ps;
    if (delta > 0.10) return "rising";
    if (delta < -0.10) return "easing";
    return "steady";
  }
  return "new";
}
function trendLabel(tr: Trend): string {
  return tr === "rising" ? t.trendRising :
         tr === "easing" ? t.trendEasing :
         tr === "steady" ? t.trendSteady : t.trendNew;
}
function trendGlyph(tr: Trend): string {
  return tr === "rising" ? "↑" : tr === "easing" ? "↓" : tr === "steady" ? "→" : "●";
}
---

<Base title={t.htmlTitle} lang={lang} alternateHref={local(homePath[other])}>
  {dates.length === 0 ? (
    <section class="empty-state">
      <p class="kicker">{t.dailyBrief}</p>
      <h1>{t.noReportsTitle}</h1>
      <p>{t.noReportsBody}</p>
      <code>python -m social_report.cli run</code>
    </section>
  ) : (
    <>
      <section class="brief-masthead" id="top">
        <p class="kicker">{t.morningBrief}</p>
        <div class="brief-line">
          <h1>{t.todayOverview}</h1>
          <p class="brief-meta ui-text">
            <strong>{prettyDate(latest)}</strong>
            <span aria-hidden="true">·</span>
            <span>{t.todayHeading(latestPairs.length)}</span>
          </p>
        </div>
      </section>

      {lead && (() => {
        const d = lead.entry.data;
        const act = activityOf(d.salience);
        const tr = trendOf(lead.topic, d.salience);
        const deck = leadDeck(lead.entry.body);
        return (
          <article class="lead-tile" data-row data-topic={lead.topic} data-date={d.date} data-haystack={haystackFor(lead.topic, lead.entry)}>
            {d.thumbnail && (
              <a class="lead-thumb" href={href(lead.entry)} aria-hidden="true" tabindex="-1">
                <img src={d.thumbnail} alt="" loading="lazy" referrerpolicy="no-referrer" />
              </a>
            )}
            <p class="kicker accent">{t.leadSignal}</p>
            <h2 class="tile-title"><a href={href(lead.entry)}>{prettyTopic(lead.topic)}</a></h2>
            <div class="tile-signals ui-text">
              <span class={`pill activity activity-${act}`} title={`${t.activityLabel}: ${activityLabel(act)}`}>
                <span class="dot" aria-hidden="true"></span>
                {activityLabel(act)}
              </span>
              <span class={`pill trend trend-${tr}`} title={`${t.activityLabel}: ${trendLabel(tr)}`}>
                <span aria-hidden="true">{trendGlyph(tr)}</span>
                {trendLabel(tr)}
              </span>
              <span class="pill sentiment" title={`Sentiment: ${d.sentiment ?? "neutral"}`}>
                <span aria-hidden="true">{sentimentEmoji(d.sentiment)}</span>
                {d.sentiment ?? "neutral"}
              </span>
              <span class="pill quiet">{t.posts(d.post_count)}</span>
            </div>
            {deck && <p class="tile-deck">{deck}</p>}
            <div class="tile-cta ui-text">
              <a class="cta-primary" href={href(lead.entry)}>{t.readReport} →</a>
              <span class="cta-langs">
                {lead.pair.en && <a class={lang === "en" ? "active" : ""} href={href(lead.pair.en)} hreflang="en">EN</a>}
                {lead.pair.th && <a class={lang === "th" ? "active" : ""} href={href(lead.pair.th)} hreflang="th" lang="th">ไทย</a>}
              </span>
            </div>
          </article>
        );
      })()}

      <nav class="controls ui-text" aria-label={t.filterTopic} data-filter-controls>
        <div class="control-row">
          <label class="search-field">
            <span class="visually-hidden">{t.search}</span>
            <svg class="search-icon" viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
              <circle cx="11" cy="11" r="6.2" fill="none" stroke="currentColor" stroke-width="1.6" />
              <line x1="15.6" y1="15.6" x2="20" y2="20" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
            </svg>
            <input
              type="search"
              data-filter-search
              placeholder={t.searchPlaceholder}
              autocomplete="off"
              spellcheck="false"
            />
          </label>
        </div>
        <div class="control-row">
          <button type="button" class="chip active" data-filter-chip data-kind="topic" data-value="">{t.filterAll}</button>
          {allTopics.map((topic) => (
            <button type="button" class="chip" data-filter-chip data-kind="topic" data-value={topic}>{prettyTopic(topic)}</button>
          ))}
        </div>
        <p class="control-empty" data-filter-empty hidden>{t.searchEmpty}</p>
      </nav>

      {others.length > 0 && (
        <section class="tile-grid" aria-label={t.alsoToday}>
          {others.map(({ topic, pair, entry }) => {
            const d = entry.data;
            const act = activityOf(d.salience);
            const tr = trendOf(topic, d.salience);
            const deck = leadDeck(entry.body);
            return (
              <article class="tile" data-row data-topic={topic} data-date={d.date} data-haystack={haystackFor(topic, entry)}>
                {d.thumbnail && (
                  <a class="tile-thumb" href={href(entry)} aria-hidden="true" tabindex="-1">
                    <img src={d.thumbnail} alt="" loading="lazy" referrerpolicy="no-referrer" />
                  </a>
                )}
                <header class="tile-head">
                  <h3 class="tile-title"><a href={href(entry)}>{prettyTopic(topic)}</a></h3>
                  <span class="tile-sentiment" aria-label={d.sentiment ?? "neutral"}>{sentimentEmoji(d.sentiment)}</span>
                </header>
                <div class="tile-signals ui-text">
                  <span class={`pill activity activity-${act}`}>
                    <span class="dot" aria-hidden="true"></span>
                    {activityLabel(act)}
                  </span>
                  <span class={`pill trend trend-${tr}`}>
                    <span aria-hidden="true">{trendGlyph(tr)}</span>
                    {trendLabel(tr)}
                  </span>
                </div>
                {deck && <p class="tile-deck">{deck}</p>}
                {d.tags?.length > 0 && (
                  <p class="tile-tags ui-text">
                    {d.tags.slice(0, 3).map((tag) => <span class="tag">#{tag}</span>)}
                  </p>
                )}
                <div class="tile-cta ui-text">
                  <a class="cta-primary" href={href(entry)}>{t.readReport} →</a>
                  <span class="cta-quiet">{t.posts(d.post_count)}</span>
                  <span class="cta-langs">
                    {pair.en && <a class={lang === "en" ? "active" : ""} href={href(pair.en)} hreflang="en">EN</a>}
                    {pair.th && <a class={lang === "th" ? "active" : ""} href={href(pair.th)} hreflang="th" lang="th">TH</a>}
                  </span>
                </div>
              </article>
            );
          })}
        </section>
      )}

      <aside class="metric-guide ui-text" aria-label={t.metricGuideTitle}>
        <p class="guide-title">{t.metricGuideTitle}</p>
        <p><strong>{t.activityLabel}</strong> — {t.legendSalience[1]}</p>
        <p><strong>{t.evidenceLabel}</strong> — {t.legendConfidence[1]}</p>
      </aside>

      {months.length > 0 && (
        <section class="calendar-archive" aria-label={t.archive} data-max-count={maxDayCount}>
          <header class="calendar-head">
            <h2>{t.archive}</h2>
            <p class="calendar-hint ui-text">
              <span class="legend-swatch" data-intensity="1" aria-hidden="true"></span>
              <span class="legend-swatch" data-intensity="2" aria-hidden="true"></span>
              <span class="legend-swatch" data-intensity="3" aria-hidden="true"></span>
              <span class="legend-swatch" data-intensity="4" aria-hidden="true"></span>
              <span class="ui-text quiet">{lang === "th" ? "ความหนาแน่นรายวัน" : "Daily intensity"}</span>
            </p>
          </header>
          <div class="calendar-months">
            {months.map((month) => (
              <div class="calendar-month">
                <h3 class="calendar-month-label">{month.label}</h3>
                <div class="calendar-grid" role="grid">
                  {weekdayLabels.map((w) => (
                    <span class="calendar-weekday ui-text" aria-hidden="true">{w}</span>
                  ))}
                  {month.weeks.flat().map((cell) => {
                    if (!cell.date) return <span class="calendar-cell empty" aria-hidden="true"></span>;
                    const day = Number(cell.date.slice(8, 10));
                    if (cell.count === 0) {
                      return (
                        <span
                          class={`calendar-cell off${cell.isFuture ? " future" : ""}`}
                          aria-label={`${cell.date} — ${lang === "th" ? "ไม่มีรายงาน" : "no report"}`}
                        >
                          <span class="day-num num">{day}</span>
                        </span>
                      );
                    }
                    const ratio = cell.count / maxDayCount;
                    const intensity = ratio >= 0.85 ? 4 : ratio >= 0.6 ? 3 : ratio >= 0.35 ? 2 : 1;
                    if (cell.isLatest) {
                      return (
                        <a
                          class={`calendar-cell on latest`}
                          data-intensity={intensity}
                          href="#top"
                          aria-label={`${cell.date} — ${lang === "th" ? "บรีฟวันนี้" : "today's brief"}`}
                          title={`${cell.count} ${lang === "th" ? "หัวข้อ" : "topics"}`}
                        >
                          <span class="day-num num">{day}</span>
                          <span class="day-count num">{cell.count}</span>
                        </a>
                      );
                    }
                    return (
                      <button
                        type="button"
                        class={`calendar-cell on`}
                        data-intensity={intensity}
                        data-cal-day={cell.date}
                        aria-label={`${cell.date} — ${cell.count} ${lang === "th" ? "หัวข้อ" : "topics"}`}
                        title={`${cell.count} ${lang === "th" ? "หัวข้อ" : "topics"}`}
                      >
                        <span class="day-num num">{day}</span>
                        <span class="day-count num">{cell.count}</span>
                      </button>
                    );
                  })}
                </div>
              </div>
            ))}
          </div>
          {archivePanels.length > 0 && (
            <div class="day-detail-host" data-day-detail-host>
              <p class="day-detail-empty ui-text quiet" data-day-detail-empty>
                {lang === "th" ? "เลือกวันในปฏิทินด้านบนเพื่อดูรายงานของวันนั้น" : "Pick a day above to see its reports."}
              </p>
              {archivePanels.map(({ date, rows }) => (
                <section class="archive-day" id={`day-${date}`} data-day-detail={date} hidden>
                  <header class="archive-day-head">
                    <h3>{prettyDate(date)}</h3>
                    <span class="ui-text quiet">{t.topics(rows.length)}</span>
                  </header>
                  <ul class="archive-list">
                    {rows.map(({ topic, pair, entry }) => {
                      const d = entry.data;
                      const act = activityOf(d.salience);
                      return (
                        <li class="archive-row" data-row data-topic={topic} data-date={d.date} data-haystack={haystackFor(topic, entry)}>
                          <a class="archive-link" href={href(entry)}>
                            <span class="archive-topic">{prettyTopic(topic)}</span>
                            <span class={`pill activity activity-${act} ui-text`}>
                              <span class="dot" aria-hidden="true"></span>
                              {activityLabel(act)}
                            </span>
                            <span class="ui-text quiet">{t.posts(d.post_count)}</span>
                          </a>
                          <span class="archive-langs ui-text">
                            {pair.en && <a href={href(pair.en)} hreflang="en">EN</a>}
                            {pair.th && <a href={href(pair.th)} hreflang="th" lang="th">TH</a>}
                          </span>
                        </li>
                      );
                    })}
                  </ul>
                </section>
              ))}
            </div>
          )}
        </section>
      )}
    </>
  )}

  <style>
    /* ---- Layout primitives ---- */
    .brief-masthead,
    .lead-tile,
    .controls,
    .tile-grid,
    .metric-guide,
    .archive-disclosure,
    .empty-state {
      max-width: 68rem;
      margin-inline: auto;
    }

    /* ---- Brief masthead (replaces dual-column header) ---- */
    .brief-masthead {
      margin-bottom: var(--space-md);
    }
    .brief-line {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: var(--space-sm) var(--space-md);
      padding-bottom: var(--space-sm);
      border-bottom: 1px solid var(--line);
    }
    .brief-masthead h1 {
      margin: 0;
      max-width: 22ch;
      font-family: var(--font-display);
      font-size: var(--step-3);
      font-weight: 650;
      line-height: 1.04;
    }
    .brief-meta {
      margin: 0;
      color: var(--soft-ink);
      font-size: var(--step--1);
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      flex-wrap: wrap;
    }
    .brief-meta strong { color: var(--ink); font-weight: 700; }

    /* ---- Lead tile: asymmetric editorial composition ---- */
    .lead-tile {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.65rem;
      padding: var(--space-md) 0 var(--space-lg);
      margin-bottom: var(--space-lg);
      border-top: 1px solid var(--ink);
      border-bottom: 1px solid var(--hairline);
      background: transparent;
      animation: tile-in 480ms cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    .lead-tile .lead-thumb {
      aspect-ratio: 16 / 9;
      margin-bottom: var(--space-sm);
      border-bottom: 1px solid var(--hairline);
    }
    .lead-tile .tile-title {
      margin: 0;
      font-family: var(--font-display);
      font-size: var(--step-3);
      font-weight: 650;
      line-height: 1.02;
      letter-spacing: -0.005em;
      max-width: 18ch;
    }
    .lead-tile .tile-deck {
      margin: 0.4rem 0 0;
      font-size: var(--step-1);
      line-height: 1.5;
      color: var(--soft-ink);
      max-width: 56ch;
      font-family: var(--font-body);
    }
    .lead-tile .tile-signals { margin: 0.25rem 0 0; }
    .lead-tile .tile-cta { margin-top: 0.5rem; padding-top: 0.65rem; }
    .kicker.accent { color: var(--accent-ink); }

    /* Two-column layout once there's horizontal room: image left, prose right. */
    @media (min-width: 56rem) {
      .lead-tile {
        grid-template-columns: minmax(0, 6fr) minmax(0, 7fr);
        column-gap: var(--space-lg);
        align-items: start;
      }
      .lead-tile .lead-thumb {
        grid-column: 1;
        grid-row: 1 / span 6;
        margin-bottom: 0;
        border-bottom: 0;
        aspect-ratio: 5 / 6;
        position: sticky;
        top: var(--space-md);
      }
      .lead-tile > *:not(.lead-thumb) {
        grid-column: 2;
      }
    }

    /* ---- Filter chip bar ---- */
    .controls {
      margin-bottom: var(--space-md);
      display: flex;
      flex-direction: column;
      gap: 0.55rem;
      align-items: stretch;
      padding-bottom: var(--space-sm);
      border-bottom: 1px solid var(--hairline);
    }
    .controls .control-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem 0.4rem;
      align-items: center;
    }

    /* ---- Search box ---- */
    .search-field {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      flex: 1 1 16rem;
      max-width: 28rem;
      padding: 0.35rem 0.65rem;
      border: 1px solid var(--line);
      background: color-mix(in oklch, var(--paper), transparent 12%);
      color: var(--soft-ink);
      transition: border-color 0.15s ease, color 0.15s ease;
    }
    .search-field:focus-within {
      border-color: var(--accent);
      color: var(--accent-ink);
    }
    .search-icon { color: currentColor; flex: 0 0 auto; }
    .search-field input {
      appearance: none;
      background: transparent;
      border: 0;
      outline: 0;
      width: 100%;
      font-family: var(--font-ui);
      font-size: var(--step--1);
      color: var(--ink);
      min-height: 24px;
    }
    .search-field input::placeholder { color: var(--faint-ink); }
    .visually-hidden {
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip: rect(0 0 0 0);
      white-space: nowrap;
    }
    .chip {
      appearance: none;
      background: transparent;
      color: var(--soft-ink);
      font-family: var(--font-ui);
      font-size: var(--step--1);
      font-weight: 600;
      border: 1px solid var(--line);
      padding: 0.32rem 0.75rem;
      min-height: 30px;
      cursor: pointer;
      line-height: 1.2;
      transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
    }
    .chip:hover { color: var(--accent-ink); border-color: var(--accent); }
    .chip.active {
      color: var(--bg);
      background: var(--accent);
      border-color: var(--accent);
    }
    .control-empty {
      flex-basis: 100%;
      margin: 0.35rem 0 0;
      color: var(--soft-ink);
      font-style: italic;
      font-size: var(--step--1);
    }

    /* ---- Tile grid (other topics) ---- */
    .tile-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(19rem, 1fr));
      gap: var(--space-lg) var(--space-md);
      margin-bottom: var(--space-lg);
    }
    .tile {
      display: grid;
      gap: 0.45rem;
      padding: 0;
      border: 0;
      background: transparent;
      animation: tile-in 500ms cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    /* Tile head sits below thumbnail; baseline-aligned title + sentiment glyph. */
    .tile-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 0.5rem;
      padding-top: 0.15rem;
    }
    .tile-title {
      margin: 0;
      font-family: var(--font-display);
      font-size: var(--step-1);
      font-weight: 650;
      line-height: 1.14;
      letter-spacing: -0.003em;
    }
    .tile-title a:hover { color: var(--accent-ink); }
    .tile-title a { text-decoration: none; }
    .tile-sentiment {
      font-size: 1.1rem;
      line-height: 1;
    }
    .tile-deck {
      margin: 0;
      color: var(--soft-ink);
      font-family: var(--font-body);
      font-size: var(--step-0);
      line-height: 1.55;
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 3;
      overflow: hidden;
    }
    .tile-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.3rem 0.5rem;
      margin: 0;
    }
    .tag {
      color: var(--soft-ink);
      font-size: 0.78rem;
      letter-spacing: 0.02em;
    }
    .tile-signals {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem 0.5rem;
      margin: 0;
    }
    .tile-cta {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.4rem 0.9rem;
      margin-top: 0.35rem;
      padding-top: 0.55rem;
      border-top: 1px solid var(--hairline);
      font-size: var(--step--1);
      font-family: var(--font-ui);
    }
    .cta-primary {
      font-weight: 700;
      color: var(--accent-ink);
      text-decoration: none;
      border-bottom: 1px solid color-mix(in oklch, var(--accent), transparent 50%);
    }
    .cta-primary:hover { border-color: var(--accent); }
    .cta-quiet { color: var(--soft-ink); }
    .cta-langs { margin-left: auto; display: inline-flex; gap: 0.3rem; }
    .cta-langs a {
      min-width: 2.2rem;
      min-height: 28px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      font-weight: 700;
      border-bottom: 1px solid var(--line);
      color: var(--soft-ink);
    }
    .cta-langs a.active { color: var(--accent-ink); border-color: var(--accent); }

    /* ---- Topic thumbnails ---- */
    .lead-thumb,
    .tile-thumb {
      display: block;
      overflow: hidden;
      background: var(--surface);
    }
    .lead-thumb img,
    .tile-thumb img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.55s cubic-bezier(0.16, 1, 0.3, 1), filter 0.3s ease;
      filter: saturate(0.92);
    }
    .lead-thumb:hover img,
    .tile-thumb:hover img {
      transform: scale(1.025);
      filter: saturate(1);
    }
    /* Tile thumbnail = framed photograph that anchors the card without
       swallowing it. 5:3 keeps the eye moving toward the headline below. */
    .tile-thumb {
      aspect-ratio: 5 / 3;
      margin: 0 0 var(--space-xs);
      border: 1px solid var(--hairline);
    }

    /* ---- Activity / trend / sentiment pills ----
       Protocol-tag look: mono lowercase label, sharp corners, hairline border.
       No rounded chips. */
    .pill {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.2rem 0.5rem;
      font-family: var(--font-mono);
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.02em;
      text-transform: lowercase;
      border: 1px solid var(--hairline);
      color: var(--soft-ink);
      line-height: 1.4;
    }
    .pill .dot {
      width: 0.42rem;
      height: 0.42rem;
      background: currentColor;
      opacity: 0.9;
    }
    .pill.activity-high { color: var(--accent-ink); border-color: color-mix(in oklch, var(--accent), transparent 55%); }
    .pill.activity-medium { color: var(--ink); }
    .pill.activity-low { color: var(--faint-ink); }
    .pill.trend-rising { color: var(--accent-ink); }
    .pill.trend-easing { color: var(--faint-ink); }
    .pill.trend-steady { color: var(--soft-ink); }
    .pill.trend-new { color: var(--accent-ink); border-color: color-mix(in oklch, var(--accent), transparent 50%); }
    .pill.sentiment, .pill.quiet { color: var(--soft-ink); }

    /* ---- Metric guide (now teaches Activity + Evidence) ---- */
    .metric-guide {
      margin-top: var(--space-lg);
      padding-top: var(--space-md);
      border-top: 1px solid var(--line);
      color: var(--soft-ink);
      font-size: var(--step--1);
      line-height: 1.6;
      column-width: 20rem;
      column-gap: var(--space-lg);
    }
    .metric-guide p {
      margin: 0 0 0.4rem;
      break-inside: avoid;
    }
    .guide-title {
      color: var(--ink);
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    /* ---- Calendar archive ---- */
    .calendar-archive {
      margin: var(--space-xl) auto 0;
      max-width: 68rem;
      border-top: 1px solid var(--line);
      padding-top: var(--space-md);
    }
    .calendar-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: var(--space-sm);
      flex-wrap: wrap;
      padding-bottom: var(--space-sm);
      border-bottom: 1px solid var(--hairline);
    }
    .calendar-head h2 {
      margin: 0;
      font-family: var(--font-display);
      font-size: var(--step-2);
      font-weight: 650;
      letter-spacing: -0.005em;
    }
    .calendar-hint {
      display: inline-flex;
      align-items: center;
      gap: 0.32rem;
      color: var(--soft-ink);
      font-size: var(--step--1);
    }
    .legend-swatch {
      width: 0.85rem;
      height: 0.85rem;
      background: color-mix(in oklch, var(--accent), transparent 65%);
      border: 1px solid color-mix(in oklch, var(--accent), transparent 40%);
    }
    .legend-swatch[data-intensity="2"] { background: color-mix(in oklch, var(--accent), transparent 50%); }
    .legend-swatch[data-intensity="3"] { background: color-mix(in oklch, var(--accent), transparent 30%); }
    .legend-swatch[data-intensity="4"] { background: var(--accent); }

    .calendar-months {
      margin-top: var(--space-md);
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(17rem, 1fr));
      gap: var(--space-lg) var(--space-md);
    }
    .calendar-month-label {
      margin: 0 0 0.45rem;
      font-family: var(--font-ui);
      font-size: var(--step--1);
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--soft-ink);
    }
    .calendar-grid {
      display: grid;
      grid-template-columns: repeat(7, minmax(0, 1fr));
      gap: 3px;
    }
    .calendar-weekday {
      font-family: var(--font-mono);
      font-size: 0.62rem;
      font-weight: 500;
      letter-spacing: 0.04em;
      color: var(--faint-ink);
      text-align: center;
      padding: 0.15rem 0;
    }
    .calendar-cell {
      aspect-ratio: 1 / 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.05rem;
      padding: 0.2rem 0.1rem;
      border: 1px solid var(--hairline);
      background: transparent;
      cursor: default;
      text-decoration: none;
      color: var(--soft-ink);
      line-height: 1;
      transition: transform 0.15s ease, border-color 0.15s ease, color 0.15s ease;
    }
    .calendar-cell.empty { border: 0; }
    .calendar-cell.off .day-num { color: var(--faint-ink); }
    .calendar-cell.future { opacity: 0.35; }
    .calendar-cell .day-num {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      font-weight: 500;
    }
    .calendar-cell .day-count {
      font-family: var(--font-mono);
      font-size: 0.62rem;
      color: var(--accent-ink);
    }
    .calendar-cell.on {
      cursor: pointer;
      color: var(--ink);
      background: color-mix(in oklch, var(--accent), transparent 78%);
      border-color: color-mix(in oklch, var(--accent), transparent 55%);
    }
    .calendar-cell.on[data-intensity="2"] {
      background: color-mix(in oklch, var(--accent), transparent 62%);
      border-color: color-mix(in oklch, var(--accent), transparent 40%);
    }
    .calendar-cell.on[data-intensity="3"] {
      background: color-mix(in oklch, var(--accent), transparent 42%);
      border-color: color-mix(in oklch, var(--accent), transparent 25%);
    }
    .calendar-cell.on[data-intensity="4"] {
      background: var(--accent);
      color: var(--bg);
      border-color: var(--accent);
    }
    .calendar-cell.on[data-intensity="4"] .day-count { color: var(--bg); }
    .calendar-cell.on:hover {
      transform: translateY(-1px);
      border-color: var(--accent);
    }
    .calendar-cell.on.selected {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }
    .calendar-cell.on.latest {
      box-shadow: inset 0 0 0 1px var(--accent-ink);
    }

    /* ---- Day-detail panels ---- */
    .day-detail-host {
      margin-top: var(--space-md);
      display: grid;
      gap: var(--space-md);
      scroll-margin-top: var(--space-md);
    }
    .day-detail-empty {
      margin: 0;
      padding: var(--space-sm) 0;
      text-align: center;
      font-style: italic;
    }
    .day-detail-host[data-active="true"] .day-detail-empty { display: none; }
    .archive-day-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 0.6rem;
      padding-bottom: 0.4rem;
      border-bottom: 1px solid var(--hairline);
    }
    .archive-day-head h3 {
      margin: 0;
      font-family: var(--font-display);
      font-size: var(--step-1);
      font-weight: 600;
    }
    .archive-list {
      margin: 0;
      padding: 0;
      list-style: none;
      display: grid;
      gap: 0.05rem;
    }
    .archive-row {
      display: flex;
      align-items: center;
      gap: 0.6rem 1rem;
      padding: 0.45rem 0;
      border-bottom: 1px dashed var(--hairline);
    }
    .archive-link {
      display: inline-flex;
      align-items: center;
      gap: 0.55rem 0.9rem;
      flex-wrap: wrap;
      flex: 1 1 auto;
      text-decoration: none;
      color: inherit;
    }
    .archive-topic {
      font-family: var(--font-display);
      font-size: var(--step-0);
      font-weight: 600;
    }
    .archive-link:hover .archive-topic { color: var(--accent-ink); }
    .archive-langs { display: inline-flex; gap: 0.3rem; }
    .archive-langs a {
      min-width: 2.2rem;
      min-height: 28px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      font-weight: 700;
      color: var(--soft-ink);
      border-bottom: 1px solid var(--line);
    }
    .quiet { color: var(--faint-ink); }

    /* Empty state */
    .empty-state {
      max-width: 42rem;
      padding-top: var(--space-lg);
    }
    .empty-state h1 {
      max-width: none;
      font-size: var(--step-3);
      line-height: 1.04;
      font-family: var(--font-display);
    }
    .empty-state p { color: var(--soft-ink); }

    /* Hide filtered rows + collapsed sections */
    .tile[hidden],
    .lead-tile[hidden],
    .archive-row[hidden] { display: none; }
    .tile-grid[data-empty="true"],
    .archive-day[data-empty="true"] { display: none; }

    @keyframes tile-in {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    @media (max-width: 760px) {
      .brief-line h1 { font-size: var(--step-2); }
      .lead-tile .tile-title { font-size: var(--step-2); }
    }
  </style>

  {/* Filter + search + calendar day picker.
      - Topic chips: single-select, hides non-matching rows.
      - Search box: substring match against data-haystack.
      - Calendar cell click: reveals that day's archive panel, hides others. */}
  <script is:inline>
    (() => {
      const controls = document.querySelector("[data-filter-controls]");
      if (!controls) return;
      const chips = Array.from(controls.querySelectorAll("[data-filter-chip]"));
      const searchInput = controls.querySelector("[data-filter-search]");
      const emptyMsg = controls.querySelector("[data-filter-empty]");

      const rows = Array.from(document.querySelectorAll("[data-row]"));
      const grid = document.querySelector(".tile-grid");

      // Calendar + day-detail wiring (optional — present only when archives exist).
      const calendar = document.querySelector(".calendar-archive");
      const dayHost = document.querySelector("[data-day-detail-host]");
      const dayPanels = Array.from(document.querySelectorAll("[data-day-detail]"));
      const calCells = Array.from(document.querySelectorAll("[data-cal-day]"));

      let activeTopic = "";
      let activeQuery = "";

      function rowMatches(row) {
        if (activeTopic && row.dataset.topic !== activeTopic) return false;
        if (activeQuery && !(row.dataset.haystack || "").includes(activeQuery)) return false;
        return true;
      }

      function apply() {
        let anyVisible = false;
        for (const row of rows) {
          const visible = rowMatches(row);
          row.hidden = !visible;
          if (visible) anyVisible = true;
        }
        if (grid) {
          const visibleTiles = grid.querySelectorAll(".tile:not([hidden])").length;
          grid.toggleAttribute("data-empty", visibleTiles === 0);
        }
        for (const panel of dayPanels) {
          const visibleRows = panel.querySelectorAll(".archive-row:not([hidden])").length;
          panel.toggleAttribute("data-empty", visibleRows === 0);
        }
        emptyMsg.hidden = anyVisible;
      }

      for (const chip of chips) {
        chip.addEventListener("click", () => {
          for (const c of chips) c.classList.toggle("active", c === chip);
          activeTopic = chip.dataset.value || "";
          apply();
        });
      }

      if (searchInput) {
        let t;
        searchInput.addEventListener("input", () => {
          clearTimeout(t);
          t = setTimeout(() => {
            activeQuery = (searchInput.value || "").trim().toLowerCase();
            apply();
          }, 60);
        });
        searchInput.addEventListener("keydown", (e) => {
          if (e.key === "Escape") {
            searchInput.value = "";
            activeQuery = "";
            apply();
            searchInput.blur();
          }
        });
      }

      // Calendar interaction
      function showDay(date, opts) {
        const panel = dayPanels.find((p) => p.dataset.dayDetail === date);
        if (!panel) return;
        for (const p of dayPanels) {
          p.hidden = p !== panel;
        }
        for (const c of calCells) {
          c.classList.toggle("selected", c.dataset.calDay === date);
        }
        if (dayHost) dayHost.setAttribute("data-active", "true");
        if (opts && opts.scroll !== false) {
          panel.scrollIntoView({ behavior: "smooth", block: "start" });
        }
      }

      for (const cell of calCells) {
        cell.addEventListener("click", () => {
          const date = cell.dataset.calDay;
          if (date) showDay(date, { scroll: true });
        });
      }

      // Deep-link: #day-YYYY-MM-DD pre-selects that day on load.
      function fromHash() {
        const h = window.location.hash;
        const m = h && h.match(/^#day-(\d{4}-\d{2}-\d{2})$/);
        if (m) showDay(m[1], { scroll: true });
      }
      fromHash();
      window.addEventListener("hashchange", fromHash);
    })();
  </script>
</Base>
