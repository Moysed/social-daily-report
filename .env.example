# Anthropic API key — used for analysis (Opus) + translation (Sonnet).
# WITHOUT it, the pipeline runs in STUB mode: no API calls, placeholder
# analysis, no Thai translation. Good for testing the plumbing end-to-end.
ANTHROPIC_API_KEY=sk-ant-...

# Which LLM backend to use:
#   api -> Anthropic API via ANTHROPIC_API_KEY above (pay-per-token; sanctioned for automation)
#   cli -> shell out to Claude Code (`claude -p`); uses your Pro/Max SUBSCRIPTION when logged in
# Default: api. The cli backend needs Claude Code installed + `claude login` on THIS machine,
# and only works where you're logged in (e.g. local Windows Task Scheduler, not a cloud server).
LLM_BACKEND=api

# Optional model overrides (defaults set in social_report/analyze/client.py)
# OPUS_MODEL=claude-opus-4-7
# SONNET_MODEL=claude-sonnet-4-6
# CLI backend model aliases (only used when LLM_BACKEND=cli)
# CLI_OPUS_MODEL=opus
# CLI_SONNET_MODEL=sonnet
# CLAUDE_BIN=C:\path\to\claude.cmd   # set if `claude` isn't auto-found on PATH
