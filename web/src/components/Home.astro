---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import { prettyDate, prettyTopic, sentimentEmoji } from "../lib/format";
import { homePath, UI, type Lang } from "../lib/i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = UI[lang];
const other: Lang = lang === "en" ? "th" : "en";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const local = (path: string) => `${base}${path}`;

const all = await getCollection("reports");

type Entry = (typeof all)[number];
type Pair = { en?: Entry; th?: Entry };

const byDate = new Map<string, Map<string, Pair>>();
for (const entry of all) {
  const day = byDate.get(entry.data.date) ?? new Map<string, Pair>();
  const pair = day.get(entry.data.topic) ?? {};
  pair[entry.data.lang] = entry;
  day.set(entry.data.topic, pair);
  byDate.set(entry.data.date, day);
}

const href = (entry: Entry) => local(`/report/${entry.data.date}/${entry.data.topic}/${entry.data.lang}`);
const pct = (value?: number | null) => (value == null ? null : Math.round(value * 100));
const entryFor = (pair: Pair) => pair[lang] ?? pair[other];

// Pull the first TL;DR bullet (or first paragraph) from a report body for the
// lead-story deck. Strips inline `[refs]`, link syntax, and bullet marker so
// the masthead reads as prose, not source.
function leadDeck(body: string | undefined): string | null {
  if (!body) return null;
  const lines = body.split(/\r?\n/);
  let inTldr = false;
  for (const raw of lines) {
    const line = raw.trim();
    if (/^##\s+(TL;DR|TL;?DR|สรุป)/i.test(line)) { inTldr = true; continue; }
    if (inTldr && /^##\s/.test(line)) break;
    if (inTldr && /^[-*]\s+/.test(line)) {
      return cleanInline(line.replace(/^[-*]\s+/, ""));
    }
  }
  for (const raw of lines) {
    const line = raw.trim();
    if (!line || line.startsWith("#") || line.startsWith("|") || /^[-*]\s/.test(line)) continue;
    return cleanInline(line);
  }
  return null;
}

function cleanInline(s: string): string {
  return s
    .replace(/\[(\d+(?:,\s*\d+)*)\]/g, "") // [9] [9,15]
    .replace(/!?\[([^\]]+)\]\([^)]+\)/g, "$1") // [text](url) / ![alt](src)
    .replace(/`([^`]+)`/g, "$1")
    .replace(/\s{2,}/g, " ")
    .trim();
}

const dates = [...byDate.keys()].sort().reverse();
const latest = dates[0];
const rowsForDate = (date: string) =>
  [...byDate.get(date)!.entries()]
      .map(([topic, pair]) => ({ topic, pair, entry: entryFor(pair)! }))
      .sort((a, b) => (b.entry.data.salience ?? 0) - (a.entry.data.salience ?? 0));
const latestPairs = latest ? rowsForDate(latest) : [];
const lead = latestPairs[0];
const archiveDates = dates.slice(1);
const archiveGroups = archiveDates.map((date) => ({ date, rows: rowsForDate(date) }));
---

<Base title={t.htmlTitle} lang={lang} alternateHref={local(homePath[other])}>
  {dates.length === 0 ? (
    <section class="empty-state">
      <p class="kicker">{t.dailyBrief}</p>
      <h1>{t.noReportsTitle}</h1>
      <p>{t.noReportsBody}</p>
      <code>python -m social_report.cli run</code>
    </section>
  ) : (
    <>
      <section class="masthead">
        <div>
          <p class="kicker">{t.dailyBrief}</p>
          <h1>Social Daily Report</h1>
        </div>
        <p class="edition ui-text">
          <span>{t.latestRun}</span>
          <strong>{prettyDate(latest)}</strong>
          <span>{t.topics(latestPairs.length)}</span>
        </p>
      </section>

      {lead && (
        <section class="lead-story" aria-labelledby="lead-title">
          <div class="lead-rule ui-text">{t.leadSignal}</div>
          <article>
            <p class="lead-meta ui-text">
              {t.salience(pct(lead.entry.data.salience))} / {t.confidence(pct(lead.entry.data.confidence))}
            </p>
            <h2 id="lead-title">
              <a href={href(lead.entry)}>{prettyTopic(lead.topic)}</a>
            </h2>
            <p>{leadDeck(lead.entry.body) ?? t.leadDeck}</p>
            <div class="lead-actions ui-text">
              <a href={href(lead.entry)}>{t.readReport}</a>
              {lead.pair.en && <a href={href(lead.pair.en)} hreflang="en">EN</a>}
              {lead.pair.th && <a href={href(lead.pair.th)} hreflang="th" lang="th">ไทย</a>}
            </div>
          </article>
        </section>
      )}

      <section class="daily-index" aria-labelledby="topics-title">
        <div class="index-head">
          <p class="kicker">{t.allSignals}</p>
          <h2 id="topics-title">{prettyDate(latest)}</h2>
        </div>
        <ol class="topic-list">
          {latestPairs.map(({ topic, pair, entry }, index) => {
            const data = entry.data;
            const salience = pct(data.salience);
            const confidence = pct(data.confidence);
            return (
              <li class="topic-row" style={`--delay: ${index * 55}ms`}>
                <span class="topic-number ui-text">{String(index + 1).padStart(2, "0")}</span>
                <div class="topic-main">
                  <h3><a href={href(entry)}>{prettyTopic(topic)}</a></h3>
                  <p class="topic-meta ui-text">
                    <span>{sentimentEmoji(data.sentiment)} {data.sentiment ?? "neutral"}</span>
                    <span>{t.posts(data.post_count)}</span>
                    <span>{t.salience(salience)}</span>
                    <span>{t.confidence(confidence)}</span>
                  </p>
                  {data.platforms.length > 0 && (
                    <p class="platforms ui-text">
                      <strong>{t.platforms}</strong>
                      {data.platforms.slice(0, 5).map((platform) => <span>{platform}</span>)}
                    </p>
                  )}
                </div>
                <div class="topic-langs ui-text" aria-label={t.availableLanguages}>
                  {pair.en && <a class={lang === "en" ? "active" : ""} href={href(pair.en)} hreflang="en">EN</a>}
                  {pair.th && <a class={lang === "th" ? "active" : ""} href={href(pair.th)} hreflang="th" lang="th">TH</a>}
                </div>
              </li>
            );
          })}
        </ol>
      </section>

      <aside class="metric-guide ui-text" aria-label={t.metricGuideTitle}>
        <p class="guide-title">{t.metricGuideTitle}</p>
        <p><strong>{t.legendSalience[0]}</strong> {t.legendSalience[1]}</p>
        <p><strong>{t.legendConfidence[0]}</strong> {t.legendConfidence[1]}</p>
      </aside>

      {archiveDates.length > 0 && (
        <section class="archive" aria-labelledby="archive-title">
          <p class="kicker">{t.archive}</p>
          <h2 id="archive-title">{t.archive}</h2>
          <ul class="ui-text">
            {archiveDates.map((date) => <li><a href={`#${date}`}>{prettyDate(date)}</a></li>)}
          </ul>
        </section>
      )}

      {archiveGroups.map(({ date, rows }) => (
        <section class="daily-index archive-day" id={date} aria-labelledby={`archive-${date}`}>
          <div class="index-head">
            <p class="kicker">{t.archive}</p>
            <h2 id={`archive-${date}`}>{prettyDate(date)}</h2>
          </div>
          <ol class="topic-list">
            {rows.map(({ topic, pair, entry }, index) => {
              const data = entry.data;
              return (
                <li class="topic-row">
                  <span class="topic-number ui-text">{String(index + 1).padStart(2, "0")}</span>
                  <div class="topic-main">
                    <h3><a href={href(entry)}>{prettyTopic(topic)}</a></h3>
                    <p class="topic-meta ui-text">
                      <span>{t.posts(data.post_count)}</span>
                      <span>{t.salience(pct(data.salience))}</span>
                      <span>{t.confidence(pct(data.confidence))}</span>
                    </p>
                  </div>
                  <div class="topic-langs ui-text" aria-label={t.availableLanguages}>
                    {pair.en && <a href={href(pair.en)} hreflang="en">EN</a>}
                    {pair.th && <a href={href(pair.th)} hreflang="th" lang="th">TH</a>}
                  </div>
                </li>
              );
            })}
          </ol>
        </section>
      ))}
    </>
  )}

  <style>
    .masthead {
      max-width: 68rem;
      margin: 0 auto var(--space-lg);
      display: grid;
      grid-template-columns: minmax(0, 1fr) max-content;
      gap: var(--space-md);
      align-items: end;
    }

    h1 {
      max-width: 10ch;
      margin: 0;
      font-family: var(--font-display);
      font-size: var(--step-4);
      font-weight: 650;
      letter-spacing: 0;
      line-height: 0.96;
    }

    .edition {
      margin: 0;
      display: grid;
      gap: 0.12rem;
      color: var(--soft-ink);
      font-size: var(--step--1);
      line-height: 1.45;
      text-align: right;
    }

    .edition strong {
      color: var(--ink);
      font-size: var(--step-1);
      font-weight: 700;
    }

    .lead-story {
      max-width: 68rem;
      margin: 0 auto var(--space-xl);
      display: grid;
      grid-template-columns: minmax(6rem, 0.28fr) minmax(0, 1fr);
      gap: var(--space-lg);
      padding-top: var(--space-md);
      border-top: 1px solid var(--line);
    }

    .lead-rule {
      color: var(--accent-ink);
      font-size: var(--step--1);
      font-weight: 800;
      letter-spacing: 0.16em;
      line-height: 1.4;
      text-transform: uppercase;
    }

    .lead-story article {
      max-width: 62ch;
    }

    .lead-meta {
      margin: 0 0 var(--space-xs);
      color: var(--soft-ink);
      font-size: var(--step--1);
      font-weight: 650;
      line-height: 1.45;
    }

    .lead-story h2 {
      margin: 0;
      font-family: var(--font-display);
      font-size: var(--step-3);
      font-weight: 650;
      line-height: 1.05;
    }

    .lead-story h2 a {
      text-decoration: none;
    }

    .lead-story p:not(.lead-meta) {
      margin: var(--space-sm) 0 0;
      color: var(--soft-ink);
      font-size: var(--step-1);
      line-height: 1.55;
    }

    .lead-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem 1rem;
      margin-top: var(--space-md);
      font-size: var(--step--1);
      font-weight: 700;
    }

    .lead-actions a {
      min-height: 44px;
      display: inline-flex;
      align-items: center;
      text-decoration: none;
      border-bottom: 1px solid var(--line);
    }

    .daily-index,
    .metric-guide,
    .archive,
    .empty-state {
      max-width: 68rem;
      margin-inline: auto;
    }

    .index-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: var(--space-md);
      padding-bottom: var(--space-sm);
      border-bottom: 1px solid var(--line);
    }

    .index-head h2 {
      margin: 0;
      font-family: var(--font-display);
      font-size: var(--step-2);
      font-weight: 600;
      line-height: 1.1;
      text-align: right;
    }

    .topic-list {
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .topic-row {
      display: grid;
      grid-template-columns: 3.5rem minmax(0, 1fr) auto;
      gap: var(--space-md);
      padding: var(--space-md) 0;
      border-bottom: 1px solid var(--hairline);
      animation: topic-in 480ms cubic-bezier(0.16, 1, 0.3, 1) both;
      animation-delay: var(--delay);
    }

    .topic-number {
      color: var(--faint-ink);
      font-size: var(--step--1);
      font-weight: 800;
      letter-spacing: 0.12em;
    }

    .topic-main h3 {
      margin: 0;
      font-family: var(--font-display);
      font-size: var(--step-1);
      font-weight: 650;
      line-height: 1.16;
    }

    .topic-main h3 a {
      text-decoration: none;
    }

    .topic-meta,
    .platforms {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem 0.8rem;
      margin: 0.55rem 0 0;
      color: var(--soft-ink);
      font-size: var(--step--1);
      line-height: 1.45;
    }

    .platforms strong {
      color: var(--ink);
      font-weight: 700;
    }

    .topic-langs {
      display: flex;
      gap: 0.35rem;
      align-items: start;
      font-size: var(--step--1);
      font-weight: 800;
    }

    .topic-langs a {
      min-width: 2.6rem;
      min-height: 44px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-bottom: 1px solid var(--line);
      text-decoration: none;
    }

    .topic-langs a.active {
      color: var(--accent-ink);
      border-color: var(--accent);
    }

    .metric-guide {
      margin-top: var(--space-lg);
      padding-top: var(--space-md);
      border-top: 1px solid var(--line);
      color: var(--soft-ink);
      font-size: var(--step--1);
      line-height: 1.6;
      column-width: 20rem;
      column-gap: var(--space-lg);
    }

    .metric-guide p {
      margin: 0 0 0.5rem;
      break-inside: avoid;
    }

    .guide-title {
      color: var(--ink);
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .archive {
      margin-top: var(--space-xl);
      padding-top: var(--space-md);
      border-top: 1px solid var(--line);
    }

    .archive-day {
      margin-top: var(--space-lg);
    }

    .archive-day .topic-row {
      animation: none;
    }

    .archive h2 {
      margin: 0 0 var(--space-sm);
      font-family: var(--font-display);
      font-size: var(--step-2);
      line-height: 1.1;
    }

    .archive ul {
      display: flex;
      flex-wrap: wrap;
      gap: 0.2rem 1rem;
      margin: 0;
      padding: 0;
      list-style: none;
      font-size: var(--step--1);
    }

    .archive a {
      min-height: 44px;
      display: inline-flex;
      align-items: center;
    }

    .empty-state {
      max-width: 42rem;
      padding-top: var(--space-lg);
    }

    .empty-state h1 {
      max-width: none;
      font-size: var(--step-3);
      line-height: 1.04;
    }

    .empty-state p {
      color: var(--soft-ink);
    }

    @keyframes topic-in {
      from {
        opacity: 0;
        transform: translateY(10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (max-width: 760px) {
      .masthead,
      .lead-story {
        grid-template-columns: 1fr;
      }

      h1 {
        max-width: 9ch;
      }

      .edition,
      .index-head h2 {
        text-align: left;
      }

      .topic-row {
        grid-template-columns: 2.6rem minmax(0, 1fr);
      }

      .topic-langs {
        grid-column: 2;
      }
    }

    @media (max-width: 460px) {
      .index-head {
        display: block;
      }

      .topic-row {
        grid-template-columns: 1fr;
        gap: var(--space-xs);
      }

      .topic-langs {
        grid-column: auto;
      }
    }
  </style>
</Base>
