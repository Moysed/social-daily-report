---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import { prettyDate, shortDate, prettyTopic, sentimentEmoji, cleanInline, extractTldr, readingMinutes } from "../lib/format";
import { homePath, UI, type Lang } from "../lib/i18n";
import { bangkokToday, relativeDate } from "../lib/relative-date";
// Build-time thumbnail manifest: original-URL -> local /thumbs path (or false if
// the source 404'd). Populated by `scripts/fetch-thumbs.mjs` (run pre-build).
// Empty {} when the script hasn't run — the site just renders without images.
import thumbsManifest from "../lib/thumbs-manifest.json";
const localThumb = (url: string | undefined | null): string | null => {
  if (!url) return null;
  const v = (thumbsManifest as Record<string, string | false>)[url];
  return typeof v === "string" ? v : null;
};

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = UI[lang];
const other: Lang = lang === "en" ? "th" : "en";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const local = (path: string) => `${base}${path}`;

const all = await getCollection("reports");
const allDigests = await getCollection("digests");
const latestDigest = allDigests
  .sort((a, b) => (a.data.end < b.data.end ? 1 : -1))[0];

type Entry = (typeof all)[number];
type Pair = { en?: Entry; th?: Entry };

const byDate = new Map<string, Map<string, Pair>>();
for (const entry of all) {
  const day = byDate.get(entry.data.date) ?? new Map<string, Pair>();
  const pair = day.get(entry.data.topic) ?? {};
  pair[entry.data.lang] = entry;
  day.set(entry.data.topic, pair);
  byDate.set(entry.data.date, day);
}

const href = (entry: Entry) => local(`/report/${entry.data.date}/${entry.data.topic}/${entry.data.lang}`);
const pct = (value?: number | null) => (value == null ? null : Math.round(value * 100));
const entryFor = (pair: Pair) => pair[lang] ?? pair[other];

// Pull the first TL;DR bullet (or first paragraph) from a report body. Strips
// inline `[refs]`, link/code syntax so the deck reads as prose.
function leadDeck(body: string | undefined): string | null {
  if (!body) return null;
  const lines = body.split(/\r?\n/);
  let inTldr = false;
  for (const raw of lines) {
    const line = raw.trim();
    if (/^##\s+(TL;DR|TL;?DR|สรุป)/i.test(line)) { inTldr = true; continue; }
    if (inTldr && /^##\s/.test(line)) break;
    if (inTldr && /^[-*]\s+/.test(line)) {
      return cleanInline(line.replace(/^[-*]\s+/, ""));
    }
  }
  for (const raw of lines) {
    const line = raw.trim();
    if (!line || line.startsWith("#") || line.startsWith("|") || /^[-*]\s/.test(line)) continue;
    return cleanInline(line);
  }
  return null;
}

const dates = [...byDate.keys()].sort().reverse();
const latest = dates[0];
const rowsForDate = (date: string) =>
  [...byDate.get(date)!.entries()]
      .map(([topic, pair]) => ({ topic, pair, entry: entryFor(pair)! }))
      .sort((a, b) => (b.entry.data.salience ?? 0) - (a.entry.data.salience ?? 0));

const todayStr = bangkokToday();

// Per-day views — every date renders the same hero+grid layout. Only the
// latest is visible by default; clicking a calendar cell swaps which one is
// active. Older days are still in the DOM so deep-links + filters work
// without a network round-trip.
const days = dates.map((date) => {
  const pairs = rowsForDate(date);
  const rel = relativeDate(date, lang, todayStr);
  return {
    date,
    pairs,
    lead: pairs[0],
    others: pairs.slice(1),
    isLatest: date === latest,
    relLabel: rel.label,
    relKind: rel.kind,
  };
});

// ---- Trending this week ----
// 7-day window ending today (Bangkok). Score by peak salience (primary) + days appeared (tiebreaker).
// One entry per topic (using entryFor for current lang to avoid double-counting EN+TH).
const [ty, tm, td] = todayStr.split("-").map(Number);
const wsDate = new Date(Date.UTC(ty, tm - 1, td - 6));
const weekStart = `${wsDate.getUTCFullYear()}-${String(wsDate.getUTCMonth()+1).padStart(2,"0")}-${String(wsDate.getUTCDate()).padStart(2,"0")}`;

type TrendRow = { topic: string; entry: Entry; peakSalience: number; daysAppeared: number };
{
  // block to scope the map
}
const _trendMap = new Map<string, { maxSal: number; count: number; bestEntry: Entry }>();
for (const date of dates) {
  if (date < weekStart || date > todayStr) continue;
  const pairs = byDate.get(date)!;
  for (const [topic, pair] of pairs) {
    const entry = entryFor(pair);
    if (!entry) continue;
    const sal = entry.data.salience ?? 0;
    const ex = _trendMap.get(topic);
    if (!ex) {
      _trendMap.set(topic, { maxSal: sal, count: 1, bestEntry: entry });
    } else {
      ex.count++;
      if (sal > ex.maxSal) { ex.maxSal = sal; ex.bestEntry = entry; }
    }
  }
}
const trendingTopics: TrendRow[] = [..._trendMap.entries()]
  .map(([topic, s]) => ({ topic, entry: s.bestEntry, peakSalience: s.maxSal, daysAppeared: s.count }))
  .sort((a, b) => b.peakSalience - a.peakSalience || b.daysAppeared - a.daysAppeared)
  .slice(0, 6);

// ---- Calendar archive ----
// Group every date that has a report by its YYYY-MM month so we can render a
// per-month grid. We include `latest` so the calendar reads as one continuous
// timeline; clicking the latest cell just scrolls to the brief at the top.
type MonthCell = { date: string | null; count: number; isLatest: boolean; isFuture: boolean };
type Month = { key: string; label: string; weeks: MonthCell[][] };

const datesWithReports = new Set(dates);
const countsByDate = new Map<string, number>(dates.map((d) => [d, byDate.get(d)!.size]));

const monthSet = new Set<string>(dates.map((d) => d.slice(0, 7)));
const monthKeys = [...monthSet].sort().reverse();

const monthFormatter = new Intl.DateTimeFormat(lang === "th" ? "th-TH" : "en-US", {
  year: "numeric",
  month: "long",
});
const weekdayLabels: string[] =
  lang === "th"
    ? ["อา", "จ", "อ", "พ", "พฤ", "ศ", "ส"]
    : ["S", "M", "T", "W", "T", "F", "S"];

const months: Month[] = monthKeys.map((key) => {
  const [y, m] = key.split("-").map(Number);
  const first = new Date(Date.UTC(y, m - 1, 1));
  const daysInMonth = new Date(Date.UTC(y, m, 0)).getUTCDate();
  const startDay = first.getUTCDay();
  const cells: MonthCell[] = [];
  for (let i = 0; i < startDay; i++) cells.push({ date: null, count: 0, isLatest: false, isFuture: false });
  for (let d = 1; d <= daysInMonth; d++) {
    const dStr = `${y}-${String(m).padStart(2, "0")}-${String(d).padStart(2, "0")}`;
    cells.push({
      date: dStr,
      count: countsByDate.get(dStr) ?? 0,
      isLatest: dStr === latest,
      isFuture: dStr > todayStr,
    });
  }
  while (cells.length % 7 !== 0) cells.push({ date: null, count: 0, isLatest: false, isFuture: false });
  const weeks: MonthCell[][] = [];
  for (let i = 0; i < cells.length; i += 7) weeks.push(cells.slice(i, i + 7));
  return {
    key,
    label: monthFormatter.format(first),
    weeks,
  };
});

// Maximum daily report count across the archive — used to scale heatmap shades.
const maxDayCount = Math.max(1, ...countsByDate.values());

const allTopics: string[] = [];
{
  const seen = new Set<string>();
  for (const date of dates) {
    for (const topic of byDate.get(date)!.keys()) {
      if (!seen.has(topic)) { seen.add(topic); allTopics.push(topic); }
    }
  }
}

function haystackFor(topic: string, entry: Entry): string {
  const d = entry.data;
  return [
    prettyTopic(topic),
    topic,
    ...(d.platforms ?? []),
    ...(d.tags ?? []),
    leadDeck(entry.body) ?? "",
  ].join(" ").toLowerCase();
}

// Activity bucket from salience (0..1). Friendly labels replace "salience %".
type Activity = "high" | "medium" | "low";
function activityOf(salience: number | null | undefined): Activity {
  if (salience == null) return "low";
  if (salience >= 0.65) return "high";
  if (salience >= 0.40) return "medium";
  return "low";
}
function activityLabel(a: Activity): string {
  return a === "high" ? t.activityHigh : a === "medium" ? t.activityMedium : t.activityLow;
}

// Trend vs the previous run of the same topic (older date). Returns the
// direction + a short label. If no prior run exists, returns "new".
type Trend = "rising" | "easing" | "steady" | "new";
function trendOf(topic: string, currentSalience: number | null | undefined): Trend {
  for (const date of dates) {
    if (date === latest) continue;
    const pair = byDate.get(date)?.get(topic);
    const prev = pair && entryFor(pair);
    if (!prev) continue;
    const ps = prev.data.salience;
    if (ps == null || currentSalience == null) return "steady";
    const delta = currentSalience - ps;
    if (delta > 0.10) return "rising";
    if (delta < -0.10) return "easing";
    return "steady";
  }
  return "new";
}
function trendLabel(tr: Trend): string {
  return tr === "rising" ? t.trendRising :
         tr === "easing" ? t.trendEasing :
         tr === "steady" ? t.trendSteady : t.trendNew;
}
function trendGlyph(tr: Trend): string {
  return tr === "rising" ? "↑" : tr === "easing" ? "↓" : tr === "steady" ? "→" : "●";
}

// Consecutive-day streak for a topic starting at `date` going backward through
// `dates` (sorted descending). 1 = appeared today only; >=3 unlocks a badge.
function streakAt(date: string, topic: string): number {
  const idx = dates.indexOf(date);
  if (idx < 0) return 0;
  let n = 0;
  for (let i = idx; i < dates.length; i++) {
    if (byDate.get(dates[i])?.get(topic)) n++;
    else break;
  }
  return n;
}

// Salience history for a topic, ending at `date`, oldest-first, up to N points.
// Null where the topic was absent that day so we can draw gaps as breaks.
type SparkPoint = { date: string; salience: number | null };
function sparkAt(date: string, topic: string, n = 14): SparkPoint[] {
  const idx = dates.indexOf(date);
  if (idx < 0) return [];
  const out: SparkPoint[] = [];
  for (let i = idx; i < dates.length && out.length < n; i++) {
    const pair = byDate.get(dates[i])?.get(topic);
    const e = pair && entryFor(pair);
    out.unshift({ date: dates[i], salience: e?.data.salience ?? null });
  }
  return out;
}

// SVG path for the sparkline. Returns "" when fewer than 2 numeric points.
// Bold lead-in helper: split a TL;DR bullet at em-dash / colon for Axios-style bold clause.
function boldLeadIn(s: string): { lead: string; rest: string } {
  const dmIdx = s.indexOf(" — ");
  if (dmIdx > 0) return { lead: s.slice(0, dmIdx + 3), rest: s.slice(dmIdx + 3) };
  const colIdx = s.indexOf(": ");
  if (colIdx > 4 && colIdx < s.length * 0.55) return { lead: s.slice(0, colIdx + 2), rest: s.slice(colIdx + 2) };
  const words = s.split(/\s+/);
  const k = Math.min(5, Math.max(3, Math.floor(words.length * 0.35)));
  return { lead: words.slice(0, k).join(" ") + " ", rest: words.slice(k).join(" ") };
}

function sparkPath(points: SparkPoint[], w = 72, h = 20): string {
  const nums = points.map((p) => p.salience).filter((v): v is number => v != null);
  if (nums.length < 2) return "";
  const pad = 1.5;
  const max = Math.max(...nums, 0.01);
  const n = points.length;
  const x = (i: number) => pad + (i / (n - 1)) * (w - 2 * pad);
  const y = (v: number | null) =>
    v == null ? null : h - pad - (v / max) * (h - 2 * pad);
  let d = "";
  let pen = false;
  for (let i = 0; i < n; i++) {
    const yi = y(points[i].salience);
    if (yi == null) { pen = false; continue; }
    const xi = x(i).toFixed(1);
    const yiStr = yi.toFixed(1);
    d += pen ? ` L${xi},${yiStr}` : `M${xi},${yiStr}`;
    pen = true;
  }
  return d;
}
---

<Base title={t.htmlTitle} lang={lang} alternateHref={local(homePath[other])} image={new URL("/og/default.png", Astro.site).href} ogType="website">
  <div data-pagefind-ignore>
  {dates.length === 0 ? (
    <section class="empty-state">
      <p class="kicker">{t.dailyBrief}</p>
      <h1>{t.noReportsTitle}</h1>
      <p>{t.noReportsBody}</p>
      <code>python -m social_report.cli run</code>
    </section>
  ) : (
    <>
      <div class="day-views" id="top" data-day-views>
        {days.map((day) => (
          <article class="day-view" data-day-view={day.date} aria-hidden={!day.isLatest} hidden={!day.isLatest}>
            {(() => {
              const prevDate = dates[dates.indexOf(day.date) + 1] ?? null;
              const nextDate = dates[dates.indexOf(day.date) - 1] ?? null;
              const totalMin = day.pairs.reduce((s, {entry}) => s + readingMinutes(entry.body ?? "", lang), 0);
              return (
                <div class="brief ui-text">
                  <span class="brief-label">
                    {day.isLatest && <span class="brief-today">{lang === "th" ? "วันนี้" : "Today"}</span>}
                    <span class="num brief-date">{shortDate(day.date)}</span>
                    <span class="brief-sep" aria-hidden="true">·</span>
                    <span><span class="num">{day.pairs.length}</span> {lang === "th" ? "รายงาน" : "reports"}</span>
                    <span class="brief-sep" aria-hidden="true">·</span>
                    <span class="num brief-time">~{totalMin} {lang === "th" ? "นาที" : "min"}</span>
                  </span>
                  <span class="brief-new" data-new-count hidden aria-live="polite"></span>
                  <nav class="brief-nav" aria-label={lang === "th" ? "เปลี่ยนวัน" : "Change day"}>
                    {prevDate
                      ? <a class="brief-daynav num" href={`#${prevDate}`} data-prev-day={prevDate} aria-label={lang === "th" ? `วันก่อนหน้า: ${prevDate}` : `Previous day: ${prevDate}`}>← {shortDate(prevDate)}</a>
                      : <span class="brief-daynav brief-daynav--disabled num" aria-hidden="true">←</span>
                    }
                    {nextDate
                      ? <a class="brief-daynav num" href={`#${nextDate}`} data-next-day={nextDate} aria-label={lang === "th" ? `วันถัดไป: ${nextDate}` : `Next day: ${nextDate}`}>{shortDate(nextDate)} →</a>
                      : <span class="brief-daynav brief-daynav--disabled num" aria-hidden="true">→</span>
                    }
                  </nav>
                </div>
              );
            })()}

            <nav class="controls ui-text" aria-label={t.filterTopic} data-filter-controls>
              <div class="control-row">
                <div class="search-wrap">
                  <label class="search-field">
                    <span class="visually-hidden">{t.search}</span>
                    <svg class="search-icon" viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
                      <circle cx="11" cy="11" r="6.2" fill="none" stroke="currentColor" stroke-width="1.6" />
                      <line x1="15.6" y1="15.6" x2="20" y2="20" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
                    </svg>
                    <input
                      type="search"
                      data-filter-search
                      placeholder={t.searchPlaceholder}
                      autocomplete="off"
                      spellcheck="false"
                    />
                  </label>
                  <div class="report-results" data-report-results hidden>
                    <div class="report-results-list" data-report-list></div>
                    <p class="report-results-empty" data-report-empty hidden>{t.searchEmpty}</p>
                    <div class="report-results-foot" data-report-foot hidden>
                      <span class="report-results-count" data-report-count></span>
                    </div>
                  </div>
                </div>
              </div>
              <div class="control-row">
                <button type="button" class="chip active" data-filter-chip data-kind="topic" data-value="">{t.filterAll}</button>
                {allTopics.map((topic) => (
                  <button type="button" class="chip" data-filter-chip data-kind="topic" data-value={topic}>{prettyTopic(topic)}</button>
                ))}
              </div>
              <p class="control-empty" data-filter-empty hidden>{t.searchEmpty}</p>
            </nav>

            {day.lead && (() => {
              const d = day.lead.entry.data;
              const tr = trendOf(day.lead.topic, d.salience);
              const allBullets = extractTldr(day.lead.entry.body ?? "");
              // Headline = the lead story (first TL;DR bullet), NOT the topic name —
              // so the front page opens with what actually happened today. Dek = the
              // trailing clause; remaining bullets become the supporting points.
              const leadFirst = allBullets.length ? boldLeadIn(allBullets[0]) : null;
              const leadHeadline = leadFirst
                ? leadFirst.lead.replace(/\s*[—:\-]\s*$/, "").trim()
                : prettyTopic(day.lead.topic);
              const leadStand = leadFirst && leadFirst.rest.trim()
                ? leadFirst.rest.trim().charAt(0).toUpperCase() + leadFirst.rest.trim().slice(1)
                : leadDeck(day.lead.entry.body);
              const bullets = allBullets.slice(1, 4);
              const spark = sparkAt(day.date, day.lead.topic);
              const sparkD = sparkPath(spark, 84, 22);
              const minR = readingMinutes(day.lead.entry.body ?? "", lang);
              const saliencePct = pct(d.salience);
              return (
                <div class="frontpage">
                  {/* Lead block */}
                  <article class="lead" data-row data-topic={day.lead.topic} data-date={d.date} data-haystack={haystackFor(day.lead.topic, day.lead.entry)} data-unread="">
                    <span class="unread-dot" aria-label={t.unread}></span>
                    <span class="lead-rank-bg" aria-hidden="true">01</span>

                    <p class="eyebrow accent lead-eyebrow">
                      <span class="lead-kicker-topic">{prettyTopic(day.lead.topic)}</span>
                      <span class="num"> · {t.minRead(minR)}</span>
                      {(tr === "rising") && <span class="lead-trend-up num"> ↑ {trendLabel(tr)}</span>}
                      {(tr === "easing") && <span class="lead-trend num"> ↓ {trendLabel(tr)}</span>}
                    </p>

                    <h1 class="lead-headline">
                      <a href={href(day.lead.entry)}>{leadHeadline}</a>
                    </h1>

                    {leadStand && (
                      <div class="lead-why">
                        <p class="lead-why-label eyebrow accent">{lang === "th" ? "ทำไมถึงสำคัญ" : "Why it matters"}</p>
                        <p class="lead-stand">{leadStand}</p>
                      </div>
                    )}

                    {bullets.length > 0 && (
                      <ul class="tldr-bullets">
                        {bullets.map((b) => {
                          const { lead, rest } = boldLeadIn(b);
                          return <li><b>{lead}</b>{rest}</li>;
                        })}
                      </ul>
                    )}

                    <div class="meta-foot num">
                      {sparkD && (
                        <svg class="spark" width="84" height="22" viewBox="0 0 84 22" role="img" aria-label={t.sparklineLabel}>
                          <path d={sparkD} fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                      )}
                      <span>
                        · {d.post_count} {lang === "th" ? "โพสต์" : "posts"}
                        {saliencePct != null && ` · ${t.interest(saliencePct)}`}
                      </span>
                      <a class="meta-read" href={href(day.lead.entry)}>{t.readReport} →</a>
                      <span class="meta-langs ui-text">
                        {day.lead.pair.en && <a class={lang === "en" ? "active" : ""} href={href(day.lead.pair.en)} hreflang="en">EN</a>}
                        {day.lead.pair.th && <a class={lang === "th" ? "active" : ""} href={href(day.lead.pair.th)} hreflang="th" lang="th">ไทย</a>}
                      </span>
                    </div>
                  </article>

                  {/* Rail */}
                  {day.others.length > 0 && (
                    <div class="rail" aria-label={t.alsoToday}>
                      <p class="eyebrow rail-head">{t.alsoToday}</p>
                      {day.others.map(({ topic, pair, entry }, idx) => {
                        const td = entry.data;
                        const railBullet = extractTldr(entry.body ?? "")[0];
                        const railSplit = railBullet ? boldLeadIn(railBullet) : null;
                        const railHeadline = railSplit
                          ? railSplit.lead.replace(/\s*[—:\-]\s*$/, "").trim()
                          : prettyTopic(topic);
                        const dek = railSplit && railSplit.rest.trim() ? railSplit.rest.trim() : leadDeck(entry.body);
                        const minT = readingMinutes(entry.body ?? "", lang);
                        const salT = pct(td.salience);
                        return (
                          <article
                            class={`teaser${idx === 0 ? " lg" : ""}${localThumb(td.thumbnail) ? " has-media" : ""}`}
                            data-row
                            data-topic={topic}
                            data-date={td.date}
                            data-haystack={haystackFor(topic, entry)}
                            data-unread=""
                          >
                            <span class="unread-dot" aria-label={t.unread}></span>
                            {localThumb(td.thumbnail) && (
                              <a class="t-media" href={href(entry)} tabindex="-1" aria-hidden="true">
                                <img src={localThumb(td.thumbnail)} alt="" loading="lazy" decoding="async" width="160" height="160" />
                              </a>
                            )}
                            <p class="eyebrow t-eyebrow">
                              <span class="t-rank num" aria-hidden="true">{String(idx + 2).padStart(2, "0")}</span>
                              {prettyTopic(topic)}
                              <span class="num"> · {t.minRead(minT)}</span>
                            </p>
                            <h3 class="t-headline"><a href={href(entry)}>{railHeadline}</a></h3>
                            {dek && <p class="t-dek">{dek}</p>}
                            <p class="t-meta num">
                              {td.post_count} {lang === "th" ? "โพสต์" : "posts"}
                              {salT != null && ` · ${t.interest(salT)}`}
                              <a class="t-read" href={href(entry)} tabindex="-1" aria-hidden="true">{t.readReport} →</a>
                            </p>
                          </article>
                        );
                      })}
                    </div>
                  )}
                </div>
              );
            })()}
          </article>
        ))}
      </div>

      {trendingTopics.length >= 2 && (
        <section class="trending" aria-labelledby="trending-title">
          <h2 id="trending-title" class="eyebrow">{t.trendingTitle}</h2>
          <ol class="trend-list">
            {trendingTopics.map(({ topic, entry, peakSalience, daysAppeared }, i) => {
              const act = activityOf(peakSalience);
              const sparkD = sparkPath(sparkAt(latest, topic, 7), 64, 18);
              return (
                <li class="trend-row">
                  <span class="trend-rank num">{i + 1}</span>
                  <a class="trend-topic" href={href(entry)}>{prettyTopic(topic)}</a>
                  {sparkD && (
                    <svg class="spark" width="64" height="18" viewBox="0 0 64 18" aria-hidden="true">
                      <path d={sparkD} fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  )}
                  <span class={`pill${act === "high" ? " high" : " med"}`}>{activityLabel(act)}</span>
                  <span class="trend-days num">{t.trendingDays(daysAppeared)}</span>
                </li>
              );
            })}
          </ol>
        </section>
      )}

      <aside class="metric-guide ui-text" aria-label={t.metricGuideTitle}>
        <p class="guide-title">{t.metricGuideTitle}</p>
        <p><strong>{t.activityLabel}</strong> — {t.legendSalience[1]}</p>
        <p><strong>{t.evidenceLabel}</strong> — {t.legendConfidence[1]}</p>
      </aside>


      {latestDigest && (
        <section class="digest-callout ui-text" aria-label="Weekly digest">
          <p class="digest-callout-kicker">Weekly digest</p>
          <div class="digest-callout-body">
            <h2>
              <a href={local(`/digest/${latestDigest.data.week}`)}>{latestDigest.data.week}</a>
            </h2>
            <p class="digest-callout-meta">
              {latestDigest.data.start} → {latestDigest.data.end} · {latestDigest.data.topic_count} topics
            </p>
          </div>
          <a class="digest-callout-cta" href={local(`/digest/${latestDigest.data.week}`)}>Read the digest →</a>
        </section>
      )}

      <section class="subscribe-block ui-text" aria-label={t.subscribeTitle}>
        <header class="subscribe-head">
          <h2>{t.subscribeTitle}</h2>
          <a class="footer-rss" href={local(`${lang === "th" ? "/th" : ""}/rss.xml`)} hreflang={lang}>{t.subscribeAllFeed} · RSS</a>
        </header>
        <p class="subscribe-quiet">{t.subscribePerTopic}</p>
        <ul class="subscribe-list">
          {allTopics.map((topic) => (
            <li>
              <a class="num" href={local(`${lang === "th" ? "/th" : ""}/rss/${topic}.xml`)}>
                <span class="subscribe-topic">{prettyTopic(topic)}</span>
                <span class="subscribe-rss">RSS</span>
              </a>
            </li>
          ))}
        </ul>
      </section>

      {months.length > 0 && (
        <section class="calendar-archive" aria-label={t.archive} data-max-count={maxDayCount}>
          <header class="calendar-head">
            <h2>{t.archive}</h2>
            <p class="calendar-hint ui-text">
              <span class="legend-swatch" data-intensity="1" aria-hidden="true"></span>
              <span class="legend-swatch" data-intensity="2" aria-hidden="true"></span>
              <span class="legend-swatch" data-intensity="3" aria-hidden="true"></span>
              <span class="legend-swatch" data-intensity="4" aria-hidden="true"></span>
              <span class="ui-text quiet">{lang === "th" ? "ความหนาแน่นรายวัน" : "Daily intensity"}</span>
            </p>
          </header>
          <div class="calendar-months">
            {months.map((month) => (
              <div class="calendar-month">
                <h3 class="calendar-month-label">{month.label}</h3>
                <div class="calendar-grid" role="grid">
                  {weekdayLabels.map((w) => (
                    <span class="calendar-weekday ui-text" aria-hidden="true">{w}</span>
                  ))}
                  {month.weeks.flat().map((cell) => {
                    if (!cell.date) return <span class="calendar-cell empty" aria-hidden="true"></span>;
                    const day = Number(cell.date.slice(8, 10));
                    if (cell.count === 0) {
                      return (
                        <span
                          class={`calendar-cell off${cell.isFuture ? " future" : ""}`}
                          aria-label={`${cell.date} — ${lang === "th" ? "ไม่มีรายงาน" : "no report"}`}
                        >
                          <span class="day-num num">{day}</span>
                        </span>
                      );
                    }
                    const ratio = cell.count / maxDayCount;
                    const intensity = ratio >= 0.85 ? 4 : ratio >= 0.6 ? 3 : ratio >= 0.35 ? 2 : 1;
                    return (
                      <button
                        type="button"
                        class={`calendar-cell on${cell.isLatest ? " latest" : ""}${cell.isLatest ? " selected" : ""}`}
                        data-intensity={intensity}
                        data-cal-day={cell.date}
                        aria-current={cell.isLatest ? "date" : undefined}
                        aria-label={`${cell.date} — ${cell.count} ${lang === "th" ? "หัวข้อ" : "topics"}`}
                        title={`${cell.count} ${lang === "th" ? "หัวข้อ" : "topics"}`}
                      >
                        <span class="day-num num">{day}</span>
                        <span class="day-count num">{cell.count}</span>
                      </button>
                    );
                  })}
                </div>
              </div>
            ))}
          </div>
        </section>
      )}
    </>
  )}
  </div>

  <style>
    /* ---- Layout primitives ---- */
    .controls,
    .metric-guide,
    .archive-disclosure,
    .empty-state {
      max-width: var(--max, 78rem);
      margin-inline: auto;
    }

    /* ---- Day-view container ---- */
    .day-view[hidden] { display: none; }
    .day-view {
      animation: day-view-in 320ms cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    @keyframes day-view-in {
      from { opacity: 0; transform: translateY(6px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ---- Brief line ---- */
    .brief {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 0.5rem 1.5rem;
      flex-wrap: wrap;
      padding: 0.85rem 0 0.75rem;
      font-size: var(--step--1);
      max-width: var(--max, 78rem);
      margin-inline: auto;
      border-bottom: var(--rule-faint);
      margin-bottom: var(--space-sm);
    }
    .brief-label {
      display: inline-flex;
      align-items: baseline;
      flex-wrap: wrap;
      gap: 0.35rem 0.55rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--soft-ink);
    }
    .brief-label .num { color: var(--ink); }
    .brief-sep { color: var(--hairline); }
    .brief-today {
      display: inline-flex;
      align-items: center;
      padding: 0.1rem 0.55rem;
      background: var(--accent);
      color: var(--bg);
      font-weight: 700;
      letter-spacing: 0.08em;
      border-radius: 999px;
    }
    .brief-date { color: var(--ink); }
    .brief-nav {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
    }
    .brief-daynav {
      display: inline-flex;
      align-items: center;
      min-height: 30px;
      padding: 0.2rem 0.65rem;
      color: var(--accent-ink);
      text-decoration: none;
      border: 1px solid var(--line);
      border-radius: 999px;
      letter-spacing: 0;
      transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
    }
    .brief-daynav:hover {
      border-color: var(--accent);
      background: color-mix(in oklch, var(--accent), transparent 92%);
    }
    .brief-daynav--disabled {
      color: var(--faint-ink);
      opacity: 0.4;
      pointer-events: none;
      border-color: var(--hairline);
    }
    .brief-new {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-size: var(--step--1);
      color: var(--accent-ink);
      font-family: var(--font-ui);
    }
    .brief-new::before {
      content: "";
      display: inline-block;
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--accent);
    }

    /* ---- Front-page grid (asymmetric lead + rail) ---- */
    .frontpage {
      display: grid;
      grid-template-columns: var(--grid-lead, minmax(0,7fr) minmax(0,5fr));
      gap: 0;
      margin-top: var(--space-md);
      max-width: var(--max, 78rem);
      margin-inline: auto;
    }
    @media (max-width: 56rem) {
      .frontpage { grid-template-columns: 1fr; }
    }

    /* ---- Lead block ---- */
    .lead {
      padding-right: var(--space-lg);
      border-top: var(--rule-lead);
      padding-top: var(--space-sm);
      position: relative;
      overflow: hidden;
    }

    /* Giant faint "01" behind the headline — editorial depth */
    .lead-rank-bg {
      position: absolute;
      top: -0.15em;
      right: calc(var(--space-lg) + 0.5rem);
      font-family: var(--font-display);
      font-size: clamp(6rem, 12vw, 14rem);
      font-weight: 700;
      line-height: 1;
      color: color-mix(in oklch, var(--accent), transparent 88%);
      pointer-events: none;
      user-select: none;
      letter-spacing: -0.04em;
    }

    .lead-eyebrow {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      flex-wrap: wrap;
      letter-spacing: 0.06em;
    }
    .lead-trend-up { color: var(--accent-ink); }
    .lead-trend { color: var(--faint-ink); }
    .lead-headline {
      font-family: var(--font-display);
      font-size: var(--step-lead);
      font-weight: 650;
      line-height: 0.97;
      letter-spacing: -0.015em;
      margin: 0.5rem 0 0;
      max-width: 15ch;
      text-wrap: balance;
    }
    :lang(th) .lead-headline { line-height: 1.18; }
    .lead-headline a { text-decoration: none; color: var(--ink); }
    .lead-headline a:hover { color: var(--accent-ink); }

    /* WHY IT MATTERS block — labeled dek under the headline */
    .lead-why {
      margin: var(--space-md) 0 0;
      max-width: var(--measure-dek, 56ch);
    }
    .lead-why-label {
      display: block;
      margin: 0 0 0.2rem;
      font-size: var(--step--1);
      font-weight: 700;
      letter-spacing: 0.08em;
    }

    /* Standfirst — Newsreader body, no italic (WHY IT MATTERS label provides context) */
    .lead-stand {
      margin: 0;
      font-family: var(--font-body);
      font-size: var(--step-1);
      font-weight: 400;
      line-height: 1.5;
      color: var(--soft-ink);
      text-wrap: pretty;
    }
    :lang(th) .lead-stand { font-family: "Noto Serif Thai", var(--font-body); line-height: 1.65; }
    .lead-kicker-topic { font-weight: 700; }

    /* Lead media hidden — type leads, not image (REDESIGN §4.2) */
    .lead-media {
      display: none;
    }
    .lead-media::after {
      content: "";
      position: absolute;
      inset: 0;
      box-shadow: inset 0 0 0 1px color-mix(in oklch, var(--ink), transparent 88%);
      pointer-events: none;
    }
    .lead-media img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      filter: saturate(0.96);
      transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), filter 0.3s ease;
    }
    .lead:hover .lead-media img { transform: scale(1.035); filter: saturate(1); }
    .why {
      margin: 1rem 0 0;
      max-width: var(--measure-dek, 56ch);
    }
    .why-lbl { display: block; }
    .why-dek {
      margin: 0.2rem 0 0;
      font-size: var(--step-0);
      line-height: 1.5;
      color: var(--soft-ink);
      font-family: var(--font-body);
    }
    .tldr-bullets {
      list-style: none;
      margin: 1.1rem 0 0;
      padding: 0;
      max-width: var(--measure-prose, 66ch);
    }
    .tldr-bullets li {
      position: relative;
      padding-left: 1.1rem;
      margin: 0.5rem 0;
      line-height: 1.55;
      font-family: var(--font-body);
      font-size: var(--step-0);
    }
    .tldr-bullets li::before {
      content: "";
      position: absolute;
      left: 0;
      top: 0.72em;
      width: 0.55rem;
      border-top: 1.5px solid var(--accent);
      opacity: 0.5;
    }
    .tldr-bullets li b {
      font-weight: 600;
      color: var(--ink);
      font-style: normal;
    }
    .meta-foot {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      flex-wrap: wrap;
      margin-top: 1.2rem;
      padding-top: 0.8rem;
      border-top: var(--rule-faint);
      font-size: var(--step--1);
      color: var(--faint-ink);
    }
    .spark {
      display: inline-block;
      vertical-align: middle;
      color: var(--accent);
      flex-shrink: 0;
    }
    .meta-read {
      font-family: var(--font-ui);
      font-weight: 600;
      color: var(--accent-ink);
      text-decoration: none;
      letter-spacing: 0;
      text-transform: none;
    }
    .meta-read:hover { text-decoration: underline; }
    .meta-langs {
      margin-left: auto;
      display: inline-flex;
      gap: 0.35rem;
      font-size: var(--step--1);
    }
    .meta-langs a {
      text-decoration: none;
      color: var(--soft-ink);
      font-weight: 600;
      border-bottom: 1px solid var(--hairline);
      padding-bottom: 0.05em;
      min-height: 28px;
      display: inline-flex;
      align-items: center;
    }
    .meta-langs a.active { color: var(--accent-ink); border-color: var(--accent); }

    @media (max-width: 56rem) {
      .lead { padding-right: 0; }
    }

    /* ---- Rail (hairline-separated teasers) ---- */
    .rail {
      padding-left: var(--space-lg);
      border-left: var(--rule-section);
      padding-top: var(--space-sm);
    }
    @media (max-width: 56rem) {
      .rail {
        padding-left: 0;
        border-left: 0;
        border-top: var(--rule-major);
        margin-top: var(--space-md);
        padding-top: var(--space-md);
      }
    }
    .rail-head {
      margin: 0 0 0.6rem;
      padding-bottom: 0.5rem;
      border-bottom: var(--rule-section);
      letter-spacing: 0.1em;
    }
    .teaser {
      padding: 0.9rem 0.6rem 0.9rem 0.7rem;
      margin-left: -0.7rem;
      border-top: var(--rule-section);
      border-left: 2px solid transparent;
      position: relative;
      transition: border-color 0.18s ease, background 0.18s ease;
    }
    .teaser:first-of-type { border-top: 0; padding-top: 0; }
    .teaser:hover,
    .teaser:focus-within {
      border-left-color: var(--accent);
      background: color-mix(in oklch, var(--accent), transparent 94%);
    }
    .teaser:hover .t-headline a,
    .teaser:focus-within .t-headline a { color: var(--accent-ink); }
    .t-eyebrow {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      flex-wrap: wrap;
    }
    .t-headline {
      font-family: var(--font-display);
      /* Sentence headlines now — step down from step-2 so rail teasers read as
         compact news items, not oversized topic labels. */
      font-size: var(--step-1);
      font-weight: 600;
      line-height: 1.12;
      letter-spacing: -0.008em;
      margin: 0.3rem 0 0;
    }
    :lang(th) .t-headline { line-height: 1.4; }
    .teaser.lg .t-headline { font-size: var(--step-2); }
    .t-headline a { text-decoration: none; color: var(--ink); }
    .t-headline a:hover { color: var(--accent-ink); }

    /* Rank number — mono, faint, sits before eyebrow */
    .t-rank {
      font-family: var(--font-mono);
      font-size: 0.66rem;
      font-weight: 500;
      color: var(--faint-ink);
      letter-spacing: 0;
      flex-shrink: 0;
      margin-right: 0.15rem;
    }

    /* Rail teaser thumbnail — small square at the right; text reflows left. Only
       when the source post had usable media (.has-media), build-time snapshot.
       The text column gets a min-width so headlines never wrap mid-word in the
       narrow remaining space; the image sits beside the kicker+headline rows. */
    .teaser.has-media {
      display: grid;
      grid-template-columns: minmax(13rem, 1fr) 72px;
      column-gap: var(--space-sm);
      align-items: start;
    }
    .teaser.has-media > .t-media { grid-column: 2; grid-row: 1 / 99; align-self: start; margin-top: 0.15rem; }
    .teaser.has-media > :not(.t-media) { grid-column: 1; }
    /* In the narrowed text column, drop the headline a step and keep words intact
       (the → glyph in "Vercel→Cloudflare" must not break mid-token). */
    .teaser.has-media .t-headline {
      font-size: var(--step-0);
      line-height: 1.2;
      overflow-wrap: normal;
      word-break: keep-all;
      hyphens: none;
    }
    .t-media {
      display: block;
      aspect-ratio: 1 / 1;
      overflow: hidden;
      background: var(--surface);
      position: relative;
    }
    .t-media::after {
      content: "";
      position: absolute;
      inset: 0;
      box-shadow: inset 0 0 0 1px color-mix(in oklch, var(--ink), transparent 88%);
    }
    .t-media img {
      width: 100%; height: 100%;
      object-fit: cover; display: block;
      filter: saturate(0.95);
      transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .teaser:hover .t-media img,
    .teaser:focus-within .t-media img { transform: scale(1.04); }
    .t-dek {
      margin: 0.3rem 0 0;
      color: var(--soft-ink);
      font-size: var(--step-0);
      line-height: 1.45;
      max-width: 46ch;
      font-family: var(--font-body);
    }
    .t-meta {
      margin: 0.45rem 0 0;
      font-size: var(--step--1);
      color: var(--faint-ink);
    }

    /* ---- old brief-meta kept for phase/badge compat ---- */
    .brief-meta {
      margin: 0;
      color: var(--soft-ink);
      font-size: var(--step--1);
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      flex-wrap: wrap;
    }
    .brief-meta strong { color: var(--ink); font-weight: 700; }

    .kicker.accent { color: var(--accent-ink); }

    /* ---- Filter chip bar ---- */
    .controls {
      margin-bottom: var(--space-md);
      display: flex;
      flex-direction: column;
      gap: 0.55rem;
      align-items: stretch;
      padding-bottom: var(--space-sm);
      border-bottom: 1px solid var(--hairline);
    }
    .controls .control-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem 0.4rem;
      align-items: center;
      width: 100%;
    }

    /* ---- Search box ---- */
    .search-wrap {
      position: relative;
      flex: 1 1 16rem;
      width: 100%;
    }
    .search-field {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      width: 100%;
      padding: 0.35rem 0.75rem;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: color-mix(in oklch, var(--paper), transparent 12%);
      color: var(--soft-ink);
      transition: border-color 0.15s ease, color 0.15s ease, border-radius 0.15s ease;
    }
    .search-field:focus-within {
      border-color: var(--accent);
      color: var(--accent-ink);
    }
    .search-wrap:has([data-report-results]:not([hidden])) .search-field {
      border-radius: 12px 12px 0 0;
      border-bottom-color: transparent;
    }
    .search-icon { color: currentColor; flex: 0 0 auto; }

    /* ---- Unified report results dropdown ---- */
    .report-results {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      z-index: 40;
      background: var(--paper);
      border: 1px solid var(--accent);
      border-top: none;
      border-radius: 0 0 12px 12px;
      max-height: 400px;
      overflow-y: auto;
      box-shadow: 0 12px 36px -12px color-mix(in oklch, var(--ink), transparent 62%);
    }
    .report-results[hidden] { display: none; }

    /* All report-row-* are JS-injected → must use :global() to bypass Astro scope */
    :global(.report-row) {
      display: block;
      padding: 0.65rem 1rem;
      border-top: 1px solid var(--hairline);
      text-decoration: none;
      color: var(--ink);
      transition: background 0.14s ease;
    }
    :global(.report-row:first-child) { border-top: none; }
    :global(.report-row:hover) { background: color-mix(in oklch, var(--accent), transparent 92%); }
    :global(.report-row:hover .report-row-title) { color: var(--accent-ink); }

    :global(.report-row-meta) {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 0.5rem;
      padding-bottom: 0.28rem;
      margin-bottom: 0.28rem;
      border-bottom: 1px solid var(--hairline);
    }
    :global(.report-row-topic) {
      font-family: var(--font-ui);
      font-size: 0.67rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--soft-ink);
    }
    :global(.report-row-date) {
      font-family: var(--font-mono);
      font-size: 0.64rem;
      color: var(--faint-ink);
      white-space: nowrap;
    }
    :global(.report-row-title) {
      font-family: var(--font-display);
      font-size: var(--step-0);
      font-weight: 600;
      line-height: 1.3;
      color: var(--ink);
      transition: color 0.14s ease;
    }
    :global(.report-row-excerpt) {
      margin: 0.2rem 0 0;
      font-family: var(--font-body);
      font-size: var(--step--1);
      line-height: 1.5;
      color: var(--soft-ink);
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 2;
      overflow: hidden;
    }
    :global(.report-row-excerpt mark) {
      background: color-mix(in oklch, var(--accent), transparent 76%);
      color: var(--ink);
      border-radius: 2px;
      padding: 0 0.1em;
    }
    .report-results-empty {
      padding: 1rem;
      font-family: var(--font-ui);
      font-size: var(--step--1);
      color: var(--faint-ink);
      text-align: center;
    }
    .report-results-foot {
      padding: 0.45rem 1rem;
      border-top: 1px solid var(--hairline);
      font-family: var(--font-mono);
      font-size: 0.65rem;
      color: var(--faint-ink);
    }

    .search-field input {
      appearance: none;
      background: transparent;
      border: 0;
      outline: 0;
      width: 100%;
      font-family: var(--font-ui);
      font-size: var(--step--1);
      color: var(--ink);
      min-height: 24px;
    }
    .search-field input::placeholder { color: var(--faint-ink); }
    .visually-hidden {
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip: rect(0 0 0 0);
      white-space: nowrap;
    }
    .chip {
      appearance: none;
      background: transparent;
      color: var(--soft-ink);
      font-family: var(--font-ui);
      font-size: var(--step--1);
      font-weight: 600;
      border: 1px solid var(--line);
      border-radius: 999px;
      padding: 0.28rem 0.8rem;
      min-height: 28px;
      cursor: pointer;
      line-height: 1.2;
      transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
    }
    .chip:hover { color: var(--accent-ink); border-color: var(--accent); background: color-mix(in oklch, var(--accent), transparent 93%); }
    .chip.active {
      color: var(--bg);
      background: var(--accent);
      border-color: var(--accent);
    }
    .control-empty {
      flex-basis: 100%;
      margin: 0.35rem 0 0;
      color: var(--soft-ink);
      font-style: italic;
