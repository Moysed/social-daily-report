---
import { getCollection, render } from "astro:content";
import Base from "../../../../layouts/Base.astro";
import { prettyDate, prettyTopic } from "../../../../lib/format";
import { UI, type Lang } from "../../../../lib/i18n";

export async function getStaticPaths() {
  const all = await getCollection("reports");
  return all.map((entry) => ({
    params: { date: entry.data.date, topic: entry.data.topic, lang: entry.data.lang },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
const hasXEmbed = entry.body?.includes("twitter-tweet") ?? false;
const lang = d.lang as Lang;
const otherLang: Lang = lang === "th" ? "en" : "th";
const t = UI[lang];
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const reportHref = (targetLang: Lang) => `${base}/report/${d.date}/${d.topic}/${targetLang}`;
const homeHref = lang === "th" ? `${base}/th/` : `${base}/`;
const title = `${prettyTopic(d.topic)} - ${d.date}`;
const pct = (value?: number | null) => (value == null ? null : Math.round(value * 100));
const meta = [
  t.posts(d.post_count),
  t.salience(pct(d.salience)),
  t.confidence(pct(d.confidence)),
  d.model ? `${t.model} ${d.model}` : null,
  d.translated_by ? `${t.translatedBy} ${d.translated_by}` : null,
].filter(Boolean);
---

<Base title={title} lang={lang} alternateHref={reportHref(otherLang)}>
  <div class="report-shell">
    <header class="report-chrome">
      <nav class="report-nav ui-text" aria-label="Report navigation">
        <a href={homeHref}>{t.backHome}</a>
        <a class="language-toggle" href={reportHref(otherLang)} aria-label={t.switchReport} hreflang={otherLang}>
          <span class={lang === "en" ? "active" : ""}>EN</span>
          <span aria-hidden="true">/</span>
          <span class={lang === "th" ? "active" : ""}>TH</span>
        </a>
      </nav>
      <p class="report-label ui-text">{t.dailyBrief}</p>
      <h1>{prettyTopic(d.topic)}</h1>
      <p class="report-date ui-text">{prettyDate(d.date)}</p>
      <p class="report-meta ui-text" aria-label={t.reportMeta}>{meta.join(" / ")}</p>
      {d.platforms.length > 0 && (
        <p class="report-platforms ui-text">
          <strong>{t.platforms}</strong>
          {d.platforms.map((platform) => <span>{platform}</span>)}
        </p>
      )}
    </header>

    <article class="prose" lang={lang}>
      <Content />
    </article>
  </div>
  {hasXEmbed && (
    <script async src="https://platform.twitter.com/widgets.js" charset="utf-8"></script>
  )}

  <style>
    .report-shell {
      max-width: 68rem;
      margin: 0 auto;
    }

    .report-chrome {
      max-width: 68ch;
      margin: 0 0 var(--space-md);
      padding-bottom: var(--space-md);
      border-bottom: 1px solid var(--line);
      position: relative;
    }
    .report-chrome::after {
      content: "";
      position: absolute;
      bottom: -1px;
      left: 0;
      width: 4rem;
      height: 1px;
      background: var(--accent);
    }

    .report-nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 0.5rem 1rem;
      margin-bottom: var(--space-lg);
      color: var(--soft-ink);
      font-size: var(--step--1);
      font-weight: 700;
      line-height: 1.4;
    }

    .report-nav a {
      min-height: 44px;
      display: inline-flex;
      align-items: center;
      text-decoration: none;
      border-bottom: 1px solid var(--line);
    }

    .language-toggle {
      gap: 0.42rem;
      color: var(--ink);
    }

    .language-toggle .active {
      color: var(--accent-ink);
      font-weight: 800;
    }

    .report-label {
      margin: 0 0 var(--space-xs);
      color: var(--accent-ink);
      font-size: 0.76rem;
      font-weight: 800;
      letter-spacing: 0.14em;
      line-height: 1.35;
      text-transform: uppercase;
    }

    .report-chrome h1 {
      margin: 0;
      font-family: var(--font-display);
      font-size: var(--step-3);
      font-weight: 650;
      letter-spacing: 0;
      line-height: 1.04;
    }

    .report-date,
    .report-meta,
    .report-platforms {
      margin: var(--space-xs) 0 0;
      color: var(--soft-ink);
      font-size: 0.84rem;
      line-height: 1.55;
      overflow-wrap: anywhere;
    }

    .report-date {
      color: var(--ink);
      font-family: var(--font-mono);
      font-weight: 500;
      font-size: 0.86rem;
      letter-spacing: 0.04em;
    }

    .report-meta {
      font-family: var(--font-mono);
      font-feature-settings: "ss01" 1, "tnum" 1;
      letter-spacing: 0.01em;
    }

    .report-platforms {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem 0.8rem;
    }

    .report-platforms strong {
      color: var(--ink);
    }

    .prose {
      min-width: 0;
      max-width: 68ch;
      margin: 0;
      font-family: var(--font-body);
      font-size: var(--step-0);
      line-height: 1.78;
      animation: report-in 520ms cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    .prose[lang="th"] {
      font-family: "Noto Serif Thai", var(--font-body);
      line-height: 1.88;
    }

    .prose :global(h1),
    .prose :global(h2),
    .prose :global(h3) {
      font-family: var(--font-display);
      letter-spacing: 0;
      color: var(--ink);
    }

    .prose[lang="th"] :global(h1),
    .prose[lang="th"] :global(h2),
    .prose[lang="th"] :global(h3) {
      font-family: "Noto Serif Thai", var(--font-display);
    }

    .prose :global(h1) {
      margin: 0 0 var(--space-lg);
      font-size: var(--step-3);
      font-weight: 650;
      line-height: 1.04;
    }

    /* The h1 (report title) duplicates the chrome above — hide it in the body
       so readers don't see the topic name printed twice. */
    .prose :global(h1):first-child { display: none; }

    /* Protocol-style section breaks: each ## becomes a two-line header —
       small mono index ("§ 04") above a serif name. Hairline rule across
       the column, with an accent stub at the leading edge. */
    .prose { counter-reset: section; }

    .prose :global(h2) {
      counter-increment: section;
      position: relative;
      margin: var(--space-xl) 0 var(--space-sm);
      padding-top: 1.6rem;
      font-family: var(--font-display);
      font-size: var(--step-2);
      font-weight: 600;
      line-height: 1.08;
      letter-spacing: -0.005em;
    }

    /* Hairline rule with accent stub */
    .prose :global(h2)::after {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(
        90deg,
        var(--accent) 0,
        var(--accent) 2.6rem,
        var(--line) 2.6rem,
        var(--line) 100%
      );
    }

    /* Section index — "§ 04" in mono, sits above the heading */
    .prose :global(h2)::before {
      content: "§ " counter(section, decimal-leading-zero);
      display: block;
      margin-bottom: 0.45rem;
      font-family: var(--font-mono);
      font-feature-settings: "ss01" 1;
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.04em;
      color: var(--accent-ink);
      line-height: 1;
    }

    /* TL;DR lead block — wider tinted strip, no left padding because the
       new heading layout dropped the inline counter. */
    .prose :global(h2):first-of-type {
      margin-top: 0;
    }
    .prose :global(h2):first-of-type + :global(ul),
    .prose :global(h2):first-of-type + :global(p) {
      padding: var(--space-md);
      margin-block: 0 var(--space-md);
      background: color-mix(in oklch, var(--accent), transparent 92%);
      border-left: 2px solid var(--accent);
    }

    .prose :global(h3) {
      margin: var(--space-lg) 0 var(--space-xs);
      font-family: var(--font-display);
      font-size: var(--step-1);
      font-weight: 600;
      line-height: 1.2;
      color: var(--accent-ink);
    }

    .prose :global(p),
    .prose :global(ul),
    .prose :global(ol),
    .prose :global(blockquote),
    .prose :global(pre),
    .prose :global(table) {
      margin-top: 0;
      margin-bottom: var(--space-md);
    }

    .prose :global(p),
    .prose :global(li),
    .prose :global(blockquote) {
      overflow-wrap: break-word;
    }

    .prose :global(ul),
    .prose :global(ol) {
      padding-left: 1.4em;
    }

    .prose :global(li) {
      padding-left: 0.35em;
      margin: 0.55rem 0;
      line-height: 1.7;
    }

    .prose[lang="th"] :global(li) { line-height: 1.85; }

    .prose :global(li::marker) {
      color: var(--accent);
      font-weight: 700;
    }

    /* Nested lists tighten back up so they don't visually explode. */
    .prose :global(li ul),
    .prose :global(li ol) {
      margin: 0.35rem 0 0.5rem;
    }

    .prose :global(a) {
      color: var(--accent-ink);
      text-decoration-line: underline;
      text-decoration-color: color-mix(in oklch, var(--accent), transparent 25%);
      text-underline-offset: 0.22em;
    }

    .prose :global(strong) {
      font-weight: 650;
      color: var(--ink);
    }

    .prose :global(blockquote) {
      margin-left: 0;
      padding: var(--space-sm) var(--space-md);
      border-left: 3px solid var(--accent);
      background: color-mix(in oklch, var(--surface), transparent 38%);
      color: var(--soft-ink);
    }

    .prose :global(table) {
      display: block;
      width: 100%;
      max-width: 100%;
      overflow-x: auto;
      border-collapse: collapse;
      font-family: var(--font-ui);
      font-size: var(--step--1);
      line-height: 1.45;
    }

    .prose :global(th),
    .prose :global(td) {
      padding: 0.62rem 0.7rem;
      border-bottom: 1px solid var(--line);
      text-align: left;
      vertical-align: top;
    }

    .prose :global(th) {
      color: var(--soft-ink);
      font-weight: 700;
      background: color-mix(in oklch, var(--surface), transparent 35%);
    }

    .prose :global(pre) {
      max-width: 100%;
      overflow-x: auto;
      padding: var(--space-sm);
      background: var(--surface);
      border: 1px solid var(--line);
    }

    .prose :global(pre code) {
      padding: 0;
      border: 0;
      background: transparent;
    }

    .prose :global(hr) {
      border: 0;
      border-top: 1px solid var(--line);
      margin: var(--space-xl) 0;
    }

    /* ---- Top Posts stream (NDF editorial cards) ----
       Layout: first card = lead (full-width, side-by-side at md+).
       Subsequent cards = 3-up dense grid that wraps to 2 / 1 on smaller widths.
       Field labels use small caps with a hanging accent rule, not blocky chips.
       "How NDF DEV adapts" is the visual anchor — a pull-quote style block
       with a strong accent bar that reads first when you scan the card. */
    .prose :global(.post-stream) {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(19rem, 1fr));
      gap: var(--space-md) var(--space-sm);
      margin: var(--space-md) 0 var(--space-lg);
      container-type: inline-size;
    }
    /* The lead card spans every column it can (max 3) and switches to a
       2-column "image left, prose right" layout once there's room. */
    .prose :global(.ndf-card:first-child) {
      grid-column: 1 / -1;
    }

    .prose :global(.ndf-card) {
      position: relative;
      display: grid;
      grid-template-rows: auto 1fr;
      border-top: 1px solid var(--line);
      padding-top: var(--space-sm);
      background: transparent;
      font-family: var(--font-body);
      font-size: var(--step--1);
      gap: 0.6rem;
    }
    /* Subtle column-rule between non-lead cards on the same row. */
    .prose :global(.ndf-card:not(:first-child)) {
      padding-inline: 0.05rem;
    }

    /* ---- Header strip ---- */
    .prose :global(.ndf-card-head) {
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
      gap: 0.35rem 0.85rem;
      color: var(--soft-ink);
      font-family: var(--font-ui);
      font-size: 0.78rem;
      letter-spacing: 0.02em;
    }
    .prose :global(.ndf-author) {
      color: var(--ink);
      font-weight: 700;
      letter-spacing: 0;
    }
    .prose :global(.ndf-platform) {
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--accent-ink);
      font-weight: 700;
      font-size: 0.66rem;
    }
    .prose :global(.ndf-engagement) {
      margin-left: auto;
      color: var(--faint-ink);
      font-family: var(--font-mono);
      font-variant-numeric: tabular-nums slashed-zero;
      font-feature-settings: "ss01" 1;
      font-size: 0.74rem;
      letter-spacing: -0.005em;
    }
    .prose :global(.ndf-author) {
      font-family: var(--font-ui);
    }

    /* ---- Media block ---- */
    .prose :global(.ndf-card-media) {
      display: block;
      aspect-ratio: 4 / 3;
      overflow: hidden;
      background: var(--surface);
    }
    .prose :global(.ndf-card-media img) {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), filter 0.3s ease;
      filter: saturate(0.92);
    }
    .prose :global(.ndf-card-media:hover img) {
      transform: scale(1.035);
      filter: saturate(1);
    }
    .prose :global(.ndf-x-embed) {
      margin: 0 !important;
      border: 1px solid var(--hairline) !important;
      padding: 0.55rem 0.8rem !important;
      background: color-mix(in oklch, var(--surface), transparent 60%) !important;
    }

    /* ---- Body ---- */
    .prose :global(.ndf-card-body) {
      display: flex;
      flex-direction: column;
      gap: 0.55rem;
    }
    .prose :global(.ndf-quote) {
      margin: 0;
      color: var(--ink);
      font-family: var(--font-body);
      font-style: italic;
      font-size: 0.95em;
      line-height: 1.55;
      position: relative;
      padding-left: 1rem;
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 3;
      overflow: hidden;
    }
    .prose :global(.ndf-quote)::before {
      content: "\201C";
      position: absolute;
      left: 0;
      top: -0.1em;
      font-family: var(--font-display);
      font-size: 1.6em;
      line-height: 1;
      color: color-mix(in oklch, var(--accent), transparent 35%);
    }

    /* ---- Field list: small-caps labels, hanging rule indent ---- */
    .prose :global(.ndf-fields) {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.45rem 0;
      margin: 0.3rem 0 0;
      padding: 0;
    }
    .prose :global(.ndf-fields dt) {
      margin: 0;
      padding-left: 0.65rem;
      position: relative;
      font-family: var(--font-ui);
      font-feature-settings: "smcp" 1, "c2sc" 1;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      color: var(--soft-ink);
      text-transform: lowercase;  /* small-caps OT renders uppercase glyphs */
    }
    .prose :global(.ndf-fields dt)::before {
      content: "";
      position: absolute;
      left: 0;
      top: 0.55em;
      width: 0.4rem;
      height: 1px;
      background: var(--soft-ink);
      opacity: 0.5;
    }
    .prose :global(.ndf-fields dd) {
      margin: 0.1rem 0 0 0.65rem;
      color: var(--ink);
      font-family: var(--font-body);
      line-height: 1.6;
    }

    /* ---- Adapt callout: the visual anchor of every card ---- */
    .prose :global(.ndf-adapt-label) {
      color: var(--accent-ink) !important;
    }
    .prose :global(.ndf-adapt-label)::before {
      background: var(--accent) !important;
      opacity: 1 !important;
      width: 0.55rem !important;
    }
    .prose :global(.ndf-adapt) {
      margin: 0.15rem 0 0 0.65rem !important;
      color: var(--ink) !important;
      font-family: var(--font-body) !important;
      font-size: 0.98em !important;
      line-height: 1.55 !important;
      padding: 0.5rem 0 0.5rem 0.85rem;
      border-left: 2px solid var(--accent);
      background: linear-gradient(
        90deg,
        color-mix(in oklch, var(--accent), transparent 92%) 0%,
        transparent 65%
      );
    }

    /* ---- Source link ---- */
    .prose :global(.ndf-source) {
      margin-top: 0.35rem;
      align-self: flex-start;
      font-family: var(--font-ui);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      color: var(--accent-ink);
      text-decoration: none;
      border-bottom: 1px solid color-mix(in oklch, var(--accent), transparent 60%);
      padding-bottom: 0.08em;
      transition: border-color 0.15s ease;
    }
    .prose :global(.ndf-source:hover) {
      border-color: var(--accent);
    }

    /* ---- Lead card: two-column composition once we have room ---- */
    @container (min-width: 44rem) {
      .prose :global(.ndf-card:first-child) {
        grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
        grid-template-rows: auto auto;
        column-gap: var(--space-md);
        row-gap: 0.55rem;
        align-items: start;
        padding-top: var(--space-md);
      }
      .prose :global(.ndf-card:first-child .ndf-card-head) {
        grid-column: 1 / -1;
      }
      .prose :global(.ndf-card:first-child .ndf-card-media),
      .prose :global(.ndf-card:first-child .ndf-x-embed) {
        grid-column: 1;
        grid-row: 2;
        aspect-ratio: 5 / 4;
        align-self: start;
        position: sticky;
        top: var(--space-md);
      }
      .prose :global(.ndf-card:first-child .ndf-card-body) {
        grid-column: 2;
        grid-row: 2;
      }
      .prose :global(.ndf-card:first-child .ndf-quote) {
        font-size: 1.1em;
        -webkit-line-clamp: 4;
        line-height: 1.5;
      }
      .prose :global(.ndf-card:first-child .ndf-quote)::before {
        font-size: 2em;
        top: -0.18em;
      }
      .prose :global(.ndf-card:first-child .ndf-fields dd) {
        font-size: 1.02em;
        line-height: 1.65;
      }
      .prose :global(.ndf-card:first-child .ndf-adapt) {
        font-size: 1.05em !important;
        padding: 0.7rem 0 0.7rem 1rem;
      }
    }

    /* On narrow / single-column post-stream, drop the strict 3-up cadence —
       cards become more spacious and the quote opens up. */
    @container (max-width: 36rem) {
      .prose :global(.ndf-card-media) { aspect-ratio: 16 / 9; }
      .prose :global(.ndf-quote) { -webkit-line-clamp: 5; }
    }

    @keyframes report-in {
      from {
        opacity: 0;
        transform: translateY(10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (max-width: 560px) {
      .report-nav > a:first-child {
        flex: 1 1 100%;
      }

      .language-toggle {
        width: 100%;
        justify-content: center;
        gap: 0.7rem;
      }

      .prose {
        line-height: 1.72;
      }

      .prose[lang="th"] {
        line-height: 1.84;
      }

      .prose :global(ul),
      .prose :global(ol) {
        padding-left: 1.05em;
      }

      .prose :global(blockquote) {
        padding-inline: var(--space-sm);
      }

      .prose :global(th),
      .prose :global(td) {
        padding: 0.55rem 0.62rem;
      }

      /* Stack the counter above the heading on narrow screens to keep the
         text from getting squeezed. */
      .prose :global(h2) {
        padding-left: 0;
        padding-top: 2.2rem;
      }
      .prose :global(h2)::before {
        position: static;
        display: block;
        margin-bottom: 0.25rem;
      }
      .prose :global(h2):first-of-type + :global(ul),
      .prose :global(h2):first-of-type + :global(p) {
        padding-left: var(--space-md);
        margin-left: 0;
      }
    }
  </style>
</Base>
