  {/* Filter + search + calendar day picker.
      - Day-view swap: each date pre-renders its own brief+lead+grid. The
        calendar picks which one is active; the layout stays identical.
      - Each day-view has its own controls (chips + search). The active
        topic/query state is broadcast across all sets so switching days
        preserves the current filter.
      - Calendar cell click: makes that day's view active, scrolls to top. */}
  <script is:inline>
    (() => {
      const wrapper = document.querySelector("[data-day-views]");
      if (!wrapper) return;
      const views = Array.from(wrapper.querySelectorAll("[data-day-view]"));
      const calCells = Array.from(document.querySelectorAll("[data-cal-day]"));

      let activeTopic = "";
      let activeQuery = "";

      function rowMatches(row) {
        if (activeTopic && row.dataset.topic !== activeTopic) return false;
        if (activeQuery && !(row.dataset.haystack || "").includes(activeQuery)) return false;
        return true;
      }

      function applyToView(view) {
        let anyVisible = false;
        const rows = view.querySelectorAll("[data-row]");
        for (const row of rows) {
          const visible = rowMatches(row);
          row.hidden = !visible;
          if (visible) anyVisible = true;
        }
        const rail = view.querySelector(".rail");
        if (rail) {
          const visibleTeasers = rail.querySelectorAll(".teaser:not([hidden])").length;
          rail.toggleAttribute("data-empty", visibleTeasers === 0);
        }
        const emptyMsg = view.querySelector("[data-filter-empty]");
        if (emptyMsg) emptyMsg.hidden = anyVisible;
      }

      function applyAll() {
        for (const view of views) applyToView(view);
      }

      function broadcastChip(value) {
        activeTopic = value || "";
        for (const view of views) {
          for (const c of view.querySelectorAll("[data-filter-chip]")) {
            c.classList.toggle("active", (c.dataset.value || "") === activeTopic);
          }
        }
      }

      function broadcastQuery(q) {
        activeQuery = q || "";
        for (const view of views) {
          const input = view.querySelector("[data-filter-search]");
          if (input && input.value !== activeQuery) input.value = activeQuery;
        }
      }

      // Wire all controls (one set per day-view). They share state.
      const debounce = { id: 0 };
      for (const view of views) {
        for (const chip of view.querySelectorAll("[data-filter-chip]")) {
          chip.addEventListener("click", () => {
            broadcastChip(chip.dataset.value || "");
            applyAll();
          });
        }
        const input = view.querySelector("[data-filter-search]");
        if (input) {
          input.addEventListener("input", () => {
            clearTimeout(debounce.id);
            debounce.id = setTimeout(() => {
              broadcastQuery((input.value || "").trim().toLowerCase());
              applyAll();
            }, 60);
          });
          input.addEventListener("keydown", (e) => {
            if (e.key === "Escape") {
              broadcastQuery("");
              applyAll();
              input.blur();
            }
          });
        }
      }

      // Day-view swap
      function showDay(date, opts) {
        const target = views.find((v) => v.dataset.dayView === date);
        if (!target) return;
        for (const v of views) {
          const on = v === target;
          v.hidden = !on;
          v.setAttribute("aria-hidden", on ? "false" : "true");
        }
        for (const c of calCells) {
          const on = c.dataset.calDay === date;
          c.classList.toggle("selected", on);
          if (on) c.setAttribute("aria-current", "date");
          else c.removeAttribute("aria-current");
        }
        const input = target.querySelector("[data-filter-search]");
        if (input) input.value = activeQuery;
        for (const c of target.querySelectorAll("[data-filter-chip]")) {
          c.classList.toggle("active", (c.dataset.value || "") === activeTopic);
        }
        applyToView(target);
        if (opts && opts.pushState) history.pushState({}, "", "#" + date);
        if (!opts || opts.scroll !== false) wrapper.scrollIntoView({ behavior: "smooth", block: "start" });
      }

      for (const cell of calCells) {
        cell.addEventListener("click", () => {
          const date = cell.dataset.calDay;
          if (date) showDay(date, { scroll: true, pushState: true });
        });
      }

      // Prev/next day arrows (a[data-prev-day] / a[data-next-day])
      wrapper.addEventListener("click", (e) => {
        const btn = e.target.closest("[data-prev-day],[data-next-day]");
        if (!btn) return;
        e.preventDefault();
        const date = btn.dataset.prevDay || btn.dataset.nextDay;
        if (date) showDay(date, { scroll: false, pushState: true });
      });

      // URL hash sync — #YYYY-MM-DD (new) or #day-YYYY-MM-DD (legacy)
      function fromHash() {
        const h = window.location.hash;
        const m = h && h.match(/^#(?:day-)?(\d{4}-\d{2}-\d{2})$/);
        if (m) showDay(m[1], { scroll: false });
      }
      fromHash();
      window.addEventListener("hashchange", fromHash);
      window.addEventListener("popstate", fromHash);
    })();
  </script>

  {/* Unread indicator: localStorage key "sdr:read" maps "${date}:${topic}" → timestamp.
      Language-agnostic key so EN read also marks TH card read and vice-versa.
      SSR default: all [data-row] have data-unread="" (shows dot). Script removes it for read cards.
      Graceful: try/catch on every localStorage access mirrors Base.astro theme pattern. */}
  <script is:inline>
    (() => {
      const KEY = "sdr:read";
      function getReadSet() {
        try {
          const raw = localStorage.getItem(KEY);
          return raw ? new Set(Object.keys(JSON.parse(raw))) : new Set();
        } catch { return new Set(); }
      }
      function markRead(date, topic) {
        try {
          const raw = localStorage.getItem(KEY);
          const obj = raw ? JSON.parse(raw) : {};
          obj[`${date}:${topic}`] = Date.now();
          localStorage.setItem(KEY, JSON.stringify(obj));
        } catch {}
      }
      // Remove data-unread from already-read cards
      const readSet = getReadSet();
      document.querySelectorAll("[data-row][data-unread]").forEach((card) => {
        const k = `${card.dataset.date}:${card.dataset.topic}`;
        if (readSet.has(k)) card.removeAttribute("data-unread");
      });
      // Update "X new since you last looked" count for the latest day-view
      (() => {
        const latestView = document.querySelector("[data-day-view]:not([hidden])");
        if (!latestView) return;
        const unreadCount = latestView.querySelectorAll("[data-row][data-unread]").length;
        const slot = document.querySelector("[data-new-count]");
        if (!slot) return;
        if (unreadCount > 0) {
          slot.textContent = slot.closest("[lang=th]") || document.documentElement.lang === "th"
            ? `${unreadCount} ใหม่ตั้งแต่คุณดูล่าสุด`
            : `${unreadCount} new since you last looked`;
          slot.hidden = false;
        } else {
          slot.hidden = true;
        }
      })();
      // Mark as read on report link click (event delegation)
      const dayViews = document.querySelector("[data-day-views]");
      if (!dayViews) return;
      dayViews.addEventListener("click", (e) => {
        const a = e.target.closest('a[href*="/report/"]');
        if (!a) return;
        const card = a.closest("[data-row]");
        if (!card || !card.dataset.date || !card.dataset.topic) return;
        markRead(card.dataset.date, card.dataset.topic);
        card.removeAttribute("data-unread");
      });
    })();
  </script>

  {/* Unified search: wires the filter search bar to Pagefind report search.
      Topic filter (chip/haystack) runs in the existing script above.
      This script adds report content search → dropdown results below the search field. */}
  <script is:inline>
    (() => {
      const input = document.querySelector("[data-filter-search]");
      const dropdown = document.querySelector("[data-report-results]");
      const list = document.querySelector("[data-report-list]");
      const emptyEl = document.querySelector("[data-report-empty]");
      const foot = document.querySelector("[data-report-foot]");
      const countEl = document.querySelector("[data-report-count]");
      if (!input || !dropdown) return;

      let pfSearch = null;
      let fallbackDocs = null;
      let loadPromise = null;

      function tokenize(s) {
        return (s || "").toLowerCase()
          .replace(/[`*_#>\[\]\(\)]/g, " ")
          .split(/[^a-z0-9ก-๙\-]+/u)
          .filter((t) => t && t.length > 1);
      }
      function scoreDoc(doc, tokens) {
        const hay = [doc.title, doc.topic, (doc.tags || []).join(" "),
          (doc.tldr || []).join(" "), (doc.signals || []).join(" ")].join(" ").toLowerCase();
        let s = 0;
        for (const t of tokens) {
          const re = new RegExp(t.replace(/[.*+?^${}()|[\]\\]/g, "\\$&"), "g");
          const m = hay.match(re); if (m) s += m.length;
        }
        return s;
      }
      function esc(s) {
        return (s || "").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;");
      }

      function closeDropdown() {
        dropdown.hidden = true;
        list.innerHTML = "";
        if (emptyEl) emptyEl.hidden = true;
        if (foot) foot.hidden = true;
      }

      function render(hits, total) {
        list.innerHTML = "";
        if (!hits.length) {
          if (emptyEl) emptyEl.hidden = false;
          if (foot) foot.hidden = true;
          dropdown.hidden = false;
          return;
        }
        if (emptyEl) emptyEl.hidden = true;
        const frag = document.createDocumentFragment();
        for (const h of hits) {
          const a = document.createElement("a");
          a.className = "report-row";
          a.href = h.url;
          const metaParts = [
            h.topic ? `<span class="report-row-topic">${esc(h.topic)}</span>` : "",
            h.date ? `<span class="report-row-date">${esc(h.date)}</span>` : "",
          ].filter(Boolean).join("");
          a.innerHTML =
            (metaParts ? `<div class="report-row-meta">${metaParts}</div>` : "") +
            `<div class="report-row-title">${esc(h.title || h.url)}</div>` +
            (h.excerpt ? `<p class="report-row-excerpt">${h.excerpt}</p>` : "");
          frag.appendChild(a);
        }
        list.appendChild(frag);
        if (foot && countEl) {
          countEl.textContent = `${total} ${total === 1 ? "result" : "results"}`;
          foot.hidden = false;
        }
        dropdown.hidden = false;
      }

      async function loadSearch() {
        if (loadPromise) return loadPromise;
        loadPromise = (async () => {
          try {
            const pf = await import("/pagefind/pagefind.js");
            await pf.options({ language: document.documentElement.lang || "en" });
            pfSearch = async (q) => {
              const r = await pf.search(q);
              const items = await Promise.all(r.results.slice(0, 7).map((x) => x.data()));
              return { total: r.results.length, items };
            };
          } catch {
            try {
              const res = await fetch("/search-index.json");
              fallbackDocs = res.ok ? (await res.json()).docs || [] : [];
            } catch { fallbackDocs = []; }
          }
        })();
        return loadPromise;
      }

      async function runQuery(q) {
        const tokens = tokenize(q);
        if (!tokens.length) { closeDropdown(); return; }
        await loadSearch();
        if (pfSearch) {
          try {
            const { total, items } = await pfSearch(q);
            const hits = items.map((d) => ({
              url: d.url,
              title: d.meta?.title || d.url,
              topic: d.meta?.topic || "",
              date: d.meta?.date || "",
              excerpt: d.excerpt || "",
            }));
            render(hits, total);
          } catch { closeDropdown(); }
        } else {
          const scored = (fallbackDocs || [])
            .map((d) => [scoreDoc(d, tokens), d])
            .filter(([s]) => s > 0)
            .sort((a, b) => b[0] - a[0] || (b[1].date || "").localeCompare(a[1].date || ""))
            .slice(0, 7);
          render(scored.map(([, d]) => ({
            url: d.url || "",
            title: d.title || d.topic || "",
            topic: d.topic || "",
            date: d.date || "",
            excerpt: (d.tldr && d.tldr[0]) || "",
          })), scored.length);
        }
      }

      const debounce = { id: 0 };
      input.addEventListener("input", () => {
        clearTimeout(debounce.id);
        debounce.id = setTimeout(() => runQuery(input.value.trim()), 180);
      });
      input.addEventListener("focus", loadSearch, { once: true });
      input.addEventListener("keydown", (e) => {
        if (e.key === "Escape") { closeDropdown(); input.blur(); }
      });

      // Close on outside click
      document.addEventListener("click", (e) => {
        if (!e.target.closest(".search-wrap")) closeDropdown();
      });
    })();
  </script>
</Base>
