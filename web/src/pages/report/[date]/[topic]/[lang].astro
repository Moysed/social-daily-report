---
import { getCollection, render } from "astro:content";
import Base from "../../../../layouts/Base.astro";
import { prettyDate, prettyTopic } from "../../../../lib/format";
import { UI, type Lang } from "../../../../lib/i18n";

export async function getStaticPaths() {
  const all = await getCollection("reports");
  return all.map((entry) => ({
    params: { date: entry.data.date, topic: entry.data.topic, lang: entry.data.lang },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const d = entry.data;
const hasXEmbed = entry.body?.includes("twitter-tweet") ?? false;
const lang = d.lang as Lang;
const otherLang: Lang = lang === "th" ? "en" : "th";
const t = UI[lang];
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const reportHref = (targetLang: Lang) => `${base}/report/${d.date}/${d.topic}/${targetLang}`;
const homeHref = lang === "th" ? `${base}/th/` : `${base}/`;
const title = `${prettyTopic(d.topic)} - ${d.date}`;
const pct = (value?: number | null) => (value == null ? null : Math.round(value * 100));
const saliencePct = pct(d.salience);
const confidencePct = pct(d.confidence);
const activityTier: "high" | "med" | "low" =
  d.post_count >= 40 ? "high" : d.post_count >= 15 ? "med" : "low";
const activityLabel =
  activityTier === "high" ? t.activityHigh : activityTier === "med" ? t.activityMedium : t.activityLow;
const postsUnit = lang === "th" ? "โพสต์" : d.post_count === 1 ? "post" : "posts";
const sectionHeadings = (headings ?? []).filter((h) => h.depth === 2);
---

<Base title={title} lang={lang} alternateHref={reportHref(otherLang)}>
  <div class="reading-progress" data-reading-progress aria-hidden="true"></div>

  <div class="report-layout">
    <div class="report-shell">
      <nav class="report-nav ui-text" aria-label="Report navigation">
        <a href={homeHref}>{t.backHome}</a>
        <a class="language-toggle" href={reportHref(otherLang)} aria-label={t.switchReport} hreflang={otherLang}>
          <span class={lang === "en" ? "active" : ""}>EN</span>
          <span aria-hidden="true">/</span>
          <span class={lang === "th" ? "active" : ""}>TH</span>
        </a>
      </nav>

      <header class="report-hero">
        <p class="report-kicker ui-text">
          <span>{t.dailyBrief}</span>
          <span class="report-kicker-dot" aria-hidden="true">/</span>
          <span class="report-kicker-date num">{d.date}</span>
        </p>

        <h1>{prettyTopic(d.topic)}</h1>
        <p class="report-deck">{prettyDate(d.date)}</p>

        <dl class="report-instruments" aria-label={t.reportMeta}>
          <div class={`instrument instrument--${activityTier}`}>
            <dt>{t.activityLabel}</dt>
            <dd>
              <span class="instrument-value num">{d.post_count}</span>
              <span class="instrument-unit">{postsUnit}</span>
              <span class={`instrument-tag instrument-tag--${activityTier}`}>{activityLabel}</span>
            </dd>
          </div>
          <div class="instrument">
            <dt>Salience</dt>
            <dd>
              <span class="instrument-value num">
                {saliencePct ?? "—"}<span class="pct">%</span>
              </span>
              <span class="meter" role="img" aria-label={t.salience(saliencePct)}>
                <span class="meter-fill" style={`--w:${saliencePct ?? 0}%`}></span>
              </span>
            </dd>
          </div>
          <div class="instrument">
            <dt>Confidence</dt>
            <dd>
              <span class="instrument-value num">
                {confidencePct ?? "—"}<span class="pct">%</span>
              </span>
              <span class="meter" role="img" aria-label={t.confidence(confidencePct)}>
                <span class="meter-fill meter-fill--soft" style={`--w:${confidencePct ?? 0}%`}></span>
              </span>
            </dd>
          </div>
        </dl>

        {d.platforms.length > 0 && (
          <ul class="report-platforms ui-text" aria-label={t.platforms}>
            {d.platforms.map((p) => (
              <li><span class="dot" aria-hidden="true"></span>{p}</li>
            ))}
          </ul>
        )}

        {(d.model || d.translated_by) && (
          <p class="report-credit ui-text">
            {d.model && <span>{t.model} <code>{d.model}</code></span>}
            {d.translated_by && <span>{t.translatedBy} <code>{d.translated_by}</code></span>}
          </p>
        )}
      </header>

      <article class="prose" lang={lang} data-article>
        <Content />
      </article>
    </div>

    {sectionHeadings.length > 1 && (
      <aside class="report-toc ui-text" aria-labelledby="toc-label">
        <p id="toc-label">{t.onThisPage}</p>
        <ol>
          {sectionHeadings.map((h, i) => (
            <li>
              <a href={`#${h.slug}`} data-toc-link>
                <span class="toc-num num">{String(i + 1).padStart(2, "0")}</span>
                <span class="toc-text">{h.text}</span>
              </a>
            </li>
          ))}
        </ol>
      </aside>
    )}
  </div>

  {hasXEmbed && (
    <script async src="https://platform.twitter.com/widgets.js" charset="utf-8"></script>
  )}

  <script is:inline>
    // Reading progress bar pinned to viewport top.
    (() => {
      const bar = document.querySelector("[data-reading-progress]");
      const article = document.querySelector("[data-article]");
      if (!bar || !article) return;
      const update = () => {
        const rect = article.getBoundingClientRect();
        const total = Math.max(1, article.offsetHeight - window.innerHeight + 200);
        const scrolled = Math.max(0, -rect.top);
        const p = Math.max(0, Math.min(1, scrolled / total));
        bar.style.transform = `scaleX(${p})`;
      };
      update();
      window.addEventListener("scroll", update, { passive: true });
      window.addEventListener("resize", update);
    })();

    // Inline citation chips: [3] / [15][33] become small mono superscript chips.
    (() => {
      const re = /\[(\d{1,3})\]/g;
      const targets = document.querySelectorAll(".prose p, .prose li, .prose dd");
      for (const el of targets) {
        const walker = document.createTreeWalker(el, NodeFilter.SHOW_TEXT, {
          acceptNode: (n) => {
            const p = n.parentElement;
            if (!p) return NodeFilter.FILTER_REJECT;
            if (p.closest("code, pre, sup.cite, a, .ndf-card-head, .ndf-engagement")) {
              return NodeFilter.FILTER_REJECT;
            }
            return NodeFilter.FILTER_ACCEPT;
          },
        });
        const nodes = [];
        while (walker.nextNode()) nodes.push(walker.currentNode);
        for (const node of nodes) {
          const text = node.nodeValue || "";
          re.lastIndex = 0;
          if (!re.test(text)) continue;
          re.lastIndex = 0;
          const frag = document.createDocumentFragment();
          let last = 0;
          let m;
          while ((m = re.exec(text))) {
            if (m.index > last) {
              frag.appendChild(document.createTextNode(text.slice(last, m.index)));
            }
            const sup = document.createElement("sup");
            sup.className = "cite num";
            sup.textContent = m[1];
            frag.appendChild(sup);
            last = m.index + m[0].length;
          }
          if (last < text.length) {
            frag.appendChild(document.createTextNode(text.slice(last)));
          }
          node.parentNode.replaceChild(frag, node);
        }
      }
    })();

    // TOC scrollspy — highlight whichever h2 sits in the top third of the viewport.
    // Top band only (rootMargin 0/-70%) so a freshly-anchored h2 (scrolled to ~top)
    // is still counted as "intersecting" and the active link updates on click.
    (() => {
      const links = document.querySelectorAll("[data-toc-link]");
      if (!links.length) return;
      const targets = [...links]
        .map((a) => {
          const id = a.getAttribute("href").slice(1);
          return document.getElementById(id);
        })
        .filter(Boolean);
      if (!targets.length) return;
      const setActive = (id) => {
        for (const l of links) {
          l.classList.toggle("active", l.getAttribute("href") === `#${id}`);
        }
      };
      const obs = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((e) => e.isIntersecting)
            .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
          if (visible.length) setActive(visible[0].target.id);
        },
        { rootMargin: "0px 0px -70% 0px", threshold: 0 },
      );
      for (const t of targets) obs.observe(t);

      // Optimistic update on direct interaction — don't wait for the observer.
      for (const a of links) {
        a.addEventListener("click", () => {
          const id = a.getAttribute("href").slice(1);
          if (id) setActive(id);
        });
      }
      window.addEventListener("hashchange", () => {
        const id = location.hash.slice(1);
        if (id) setActive(id);
      });
      // Initial: respect any hash already in the URL.
      if (location.hash) setActive(location.hash.slice(1));
    })();
  </script>

  <style>
    /* ---- Layout shell ---- */
    .report-layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: var(--space-md);
      align-items: start;
    }
    @media (min-width: 1100px) {
      .report-layout {
        grid-template-columns: minmax(0, 1fr) 14rem;
        column-gap: var(--space-lg);
      }
    }

    .report-shell {
      min-width: 0;
      max-width: 70rem;
    }

    /* ---- Reading progress ---- */
    .reading-progress {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      height: 2px;
      background: var(--accent);
      transform: scaleX(0);
      transform-origin: left center;
      z-index: 50;
      pointer-events: none;
      transition: transform 80ms linear;
      opacity: 0.85;
    }

    /* ---- Top nav ---- */
    .report-nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 0.5rem 1rem;
      margin-bottom: var(--space-md);
      color: var(--soft-ink);
      font-size: var(--step--1);
      font-weight: 700;
      line-height: 1.4;
    }
    .report-nav a {
      min-height: 44px;
      display: inline-flex;
      align-items: center;
      text-decoration: none;
      border-bottom: 1px solid var(--line);
    }
    .language-toggle {
      gap: 0.42rem;
      color: var(--ink);
    }
    .language-toggle .active {
      color: var(--accent-ink);
      font-weight: 800;
    }

    /* ---- Hero ---- */
    .report-hero {
      position: relative;
      max-width: 64ch;
      margin: 0 0 var(--space-lg);
      padding: var(--space-md) 0 var(--space-md);
      border-bottom: 1px solid var(--line);
      isolation: isolate;
      animation: hero-in 620ms cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    .report-hero::before {
      content: "";
      position: absolute;
      inset: -1.5rem -2rem 0;
      background:
        radial-gradient(
          ellipse 55% 70% at 12% -10%,
          color-mix(in oklch, var(--accent), transparent 90%),
          transparent 60%
        ),
        radial-gradient(
          ellipse 40% 60% at 90% 110%,
          color-mix(in oklch, var(--accent-ink), transparent 94%),
          transparent 65%
        );
      pointer-events: none;
      z-index: -1;
    }
    .report-hero::after {
      content: "";
      position: absolute;
      bottom: -1px;
      left: 0;
      width: 4rem;
      height: 1px;
      background: var(--accent);
    }

    .report-kicker {
      display: inline-flex;
      align-items: baseline;
      flex-wrap: wrap;
      gap: 0.55rem;
      margin: 0 0 var(--space-sm);
      font-family: var(--font-mono);
      font-size: 0.74rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent-ink);
    }
    .report-kicker-dot { color: var(--faint-ink); }
    .report-kicker-date {
      color: var(--soft-ink);
      letter-spacing: 0.06em;
    }

    .report-hero h1 {
      margin: 0;
      font-family: var(--font-display);
      font-size: var(--step-3);
      font-weight: 650;
      letter-spacing: -0.012em;
      line-height: 1.02;
      color: var(--ink);
      text-wrap: balance;
    }

    .report-deck {
      margin: var(--space-xs) 0 0;
      color: var(--soft-ink);
      font-family: var(--font-body);
      font-size: 0.95rem;
      font-style: italic;
      line-height: 1.5;
    }

    /* ---- Instruments grid ---- */
    .report-instruments {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr));
      gap: var(--space-sm) var(--space-md);
      margin: var(--space-md) 0 0;
      padding: 0;
    }

    .instrument {
      position: relative;
      padding-top: 0.7rem;
      border-top: 1px solid var(--line);
    }
    .instrument::before {
      content: "";
      position: absolute;
      top: -1px;
      left: 0;
      width: 1.4rem;
      height: 1px;
      background: var(--accent);
    }
    .instrument dt {
      margin: 0 0 0.4rem;
      font-family: var(--font-ui);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--soft-ink);
    }
    .instrument dd {
      margin: 0;
      display: flex;
      align-items: baseline;
      flex-wrap: wrap;
      gap: 0.3rem 0.55rem;
    }
    .instrument-value {
      font-family: var(--font-display);
      font-size: var(--step-2);
      font-weight: 600;
      line-height: 1;
      color: var(--ink);
      letter-spacing: -0.01em;
    }
    .instrument-value .pct {
      font-size: 0.5em;
      color: var(--soft-ink);
      margin-left: 0.12em;
      font-weight: 500;
      letter-spacing: 0;
    }
    .instrument-unit {
      font-family: var(--font-ui);
      font-size: 0.78rem;
      color: var(--soft-ink);
      letter-spacing: 0.02em;
    }
    .instrument-tag {
      margin-left: auto;
      display: inline-flex;
      align-items: center;
      padding: 0.18em 0.55em;
      font-family: var(--font-ui);
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      border: 1px solid var(--line);
      color: var(--soft-ink);
      white-space: nowrap;
    }
    .instrument-tag--high {
      color: var(--accent-ink);
      border-color: color-mix(in oklch, var(--accent), transparent 55%);
      background: color-mix(in oklch, var(--accent), transparent 90%);
    }
    .instrument-tag--med {
      color: var(--ink);
    }
    .instrument-tag--low {
      color: var(--faint-ink);
    }

    .meter {
      flex: 1 1 100%;
      display: block;
      height: 4px;
      margin-top: 0.45rem;
      background: color-mix(in oklch, var(--line), transparent 35%);
      position: relative;
      overflow: hidden;
    }
    .meter-fill {
      position: absolute;
      inset: 0 auto 0 0;
      width: 0;
      background: var(--accent);
      animation: meter-in 950ms cubic-bezier(0.16, 1, 0.3, 1) 120ms both;
    }
    .meter-fill--soft {
      background: color-mix(in oklch, var(--accent-ink), transparent 30%);
    }

    /* ---- Platforms ---- */
    .report-platforms {
      list-style: none;
      margin: var(--space-md) 0 0;
      padding: 0;
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem 0.55rem;
      font-size: 0.78rem;
      color: var(--soft-ink);
    }
    .report-platforms li {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.22rem 0.6rem;
      border: 1px solid var(--hairline);
      border-radius: 999px;
      background: color-mix(in oklch, var(--paper), transparent 20%);
      letter-spacing: 0.02em;
    }
    .report-platforms .dot {
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: var(--accent);
    }

    /* ---- Credit ---- */
    .report-credit {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem 1.1rem;
      margin: var(--space-sm) 0 0;
      font-size: 0.74rem;
      color: var(--faint-ink);
    }
    .report-credit code {
      background: transparent;
      border: 0;
      padding: 0;
      color: var(--soft-ink);
      font-size: 0.78rem;
    }

    /* ---- TOC sticky rail ---- */
    .report-toc {
      display: none;
    }
    @media (min-width: 1100px) {
      .report-toc {
        display: block;
        position: sticky;
        top: var(--space-md);
        align-self: start;
        padding-top: var(--space-md);
        max-height: calc(100vh - var(--space-md) * 2);
        overflow-y: auto;
      }
    }
    .report-toc p {
      margin: 0 0 0.75rem;
      padding-bottom: 0.55rem;
      font-family: var(--font-ui);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--soft-ink);
      border-bottom: 1px solid var(--line);
      position: relative;
    }
    .report-toc p::after {
      content: "";
      position: absolute;
      left: 0;
      bottom: -1px;
      width: 1.4rem;
      height: 1px;
      background: var(--accent);
    }
    .report-toc ol {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .report-toc li { margin: 0; }
    .report-toc a {
      display: grid;
      grid-template-columns: 1.7rem 1fr;
      align-items: baseline;
      gap: 0.5rem;
      padding: 0.35rem 0.5rem 0.35rem 0.55rem;
      margin-left: -0.55rem;
      text-decoration: none;
      color: var(--soft-ink);
      font-size: 0.82rem;
      line-height: 1.35;
      border-left: 2px solid transparent;
      transition: color 180ms ease, border-color 180ms ease, background 180ms ease;
    }
    .report-toc a:hover { color: var(--ink); }
    .report-toc a.active {
      color: var(--accent-ink);
      border-left-color: var(--accent);
      background: color-mix(in oklch, var(--accent), transparent 94%);
    }
    .report-toc .toc-num {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      font-weight: 500;
      color: var(--faint-ink);
      letter-spacing: 0;
    }
    .report-toc a.active .toc-num { color: var(--accent); }
    .report-toc[lang="th"] a,
    html[lang="th"] .report-toc a { line-height: 1.55; }

    /* ---- Prose ---- */
    .prose {
      min-width: 0;
      max-width: 68ch;
      margin: 0;
      font-family: var(--font-body);
      font-size: var(--step-0);
      line-height: 1.78;
      animation: report-in 620ms cubic-bezier(0.16, 1, 0.3, 1) 80ms both;
    }
    .prose[lang="th"] {
      font-family: "Noto Serif Thai", var(--font-body);
      line-height: 1.9;
    }

    .prose :global(h1),
    .prose :global(h2),
    .prose :global(h3) {
      font-family: var(--font-display);
      letter-spacing: 0;
      color: var(--ink);
    }
    .prose[lang="th"] :global(h1),
    .prose[lang="th"] :global(h2),
    .prose[lang="th"] :global(h3) {
      font-family: "Noto Serif Thai", var(--font-display);
    }

    .prose :global(h1) {
      margin: 0 0 var(--space-lg);
      font-size: var(--step-3);
      font-weight: 650;
      line-height: 1.04;
    }
    /* Hero already prints the topic name, so suppress the body H1. */
    .prose :global(h1):first-child { display: none; }

    .prose { counter-reset: section; }

    .prose :global(h2) {
      counter-increment: section;
      position: relative;
      margin: var(--space-xl) 0 var(--space-sm);
      padding-top: 1.7rem;
      font-family: var(--font-display);
      font-size: var(--step-2);
      font-weight: 600;
      line-height: 1.08;
      letter-spacing: -0.008em;
      text-wrap: balance;
      scroll-margin-top: var(--space-md);
    }
    .prose :global(h2)::after {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(
        90deg,
        var(--accent) 0,
        var(--accent) 2.6rem,
        var(--line) 2.6rem,
        var(--line) 100%
      );
    }
    .prose :global(h2)::before {
      content: "§ " counter(section, decimal-leading-zero);
      display: block;
      margin-bottom: 0.5rem;
      font-family: var(--font-mono);
      font-feature-settings: "ss01" 1;
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.04em;
      color: var(--accent-ink);
      line-height: 1;
    }
    .prose :global(h2):first-of-type {
      margin-top: 0;
    }
    /* TL;DR lead block — tinted strip and tighter cadence. */
    .prose :global(h2):first-of-type + :global(ul),
    .prose :global(h2):first-of-type + :global(p) {
      padding: var(--space-md);
      margin-block: 0 var(--space-md);
      background: linear-gradient(
        180deg,
        color-mix(in oklch, var(--accent), transparent 92%),
        color-mix(in oklch, var(--accent), transparent 96%)
      );
      border-left: 2px solid var(--accent);
      border-radius: 2px;
      font-size: 1.02em;
      line-height: 1.7;
    }
    .prose :global(h2):first-of-type + :global(ul) :global(li) {
      margin: 0.45rem 0;
    }

    .prose :global(h3) {
      margin: var(--space-lg) 0 var(--space-xs);
      font-family: var(--font-display);
      font-size: var(--step-1);
      font-weight: 600;
      line-height: 1.2;
      color: var(--accent-ink);
    }

    .prose :global(p),
    .prose :global(ul),
    .prose :global(ol),
    .prose :global(blockquote),
    .prose :global(pre),
    .prose :global(table) {
      margin-top: 0;
      margin-bottom: var(--space-md);
    }
    .prose :global(p),
    .prose :global(li),
    .prose :global(blockquote) {
      overflow-wrap: break-word;
    }
    .prose :global(ul),
    .prose :global(ol) { padding-left: 1.4em; }
    .prose :global(li) {
      padding-left: 0.35em;
      margin: 0.55rem 0;
      line-height: 1.72;
    }
    .prose[lang="th"] :global(li) { line-height: 1.88; }
    .prose :global(li::marker) {
      color: var(--accent);
      font-weight: 700;
    }
