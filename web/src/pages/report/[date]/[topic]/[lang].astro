---
import { getCollection, render } from "astro:content";
import Base from "../../../../layouts/Base.astro";
import ReportShare from "../../../../components/ReportShare.astro";
import { prettyTopic, extractTldr, shortDate, readingMinutes, boldLeadIn } from "../../../../lib/format";
import { UI, type Lang } from "../../../../lib/i18n";
import { bangkokToday, relativeDate } from "../../../../lib/relative-date";

export async function getStaticPaths() {
  const all = await getCollection("reports");
  // Same-topic prev/next: group by topic+lang, sort by date, attach nearest
  // older/newer date that also has THIS topic (skips days where it's absent).
  const groups = new Map<string, typeof all>();
  for (const e of all) {
    const key = `${e.data.topic}|${e.data.lang}`;
    const arr = groups.get(key) ?? [];
    arr.push(e);
    groups.set(key, arr);
  }
  for (const arr of groups.values()) {
    arr.sort((a, b) => (a.data.date < b.data.date ? -1 : a.data.date > b.data.date ? 1 : 0));
  }
  return all.map((entry) => {
    const arr = groups.get(`${entry.data.topic}|${entry.data.lang}`)!;
    const i = arr.findIndex((e) => e.data.date === entry.data.date);
    const prev = i > 0 ? arr[i - 1] : null;
    const next = i >= 0 && i < arr.length - 1 ? arr[i + 1] : null;
    return {
      params: { date: entry.data.date, topic: entry.data.topic, lang: entry.data.lang },
      props: {
        entry,
        prevDate: prev?.data.date ?? null,
        nextDate: next?.data.date ?? null,
        prevSalience: prev?.data.salience ?? null,
      },
    };
  });
}

const { entry, prevDate, nextDate, prevSalience } = Astro.props;
const { Content, headings } = await render(entry);
const d = entry.data;
const hasXEmbed = entry.body?.includes("twitter-tweet") ?? false;
const lang = d.lang as Lang;
const otherLang: Lang = lang === "th" ? "en" : "th";
const t = UI[lang];
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const reportHref = (targetLang: Lang) => `${base}/report/${d.date}/${d.topic}/${targetLang}`;
const homeHref = lang === "th" ? `${base}/th/` : `${base}/`;
const title = `${prettyTopic(d.topic)} - ${d.date}`;
const pct = (value?: number | null) => (value == null ? null : Math.round(value * 100));
const saliencePct = pct(d.salience);
const confidencePct = pct(d.confidence);
const activityTier: "high" | "med" | "low" =
  d.post_count >= 40 ? "high" : d.post_count >= 15 ? "med" : "low";
const activityLabel =
  activityTier === "high" ? t.activityHigh : activityTier === "med" ? t.activityMedium : t.activityLow;
const postsUnit = lang === "th" ? "โพสต์" : d.post_count === 1 ? "post" : "posts";
const sectionHeadings = (headings ?? []).filter((h) => h.depth === 2);
const tldrBullets = extractTldr(entry.body ?? "");
const today = bangkokToday();
const rel = relativeDate(d.date, lang, today);
const canonicalUrl = new URL(`/report/${d.date}/${d.topic}/${lang}`, Astro.site).href;
const ogImageUrl = new URL(`/og/report/${d.date}/${d.topic}/${lang}.png`, Astro.site).href;
// Note: OG image path matches the [..route].ts endpoint key pattern (already .png)
const rssHref = `${base}${lang === "th" ? "/th" : ""}/rss/${d.topic}.xml`;

// --- R2 metadata strip ---
const body = entry.body ?? "";
const wordCount = body.trim() ? body.trim().split(/\s+/).length : 0;
const minutes = readingMinutes(body, lang);
// "sources" = distinct inline [n] citation markers; honest fallback to post_count.
const citeNums = new Set<string>();
for (const m of body.matchAll(/\[(\d{1,3})\]/g)) citeNums.add(m[1]);
const sourceCount = citeNums.size;
// Salience trend vs the previous same-topic run (no glyph if no prior run).
const trend: "up" | "down" | "steady" | null =
  d.salience != null && prevSalience != null
    ? d.salience > prevSalience + 0.02
      ? "up"
      : d.salience < prevSalience - 0.02
        ? "down"
        : "steady"
    : null;
const trendGlyph = trend === "up" ? "↑" : trend === "down" ? "↓" : trend === "steady" ? "→" : "";

// --- R2 prev/next edition foot ---
const editionHref = (date: string) => `${base}/report/${date}/${d.topic}/${lang}`;
const frontHref = `${homeHref}#${d.date}`;

// --- Headline from the lead TL;DR bullet: the H1 should BE the story, not the
// section name (CEO note: "doesn't point out the real detail"). The first TL;DR
// bullet's lead clause becomes the headline; its trailing clause becomes the
// standfirst/dek. Remaining bullets fill KEY POINTS so nothing is duplicated.
// Falls back to the topic name when a report has no TL;DR. ---
const firstSplit = tldrBullets.length ? boldLeadIn(tldrBullets[0]) : null;
// Strip the trailing clause separator ("— " / ": ") left on the lead clause so
// the headline doesn't dangle a dash; capitalize the dek's first letter so the
// standfirst reads as its own sentence.
const headline = firstSplit
  ? firstSplit.lead.replace(/\s*[—:-]\s*$/, "").trim()
  : prettyTopic(d.topic);
const rawDek = firstSplit ? firstSplit.rest.trim() : "";
const standfirst = rawDek ? rawDek.charAt(0).toUpperCase() + rawDek.slice(1) : null;
const restLeads = tldrBullets.slice(1).map((b) => boldLeadIn(b));
const kickerYear = d.date.slice(0, 4);
---

<Base title={title} lang={lang} alternateHref={reportHref(otherLang)} image={ogImageUrl} ogType="article">
  <div class="reading-progress" data-reading-progress aria-hidden="true"></div>

  <div class="report-layout">
    <div class="report-shell">
      <nav class="report-nav ui-text" aria-label="Report navigation" data-pagefind-ignore>
        <a href={homeHref}>← {t.backHome}</a>
        <span class="crumb-sep" aria-hidden="true">/</span>
        <span class="crumb-topic">{prettyTopic(d.topic)}</span>
      </nav>

      <header class="report-hero">
        <p class="report-kicker ui-text">
          <span class="rk-topic" data-pagefind-meta="title" data-pagefind-filter="topic">{prettyTopic(d.topic)}</span>
          <span class="report-kicker-dot" aria-hidden="true">·</span>
          <span class="report-kicker-date num" data-pagefind-meta="date" data-pagefind-filter="date">{shortDate(d.date, lang)} {kickerYear}</span>
          {rel.label && <span class={`date-badge date-badge-${rel.kind}`}>{rel.label}</span>}
        </p>

        <h1>{headline}</h1>

        {standfirst && <p class="report-dek">{standfirst}</p>}

        <div class="metastrip num" aria-label={t.reportMeta} data-pagefind-ignore>
          <span>{t.minRead(minutes)}</span>
          {sourceCount > 0 && (
            <Fragment>
              <span class="ms-dot" aria-hidden="true">·</span>
              <span>{sourceCount} {t.sourcesUnit(sourceCount)}</span>
            </Fragment>
          )}
          <span class="ms-dot" aria-hidden="true">·</span>
          <span>{d.post_count} {postsUnit}</span>
          {saliencePct != null && (
            <Fragment>
              <span class="ms-dot" aria-hidden="true">·</span>
              <span>{activityLabel}{trendGlyph && (
                <span class={trend === "up" ? "ms-up" : "ms-flat"}> {trendGlyph}</span>
              )}</span>
            </Fragment>
          )}
          <span class="metastrip-langs ui-text">
            <a class={lang === "en" ? "on" : ""} href={reportHref("en")} hreflang="en">EN</a>
            <span aria-hidden="true">|</span>
            <a class={lang === "th" ? "on" : ""} href={reportHref("th")} hreflang="th" lang="th">ไทย</a>
          </span>
        </div>

        {restLeads.length > 0 && (
          <section class="keypoints" aria-label={t.keyPoints}>
            <p class="keypoints-lbl eyebrow">{t.keyPoints}</p>
            <ul>
              {restLeads.map(({ lead, rest }) => <li><b>{lead}</b>{rest}</li>)}
            </ul>
          </section>
        )}

        {d.platforms.length > 0 && (
          <ul class="report-platforms ui-text" aria-label={t.platforms} data-pagefind-ignore>
            {d.platforms.map((p) => (
              <li><span class="dot" aria-hidden="true"></span>{p}</li>
            ))}
          </ul>
        )}

        {(d.model || d.translated_by) && (
          <p class="report-credit ui-text">
            {d.model && <span>{t.model} <code>{d.model}</code></span>}
            {d.translated_by && <span>{t.translatedBy} <code>{d.translated_by}</code></span>}
          </p>
        )}

      </header>

      {tldrBullets.length > 0 ? (
        <details class="mobile-collapse" data-mobile-collapse open>
          <summary class="ui-text" data-pagefind-ignore>{t.readFullReport}</summary>
          <article class="prose" lang={lang} data-article data-tldr-hoisted="true" data-pagefind-body>
            <Content />
          </article>
        </details>
      ) : (
        <article class="prose" lang={lang} data-article data-pagefind-body>
          <Content />
        </article>
      )}
    </div>

    {sectionHeadings.length > 1 && (
      <aside class="report-toc ui-text" aria-labelledby="toc-label" data-pagefind-ignore>
        <p id="toc-label">{t.onThisPage}</p>
        <ol>
          {sectionHeadings.map((h, i) => (
            <li>
              <a href={`#${h.slug}`} data-toc-link>
                <span class="toc-num num">{String(i + 1).padStart(2, "0")}</span>
                <span class="toc-text">{h.text}</span>
              </a>
            </li>
          ))}
        </ol>
      </aside>
    )}
  </div>

  <footer class="r-foot ui-text" data-pagefind-ignore>
    <nav class="editions" aria-label={t.switchReport}>
      {prevDate && (
        <a class="ed-prev" href={editionHref(prevDate)} rel="prev" aria-label={t.prevReport}>
          ← <span class="num">{shortDate(prevDate, lang)}</span>
        </a>
      )}
      <span class="ed-cur">
        {prettyTopic(d.topic)} · <span class="num">{shortDate(d.date, lang)}</span>
        {!nextDate && <span class="ed-latest"> · {t.latestEdition}</span>}
      </span>
      {nextDate && (
        <a class="ed-next" href={editionHref(nextDate)} rel="next" aria-label={t.nextReport}>
          <span class="num">{shortDate(nextDate, lang)}</span> →
        </a>
      )}
      <a class="frontlink" href={frontHref}>↑ <span class="num">{shortDate(d.date, lang)}</span> {t.frontPage}</a>
    </nav>
    <ReportShare title={title} url={canonicalUrl} lang={lang} rssHref={rssHref} compact={true} />
  </footer>

  <div
    class="sticky-share-bar"
    data-sticky-bar
    data-pagefind-ignore
    hidden
    aria-hidden="true"
    aria-label={t.shareTitle}
  >
    <ReportShare title={title} url={canonicalUrl} lang={lang} rssHref={rssHref} compact={true} />
  </div>

  {hasXEmbed && (
    <script async src="https://platform.twitter.com/widgets.js" charset="utf-8"></script>
  )}

  <script is:inline>
    // Reading progress bar pinned to viewport top.
    (() => {
      const bar = document.querySelector("[data-reading-progress]");
      const article = document.querySelector("[data-article]");
      if (!bar || !article) return;
      const update = () => {
        const rect = article.getBoundingClientRect();
        const total = Math.max(1, article.offsetHeight - window.innerHeight + 200);
        const scrolled = Math.max(0, -rect.top);
        const p = Math.max(0, Math.min(1, scrolled / total));
        bar.style.transform = `scaleX(${p})`;
      };
      update();
      window.addEventListener("scroll", update, { passive: true });
      window.addEventListener("resize", update);
    })();

    // Strip inline citation markers ([3], [15][48], ...). The pipeline emits
    // marker numbers that run past the Raw Sources row count (e.g. [60] with ~30
    // rows) and the table has no per-row numbering, so the markers point nowhere
    // and just clutter the prose (CEO note). Remove them cleanly, tidying the
    // leftover space before punctuation. Pipeline stays untouched (web-only fix).
    (() => {
      const re = /\s*\[\d{1,3}\](?:\s*\[\d{1,3}\])*/g;
      const targets = document.querySelectorAll(".prose p, .prose li, .prose dd, .prose td");
      for (const el of targets) {
        const walker = document.createTreeWalker(el, NodeFilter.SHOW_TEXT, {
          acceptNode: (n) => {
            const p = n.parentElement;
            if (!p) return NodeFilter.FILTER_REJECT;
            if (p.closest("code, pre, a")) return NodeFilter.FILTER_REJECT;
            return re.test(n.nodeValue || "") ? NodeFilter.FILTER_ACCEPT : NodeFilter.FILTER_REJECT;
          },
        });
        const nodes = [];
        while (walker.nextNode()) nodes.push(walker.currentNode);
        for (const node of nodes) {
          // Drop the markers; if one sat before a . , ; : keep the punctuation tight.
          node.nodeValue = (node.nodeValue || "")
            .replace(re, (m, off, s) => (/^[.,;:!?)]/.test(s.slice(off + m.length)) ? "" : " "))
            .replace(/\s{2,}/g, " ");
        }
      }
    })();

    // Humanize raw engagement cells in the Raw Sources table: "^4465 c0" is
    // scraper shorthand (^=upvotes/likes, c=comments) that reads as gibberish.
    // Rewrite to "4,465 likes · 0 comments" (compact "12.3k" past 10k). web-only.
    (() => {
      const reEng = /^\s*\^(\d+)\s+c(\d+)\s*$/;
      const fmt = (n) => (n >= 10000 ? (n / 1000).toFixed(1).replace(/\.0$/, "") + "k" : n.toLocaleString("en-US"));
      const isTh = document.documentElement.lang === "th";
      const L = isTh ? { up: "ไลก์", c: "คอมเมนต์" } : { up: "likes", c: "comments" };
      for (const td of document.querySelectorAll(".prose td")) {
        const m = (td.textContent || "").match(reEng);
        if (!m) continue;
        const up = Number(m[1]), c = Number(m[2]);
        td.textContent = `${fmt(up)} ${L.up} · ${fmt(c)} ${L.c}`;
        td.classList.add("eng-cell");
      }
    })();

    // TOC scrollspy — highlight whichever h2 sits in the top third of the viewport.
    // Top band only (rootMargin 0/-70%) so a freshly-anchored h2 (scrolled to ~top)
    // is still counted as "intersecting" and the active link updates on click.
    (() => {
      const links = document.querySelectorAll("[data-toc-link]");
      if (!links.length) return;
      const targets = [...links]
        .map((a) => {
          const id = a.getAttribute("href").slice(1);
          return document.getElementById(id);
        })
        .filter(Boolean);
      if (!targets.length) return;
      const setActive = (id) => {
        for (const l of links) {
          const on = l.getAttribute("href") === `#${id}`;
          l.classList.toggle("active", on);
          if (on) l.setAttribute("aria-current", "true");
          else l.removeAttribute("aria-current");
        }
      };
      const obs = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((e) => e.isIntersecting)
            .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
          if (visible.length) setActive(visible[0].target.id);
        },
        { rootMargin: "0px 0px -70% 0px", threshold: 0 },
      );
      for (const t of targets) obs.observe(t);

      // Optimistic update on direct interaction — don't wait for the observer.
      for (const a of links) {
        a.addEventListener("click", () => {
          const id = a.getAttribute("href").slice(1);
          if (id) setActive(id);
        });
      }
      window.addEventListener("hashchange", () => {
        const id = location.hash.slice(1);
        if (id) setActive(id);
      });
      // Initial: respect any hash already in the URL.
      if (location.hash) setActive(location.hash.slice(1));
    })();

    // Copy-link + native share handler for all [data-copy-link] buttons on this page.
    (() => {
      document.querySelectorAll("[data-copy-link]").forEach((btn) => {
        btn.addEventListener("click", async () => {
          const url = btn.dataset.url || location.href;
          const labelEl = btn.querySelector(".copy-label");
          const copied = btn.dataset.labelCopied || "Copied";
          const copy = btn.dataset.labelCopy || "Copy link";
          try {
            if (navigator.share) {
              await navigator.share({ title: document.title, url });
            } else {
              await navigator.clipboard.writeText(url);
            }
          } catch {
            try { await navigator.clipboard.writeText(url); } catch (_) {}
          }
          if (labelEl) labelEl.textContent = copied;
          btn.setAttribute("aria-label", copied);
          setTimeout(() => {
            if (labelEl) labelEl.textContent = copy;
            btn.setAttribute("aria-label", copy);
          }, 1800);
        });
      });
    })();

    // Sticky share bar: show after .report-instruments leaves viewport, hide near footer.
    (() => {
      const bar = document.querySelector("[data-sticky-bar]");
      if (!bar) return;
      const trigger = document.querySelector(".metastrip");
      const footer = document.querySelector(".site-footer");
      let triggerGone = false;
      let footerVisible = false;
      function updateBar() {
        const show = triggerGone && !footerVisible;
        bar.hidden = !show;
        bar.setAttribute("aria-hidden", show ? "false" : "true");
      }
      if (trigger) {
        new IntersectionObserver(([e]) => {
          triggerGone = !e.isIntersecting;
          updateBar();
        }, { threshold: 0 }).observe(trigger);
      }
      if (footer) {
        new IntersectionObserver(([e]) => {
          footerVisible = e.isIntersecting;
          updateBar();
        }, { threshold: 0.05 }).observe(footer);
      }
    })();

    // Hide the original TL;DR heading + its following list when the card is hoisted above.
    (() => {
      const prose = document.querySelector('.prose[data-tldr-hoisted="true"]');
      if (!prose) return;
      for (const h2 of prose.querySelectorAll("h2")) {
        if (/^(TL;DR|สรุป)$/i.test((h2.textContent || "").trim())) {
          const next = h2.nextElementSibling;
          h2.remove();
          if (next && (next.tagName === "UL" || next.tagName === "P")) next.remove();
          break;
        }
      }
    })();

    // Mobile collapse: on desktop (≥721px) force-open the details so prose always shows.
    (() => {
      const details = document.querySelector("details[data-mobile-collapse]");
      if (!details) return;
      if (window.innerWidth >= 721) {
        details.open = true;
      }
    })();
  </script>

  <style>
    /* ---- Layout shell ---- */
    .report-layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: var(--space-md);
      align-items: start;
    }
    @media (min-width: 1100px) {
      .report-layout {
        grid-template-columns: minmax(0, 1fr) 14rem;
        column-gap: var(--space-lg);
      }
    }

    .report-shell {
      min-width: 0;
      max-width: 70rem;
    }

    /* ---- Reading progress ---- */
    .reading-progress {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      height: 2px;
      background: var(--accent);
      transform: scaleX(0);
      transform-origin: left center;
      z-index: 50;
      pointer-events: none;
      transition: transform 80ms linear;
      opacity: 0.85;
    }

    /* ---- Top nav ---- */
    .report-nav {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.25rem 0.6rem;
      margin-bottom: var(--space-md);
      color: var(--soft-ink);
      font-size: var(--step--1);
      font-weight: 600;
      letter-spacing: 0.02em;
      line-height: 1.4;
    }
    .report-nav a {
      min-height: 44px;
      display: inline-flex;
      align-items: center;
      text-decoration: none;
      color: var(--soft-ink);
      transition: color 0.15s ease;
    }
    .report-nav a:hover { color: var(--accent-ink); }
    .crumb-sep { color: var(--faint-ink); }
    .crumb-topic { color: var(--ink); }

    /* ---- Metadata strip (R2 §4.5) ---- */
    .metastrip {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.45rem 0.7rem;
      margin: var(--space-sm) 0 0;
      padding: 0.65rem 0;
      border-top: var(--rule-section);
      border-bottom: var(--rule-faint);
      font-family: var(--font-mono);
      font-feature-settings: "tnum" 1, "ss01" 1;
      font-size: var(--step--1);
      color: var(--faint-ink);
      letter-spacing: -0.005em;
    }
    .metastrip .ms-dot { color: var(--hairline); }
    .metastrip .ms-up { color: var(--accent-ink); font-weight: 700; }
    .metastrip .ms-flat { color: var(--faint-ink); }
    .metastrip-langs {
      margin-left: auto;
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-family: var(--font-ui);
      letter-spacing: 0.02em;
      color: var(--faint-ink);
    }
    .metastrip-langs a {
      min-height: 32px;
      display: inline-flex;
      align-items: center;
      text-decoration: none;
      color: var(--soft-ink);
    }
    .metastrip-langs a:hover { color: var(--accent-ink); }
    .metastrip-langs a.on { color: var(--accent-ink); font-weight: 700; }

    /* ---- Hero ---- */
    .report-hero {
      position: relative;
      max-width: 64ch;
      margin: 0 0 var(--space-lg);
      padding: var(--space-md) 0 var(--space-md);
      border-bottom: 1px solid var(--line);
      isolation: isolate;
      animation: hero-in 620ms cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    .report-hero::before {
      content: "";
      position: absolute;
      inset: -1.5rem -2rem 0;
      background:
        radial-gradient(
          ellipse 55% 70% at 12% -10%,
          color-mix(in oklch, var(--accent), transparent 90%),
          transparent 60%
        ),
        radial-gradient(
          ellipse 40% 60% at 90% 110%,
          color-mix(in oklch, var(--accent-ink), transparent 94%),
          transparent 65%
        );
      pointer-events: none;
      z-index: -1;
    }
    .report-hero::after {
      content: "";
      position: absolute;
      bottom: -1px;
      left: 0;
      width: 4rem;
      height: 1px;
      background: var(--accent);
    }

    .report-kicker {
      display: inline-flex;
      align-items: baseline;
      flex-wrap: wrap;
      gap: 0.55rem;
      margin: 0 0 var(--space-sm);
      font-family: var(--font-mono);
      font-size: 0.74rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent-ink);
    }
    .report-kicker .rk-topic { color: var(--accent-ink); font-weight: 700; }
    .report-kicker-dot { color: var(--faint-ink); }
    .report-kicker-date {
      color: var(--soft-ink);
      letter-spacing: 0.06em;
    }

    .report-hero h1 {
      margin: 0;
      font-family: var(--font-display);
      font-size: var(--step-3);
      font-weight: 650;
      letter-spacing: -0.012em;
      line-height: 1.08;
      color: var(--ink);
      text-wrap: balance;
      max-width: 20ch;
    }
    .report-hero[lang="th"] h1,
    html[lang="th"] .report-hero h1 {
      font-family: "Noto Serif Thai", var(--font-display);
      line-height: 1.35;
    }

    /* Standfirst / dek — the trailing clause of the lead story, Newsreader serif,
       sits under the headline like a newspaper sub-deck (clarity, CEO note). */
    .report-dek {
      margin: var(--space-sm) 0 0;
      max-width: var(--measure-dek, 56ch);
      font-family: var(--font-body);
      font-size: var(--step-1);
      font-weight: 400;
      line-height: 1.4;
      color: var(--soft-ink);
      text-wrap: pretty;
    }
    .report-hero[lang="th"] .report-dek,
    html[lang="th"] .report-dek {
      font-family: "Noto Serif Thai", var(--font-body);
      line-height: 1.6;
    }
    /* R4 shared-element morph: same-named hero across report editions morphs on
       prev/next navigation (cross-document VT). Home→report names the clicked
       teaser at pageswap (Base.astro). Gated under no-preference. */
    @media (prefers-reduced-motion: no-preference) {
      .report-hero h1 { view-transition-name: hero-title; }
    }

    /* ---- Instruments grid ---- */
    .report-instruments {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr));
      gap: var(--space-sm) var(--space-md);
      margin: var(--space-md) 0 0;
      padding: 0;
    }

    .instrument {
      position: relative;
      padding-top: 0.7rem;
      border-top: 1px solid var(--line);
    }
    .instrument::before {
      content: "";
      position: absolute;
      top: -1px;
      left: 0;
      width: 1.4rem;
      height: 1px;
      background: var(--accent);
    }
    .instrument dt {
      margin: 0 0 0.4rem;
      font-family: var(--font-ui);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--soft-ink);
    }
    .instrument dd {
      margin: 0;
      display: flex;
      align-items: baseline;
      flex-wrap: wrap;
      gap: 0.3rem 0.55rem;
    }
    .instrument-value {
      font-family: var(--font-display);
      font-size: var(--step-2);
      font-weight: 600;
      line-height: 1;
      color: var(--ink);
      letter-spacing: -0.01em;
    }
    .instrument-value .pct {
      font-size: 0.5em;
      color: var(--soft-ink);
      margin-left: 0.12em;
      font-weight: 500;
      letter-spacing: 0;
    }
    .instrument-unit {
      font-family: var(--font-ui);
      font-size: 0.78rem;
      color: var(--soft-ink);
      letter-spacing: 0.02em;
    }
    .instrument-tag {
      margin-left: auto;
      display: inline-flex;
      align-items: center;
      padding: 0.18em 0.55em;
      font-family: var(--font-ui);
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      border: 1px solid var(--line);
      color: var(--soft-ink);
      white-space: nowrap;
    }
    .instrument-tag--high {
      color: var(--accent-ink);
      border-color: color-mix(in oklch, var(--accent), transparent 55%);
      background: color-mix(in oklch, var(--accent), transparent 90%);
    }
    .instrument-tag--med {
      color: var(--ink);
    }
    .instrument-tag--low {
      color: var(--faint-ink);
    }

    .meter {
      flex: 1 1 100%;
      display: block;
      height: 4px;
      margin-top: 0.45rem;
      background: color-mix(in oklch, var(--line), transparent 35%);
      position: relative;
      overflow: hidden;
    }
    .meter-fill {
      position: absolute;
      inset: 0 auto 0 0;
      width: 0;
      background: var(--accent);
      animation: meter-in 950ms cubic-bezier(0.16, 1, 0.3, 1) 120ms both;
    }
    .meter-fill--soft {
      background: color-mix(in oklch, var(--accent-ink), transparent 30%);
    }

    /* ---- Platforms ---- */
    .report-platforms {
      list-style: none;
      margin: var(--space-md) 0 0;
      padding: 0;
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem 0.55rem;
      font-size: 0.78rem;
      color: var(--soft-ink);
    }
    .report-platforms li {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.22rem 0.6rem;
      border: 1px solid var(--hairline);
      border-radius: 999px;
      background: color-mix(in oklch, var(--paper), transparent 20%);
      letter-spacing: 0.02em;
    }
    .report-platforms .dot {
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: var(--accent);
    }

    /* ---- Credit ---- */
    .report-credit {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem 1.1rem;
      margin: var(--space-sm) 0 0;
      font-size: 0.74rem;
      color: var(--faint-ink);
    }
    .report-credit code {
      background: transparent;
      border: 0;
      padding: 0;
      color: var(--soft-ink);
      font-size: 0.78rem;
    }

    /* ---- TOC sticky rail ---- */
    .report-toc {
      display: none;
    }
    @media (min-width: 1100px) {
      .report-toc {
        display: block;
        position: sticky;
        top: var(--space-md);
        align-self: start;
        padding-top: var(--space-md);
        max-height: calc(100vh - var(--space-md) * 2);
        overflow-y: auto;
      }
    }
    .report-toc p {
      margin: 0 0 0.75rem;
      padding-bottom: 0.55rem;
      font-family: var(--font-ui);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--soft-ink);
      border-bottom: 1px solid var(--line);
      position: relative;
    }
    .report-toc p::after {
      content: "";
      position: absolute;
      left: 0;
      bottom: -1px;
      width: 1.4rem;
      height: 1px;
      background: var(--accent);
    }
    .report-toc ol {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .report-toc li { margin: 0; }
    .report-toc a {
      display: grid;
      grid-template-columns: 1.7rem 1fr;
      align-items: baseline;
      gap: 0.5rem;
      padding: 0.35rem 0.5rem 0.35rem 0.55rem;
      margin-left: -0.55rem;
      text-decoration: none;
      color: var(--soft-ink);
      font-size: 0.82rem;
      line-height: 1.35;
      border-left: 2px solid transparent;
      transition: color 180ms ease, border-color 180ms ease, background 180ms ease;
    }
    .report-toc a:hover { color: var(--ink); }
    .report-toc a.active {
      color: var(--accent-ink);
      border-left-color: var(--accent);
      background: color-mix(in oklch, var(--accent), transparent 94%);
    }
    .report-toc .toc-num {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      font-weight: 500;
      color: var(--faint-ink);
      letter-spacing: 0;
    }
    .report-toc a.active .toc-num { color: var(--accent); }
    .report-toc[lang="th"] a,
    html[lang="th"] .report-toc a { line-height: 1.55; }

    /* ---- Prose ---- */
    .prose {
      min-width: 0;
      max-width: 68ch;
      margin: 0;
      font-family: var(--font-body);
      font-size: var(--step-0);
      line-height: 1.78;
      animation: report-in 620ms cubic-bezier(0.16, 1, 0.3, 1) 80ms both;
    }
    .prose[lang="th"] {
      font-family: "Noto Serif Thai", var(--font-body);
      line-height: 1.9;
    }

    /* Drop cap on the first body paragraph (EN only — Thai combining marks
       make ::first-letter clip unreliably). Graceful: if the article's first
       child isn't a <p>, the rule simply doesn't apply. */
    .prose:not([lang="th"]) > :global(p:first-of-type)::first-letter {
      float: left;
      margin: 0.02em 0.08em 0 0;
      font-family: var(--font-display);
      font-weight: 650;
      font-size: 3.4em;
      line-height: 0.72;
      color: var(--accent-ink);
    }

    .prose :global(h1),
    .prose :global(h2),
    .prose :global(h3) {
      font-family: var(--font-display);
      letter-spacing: 0;
      color: var(--ink);
    }
    .prose[lang="th"] :global(h1),
    .prose[lang="th"] :global(h2),
    .prose[lang="th"] :global(h3) {
      font-family: "Noto Serif Thai", var(--font-display);
    }

    .prose :global(h1) {
      margin: 0 0 var(--space-lg);
      font-size: var(--step-3);
      font-weight: 650;
      line-height: 1.04;
    }
    /* Hero already prints the topic name, so suppress the body H1. */
    .prose :global(h1):first-child { display: none; }

    /* Labeled section headings — eyebrow small-caps over a faint rule (R2 §4.5). */
    .prose :global(h2) {
      margin: var(--space-xl) 0 var(--space-sm);
      padding-top: 0.75rem;
      border-top: var(--rule-faint);
      font-family: var(--font-ui);
      font-size: var(--step--1);
      font-weight: 700;
      line-height: 1.3;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: var(--soft-ink);
      scroll-margin-top: var(--space-md);
    }
    .prose[lang="th"] :global(h2) {
      font-family: var(--font-ui);
      letter-spacing: 0.01em;
      text-transform: none;
    }
    .prose :global(h2):first-of-type {
      margin-top: 0;
    }

    .prose :global(h3) {
      margin: var(--space-lg) 0 var(--space-xs);
      font-family: var(--font-display);
      font-size: var(--step-1);
      font-weight: 600;
      line-height: 1.2;
      color: var(--accent-ink);
    }

    .prose :global(p),
    .prose :global(ul),
    .prose :global(ol),
    .prose :global(blockquote),
    .prose :global(pre),
    .prose :global(table) {
      margin-top: 0;
      margin-bottom: var(--space-md);
    }
    .prose :global(p),
    .prose :global(li),
    .prose :global(blockquote) {
      overflow-wrap: break-word;
    }
    .prose :global(ul),
    .prose :global(ol) { padding-left: 1.4em; }
    .prose :global(li) {
      padding-left: 0.35em;
      margin: 0.55rem 0;
      line-height: 1.72;
    }
    .prose[lang="th"] :global(li) { line-height: 1.88; }
    .prose :global(li::marker) {
      color: var(--accent);
      font-weight: 700;
    }
    .prose :global(li ul),
    .prose :global(li ol) { margin: 0.35rem 0 0.5rem; }

    .prose :global(a) {
      color: var(--accent-ink);
      text-decoration-line: underline;
      text-decoration-color: color-mix(in oklch, var(--accent), transparent 25%);
      text-underline-offset: 0.22em;
    }
    .prose :global(strong) {
      font-weight: 650;
      color: var(--ink);
    }

    /* Pull quote — inline, no box, ember left edge, larger Fraunces (R2 §4.5). */
    .prose :global(blockquote) {
      margin: var(--space-md) 0;
      padding: 0.1rem 0 0.1rem var(--space-md);
      border-left: var(--rule-lead);
      background: none;
      max-width: 34ch;
      font-family: var(--font-display);
      font-weight: 500;
      font-size: var(--step-1);
      line-height: 1.3;
      color: var(--ink);
    }
    .prose[lang="th"] :global(blockquote) {
      font-family: "Noto Serif Thai", var(--font-display);
      line-height: 1.55;
    }
    .prose :global(blockquote p) { margin: 0; }

    /* ---- Inline citation chips (injected by client script) ---- */
    /* Citations: quiet superscript numerals — no chip/box/fill (CEO note: the
       boxed [19][54] markers cluttered the prose and hurt readability). They stay
       legible + clickable-feeling via the accent ink, but recede from the line. */
    .prose :global(sup.cite) {
      vertical-align: super;
      margin: 0 0.04em;
      font-family: var(--font-mono);
      font-feature-settings: "tnum" 1, "ss01" 1;
      font-size: 0.62em;
      font-weight: 500;
      line-height: 0;
      letter-spacing: 0;
      color: var(--faint-ink);
    }
    .prose :global(sup.cite + sup.cite)::before {
      content: ",";
      color: var(--faint-ink);
      margin: 0 0.05em 0 -0.02em;
    }

    /* ---- Table ---- */
    .prose :global(table) {
      display: block;
      width: 100%;
      max-width: 100%;
      overflow-x: auto;
      border-collapse: collapse;
      font-family: var(--font-ui);
      font-size: var(--step--1);
      line-height: 1.5;
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
    }
    .prose :global(th),
    .prose :global(td) {
      padding: 0.65rem 0.75rem;
      border-bottom: 1px solid var(--hairline);
      text-align: left;
      vertical-align: top;
    }
    .prose :global(th) {
      color: var(--soft-ink);
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      font-size: 0.7rem;
      background: color-mix(in oklch, var(--surface), transparent 25%);
      border-bottom-color: var(--line);
    }
    .prose :global(tbody tr:nth-child(even) td) {
      background: color-mix(in oklch, var(--surface), transparent 70%);
    }
    .prose :global(tbody tr:last-child td) { border-bottom: 0; }

    .prose :global(pre) {
      max-width: 100%;
      overflow-x: auto;
      padding: var(--space-sm);
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: 2px;
    }
    .prose :global(pre code) {
      padding: 0;
      border: 0;
      background: transparent;
    }
    .prose :global(hr) {
      border: 0;
      border-top: 1px solid var(--line);
      margin: var(--space-xl) 0;
    }

    /* ---- Top Posts stream (kept) ---- */
    .prose :global(.post-stream) {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(19rem, 1fr));
      gap: var(--space-md) var(--space-sm);
      margin: var(--space-md) 0 var(--space-lg);
      container-type: inline-size;
    }
    .prose :global(.ndf-card:first-child) {
      grid-column: 1 / -1;
    }
    .prose :global(.ndf-card) {
      position: relative;
      display: grid;
      grid-template-rows: auto 1fr;
      border-top: 1px solid var(--line);
      padding-top: var(--space-sm);
      background: transparent;
      font-family: var(--font-body);
      font-size: var(--step--1);
      gap: 0.6rem;
    }
    .prose :global(.ndf-card:not(:first-child)) {
      padding-inline: 0.05rem;
    }
    .prose :global(.ndf-card-head) {
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
      gap: 0.35rem 0.85rem;
      color: var(--soft-ink);
      font-family: var(--font-ui);
      font-size: 0.78rem;
      letter-spacing: 0.02em;
    }
    .prose :global(.ndf-author) {
      color: var(--ink);
      font-weight: 700;
      letter-spacing: 0;
      font-family: var(--font-ui);
    }
    .prose :global(.ndf-platform) {
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--accent-ink);
      font-weight: 700;
      font-size: 0.66rem;
    }
    .prose :global(.ndf-engagement) {
      margin-left: auto;
      color: var(--faint-ink);
      font-family: var(--font-mono);
      font-variant-numeric: tabular-nums slashed-zero;
      font-feature-settings: "ss01" 1;
      font-size: 0.74rem;
      letter-spacing: -0.005em;
    }
    .prose :global(.ndf-card-media) {
      display: block;
      aspect-ratio: 4 / 3;
      overflow: hidden;
      background: var(--surface);
    }
    .prose :global(.ndf-card-media img) {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), filter 0.3s ease;
      filter: saturate(0.92);
    }
    .prose :global(.ndf-card-media:hover img) {
      transform: scale(1.035);
      filter: saturate(1);
    }
    .prose :global(.ndf-x-embed) {
      margin: 0 !important;
      border: 1px solid var(--hairline) !important;
      padding: 0.55rem 0.8rem !important;
      background: color-mix(in oklch, var(--surface), transparent 60%) !important;
    }
    .prose :global(.ndf-card-body) {
      display: flex;
      flex-direction: column;
      gap: 0.55rem;
    }
    .prose :global(.ndf-quote) {
      margin: 0;
      color: var(--ink);
      font-family: var(--font-body);
      font-style: italic;
      font-size: 0.95em;
      line-height: 1.55;
      position: relative;
      padding-left: 1rem;
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 3;
      overflow: hidden;
    }
    .prose :global(.ndf-quote)::before {
      content: "\201C";
      position: absolute;
      left: 0;
      top: -0.1em;
      font-family: var(--font-display);
      font-size: 1.6em;
      line-height: 1;
      color: color-mix(in oklch, var(--accent), transparent 35%);
    }
    .prose :global(.ndf-fields) {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.45rem 0;
      margin: 0.3rem 0 0;
      padding: 0;
    }
    .prose :global(.ndf-fields dt) {
      margin: 0;
      padding-left: 0.65rem;
      position: relative;
      font-family: var(--font-ui);
      font-feature-settings: "smcp" 1, "c2sc" 1;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      color: var(--soft-ink);
      text-transform: lowercase;
    }
    .prose :global(.ndf-fields dt)::before {
      content: "";
      position: absolute;
      left: 0;
      top: 0.55em;
      width: 0.4rem;
      height: 1px;
      background: var(--soft-ink);
      opacity: 0.5;
    }
    .prose :global(.ndf-fields dd) {
      margin: 0.1rem 0 0 0.65rem;
      color: var(--ink);
      font-family: var(--font-body);
      line-height: 1.6;
    }
    .prose :global(.ndf-adapt-label) {
      color: var(--accent-ink) !important;
    }
    .prose :global(.ndf-adapt-label)::before {
      background: var(--accent) !important;
      opacity: 1 !important;
      width: 0.55rem !important;
    }
    .prose :global(.ndf-adapt) {
      margin: 0.15rem 0 0 0.65rem !important;
      color: var(--ink) !important;
      font-family: var(--font-body) !important;
      font-size: 0.98em !important;
      line-height: 1.55 !important;
      padding: 0.5rem 0 0.5rem 0.85rem;
      border-left: 2px solid var(--accent);
      background: linear-gradient(
        90deg,
        color-mix(in oklch, var(--accent), transparent 92%) 0%,
        transparent 65%
      );
    }
    .prose :global(.ndf-source) {
      margin-top: 0.35rem;
      align-self: flex-start;
      font-family: var(--font-ui);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      color: var(--accent-ink);
      text-decoration: none;
      border-bottom: 1px solid color-mix(in oklch, var(--accent), transparent 60%);
      padding-bottom: 0.08em;
      transition: border-color 0.15s ease;
    }
    .prose :global(.ndf-source:hover) { border-color: var(--accent); }

    @container (min-width: 44rem) {
      .prose :global(.ndf-card:first-child) {
        grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
        grid-template-rows: auto auto;
        column-gap: var(--space-md);
        row-gap: 0.55rem;
        align-items: start;
        padding-top: var(--space-md);
      }
      .prose :global(.ndf-card:first-child .ndf-card-head) {
        grid-column: 1 / -1;
      }
      .prose :global(.ndf-card:first-child .ndf-card-media),
      .prose :global(.ndf-card:first-child .ndf-x-embed) {
        grid-column: 1;
        grid-row: 2;
        aspect-ratio: 5 / 4;
        align-self: start;
        position: sticky;
        top: var(--space-md);
      }
      .prose :global(.ndf-card:first-child .ndf-card-body) {
        grid-column: 2;
        grid-row: 2;
      }
      .prose :global(.ndf-card:first-child .ndf-quote) {
        font-size: 1.1em;
        -webkit-line-clamp: 4;
        line-height: 1.5;
      }
      .prose :global(.ndf-card:first-child .ndf-quote)::before {
        font-size: 2em;
        top: -0.18em;
      }
      .prose :global(.ndf-card:first-child .ndf-fields dd) {
        font-size: 1.02em;
        line-height: 1.65;
      }
      .prose :global(.ndf-card:first-child .ndf-adapt) {
        font-size: 1.05em !important;
        padding: 0.7rem 0 0.7rem 1rem;
      }
    }
    @container (max-width: 36rem) {
      .prose :global(.ndf-card-media) { aspect-ratio: 16 / 9; }
      .prose :global(.ndf-quote) { -webkit-line-clamp: 5; }
    }

    /* ---- Sticky share bar (mobile/tablet ≤1023px) ---- */
    .sticky-share-bar {
      display: none;
    }
    @media (max-width: 1023px) {
      .sticky-share-bar {
        display: flex;
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        z-index: 40;
        align-items: center;
        justify-content: center;
        padding: 0.55rem 1.25rem;
        padding-bottom: calc(0.55rem + env(safe-area-inset-bottom, 0px));
        background: var(--bg);
        border-top: 1px solid var(--hairline);
      }
      .sticky-share-bar[hidden] { display: none; }
      @media (prefers-reduced-motion: no-preference) {
        .sticky-share-bar:not([hidden]) {
          animation: sticky-bar-in 180ms ease both;
        }
        @keyframes sticky-bar-in {
          from { opacity: 0; transform: translateY(6px); }
          to   { opacity: 1; transform: translateY(0); }
        }
      }
    }

    /* ---- KEY POINTS box (R2 §4.5) — hairline-ruled, ember left edge, no fill ---- */
    .keypoints {
      margin: var(--space-md) 0 0;
      padding: var(--space-sm) var(--space-md);
      border: var(--rule-section);
      border-left: var(--rule-lead);
    }
    .keypoints-lbl {
      margin: 0 0 0.5rem;
    }
    .keypoints ul {
      margin: 0;
      padding-left: 1.15em;
    }
    .keypoints li {
      margin: 0.4rem 0;
      line-height: 1.55;
      font-family: var(--font-body);
      font-size: var(--step-0);
      color: var(--soft-ink);
    }
    .keypoints li b {
      font-weight: 650;
      color: var(--ink);
    }
    .keypoints li::marker { color: var(--accent); }
    :lang(th) .keypoints li { line-height: 1.7; }

    /* ---- Report foot: same-topic prev/next edition + share (R2 §4.5) ---- */
    .r-foot {
      max-width: 70rem;
      margin: var(--space-lg) 0 0;
      padding: var(--space-md) 0 0;
      border-top: var(--rule-major);
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: var(--space-sm) var(--space-md);
      font-family: var(--font-ui);
      font-size: var(--step--1);
    }
    .r-foot .editions {
      display: inline-flex;
      align-items: baseline;
      flex-wrap: wrap;
      gap: 0.5rem 1.1rem;
      color: var(--soft-ink);
      letter-spacing: 0.02em;
    }
    .r-foot .editions a {
      min-height: 44px;
      display: inline-flex;
      align-items: center;
      text-decoration: none;
      color: var(--soft-ink);
      transition: color 0.15s ease;
    }
    .r-foot .editions a:hover { color: var(--accent-ink); }
    .r-foot .editions .num {
      font-family: var(--font-mono);
      font-feature-settings: "tnum" 1;
      letter-spacing: 0;
    }
    .r-foot .ed-cur { color: var(--faint-ink); }
    .r-foot .ed-cur .num { color: var(--soft-ink); }
    .r-foot .ed-latest { color: var(--accent-ink); }
    .r-foot .frontlink { color: var(--accent-ink); }
    .r-foot .frontlink:hover { text-decoration: underline; }
    .r-foot .report-share { margin: 0; padding: 0; border: 0; }

    @media (max-width: 720px) {
      .r-foot { flex-direction: column; align-items: flex-start; }
      /* leave room above the fixed mobile share bar */
      .r-foot { margin-bottom: calc(44px + env(safe-area-inset-bottom, 0px)); }
    }

    /* ---- Mobile collapse disclosure ---- */
    details[data-mobile-collapse] > summary {
      display: none;
    }
    @media (max-width: 720px) {
      details[data-mobile-collapse] > summary {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        list-style: none;
        cursor: pointer;
        padding: 0.75rem 0;
        margin: var(--space-md) 0 0;
        border-top: 1px solid var(--hairline);
        font-family: var(--font-mono);
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        color: var(--accent-ink);
        min-height: 44px;
        user-select: none;
      }
      details[data-mobile-collapse] > summary::after {
        content: "▾";
        font-size: 1rem;
        line-height: 1;
        transition: transform 160ms ease;
      }
      details[data-mobile-collapse][open] > summary::after {
        transform: rotate(-180deg);
      }
      @media (prefers-reduced-motion: reduce) {
        details[data-mobile-collapse] > summary::after {
          transition: none;
        }
      }
    }

    @keyframes hero-in {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes report-in {
      from { opacity: 0; transform: translateY(10px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes meter-in {
      from { width: 0; }
      to   { width: var(--w, 0%); }
    }

    @media (max-width: 720px) {
      .report-instruments {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 560px) {
      .report-hero h1 { font-size: var(--step-2); }
      .instrument-value { font-size: var(--step-1); }
      .prose { line-height: 1.72; }
      .prose[lang="th"] { line-height: 1.86; }
      .prose :global(ul),
      .prose :global(ol) { padding-left: 1.05em; }
      .prose :global(blockquote) { padding-left: var(--space-sm); }
      .prose :global(th),
      .prose :global(td) { padding: 0.55rem 0.62rem; }
      .prose:not([lang="th"]) > :global(p:first-of-type)::first-letter { font-size: 3em; }
    }
  </style>
</Base>
